@model ThriveHealth.Web.Models.ViewModels.BloodDonorInputViewModel
@{ ViewData["Title"] = "Register donor"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="th-section-title">Register donor</h1>
    <a asp-action="Donors" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Donors</a>
</div>

<form asp-action="NewDonor" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.BloodBankManage">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="th-card"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-person me-1"></i> Donor</h6>
                <div class="row g-3">
                    <div class="col-md-12"><label asp-for="FullName" class="form-label">Full name</label><input asp-for="FullName" class="form-control" /><span asp-validation-for="FullName" class="text-danger small"></span></div>
                    <div class="col-md-6"><label asp-for="DateOfBirth" class="form-label">DOB</label><input asp-for="DateOfBirth" type="date" class="form-control" /></div>
                    <div class="col-md-6">
                        <label asp-for="Sex" class="form-label">Sex</label>
                        <select asp-for="Sex" class="form-select"><option value="">—</option><option>Male</option><option>Female</option></select>
                    </div>
                    <div class="col-md-6"><label asp-for="Phone" class="form-label">Phone</label><input asp-for="Phone" class="form-control" /></div>
                    <div class="col-md-6"><label asp-for="Address" class="form-label">Address</label><input asp-for="Address" class="form-control" /></div>
                    <div class="col-md-6">
                        <label asp-for="BloodGroup" class="form-label">Group</label>
                        <select asp-for="BloodGroup" class="form-select">
                            <option value="0">Unknown</option>
                            <option value="1">O+</option><option value="2">O−</option>
                            <option value="3">A+</option><option value="4">A−</option>
                            <option value="5">B+</option><option value="6">B−</option>
                            <option value="7">AB+</option><option value="8">AB−</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DonorType" class="form-label">Donor type</label>
                        <select asp-for="DonorType" class="form-select">
                            <option value="1">Voluntary</option><option value="2">Family replacement</option>
                            <option value="3">Paid</option><option value="4">Autologous</option>
                        </select>
                    </div>
                </div>
            </div></div>
        </div>
        <div class="col-lg-6">
            <div class="th-card"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-shield-check me-1"></i> Screening</h6>
                <p class="small text-muted">Tick negative results. All five must be negative for unit acceptance.</p>
                <div class="row g-2">
                    <div class="col-md-6 form-check ms-3"><input name="HivNegative" value="true" type="checkbox" class="form-check-input" id="hiv" /><label for="hiv" class="form-check-label">HIV negative</label></div>
                    <div class="col-md-6 form-check"><input name="HepBNegative" value="true" type="checkbox" class="form-check-input" id="hbv" /><label for="hbv" class="form-check-label">HepB negative</label></div>
                    <div class="col-md-6 form-check ms-3"><input name="HepCNegative" value="true" type="checkbox" class="form-check-input" id="hcv" /><label for="hcv" class="form-check-label">HepC negative</label></div>
                    <div class="col-md-6 form-check"><input name="VdrlNegative" value="true" type="checkbox" class="form-check-input" id="vdrl" /><label for="vdrl" class="form-check-label">VDRL negative</label></div>
                    <div class="col-md-6 form-check ms-3"><input name="MalariaNegative" value="true" type="checkbox" class="form-check-input" id="mal" /><label for="mal" class="form-check-label">Malaria negative</label></div>
                </div>
                <div class="mt-3">
                    <label asp-for="Status" class="form-label">Donor status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="1">Accepted</option><option value="2">Deferred</option><option value="3">Rejected</option>
                    </select>
                </div>
                <div class="mt-2"><label asp-for="DeferralReason" class="form-label">Deferral reason</label><textarea asp-for="DeferralReason" class="form-control" rows="2"></textarea></div>
                <div class="mt-2"><label asp-for="Notes" class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
            </div></div>
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2 mt-3">
        <a asp-action="Donors" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary"><i class="bi bi-save me-1"></i> Register donor</button>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
