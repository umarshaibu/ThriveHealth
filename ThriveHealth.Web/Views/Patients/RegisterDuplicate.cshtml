@model ThriveHealth.Web.Models.ViewModels.PatientRegisterViewModel
@{
    ViewData["Title"] = "Possible duplicate";
    var auto = ViewBag.AutoMatch as ThriveHealth.Web.Services.MpiCandidate;
    var matches = ViewBag.Matches as IEnumerable<ThriveHealth.Web.Services.MpiCandidate> ?? Enumerable.Empty<ThriveHealth.Web.Services.MpiCandidate>();
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="th-section-title">
            <i class="bi bi-exclamation-triangle text-warning me-1"></i> Possible duplicate detected
        </h1>
        <p class="th-section-sub mb-0">The Master Patient Index found existing records that may already represent this patient.</p>
    </div>
</div>

@if (auto is not null)
{
    <div class="alert alert-warning d-flex align-items-start gap-2">
        <i class="bi bi-shield-exclamation fs-4"></i>
        <div>
            <strong>Strong match (@auto.Score.ToString("F0")% confidence)</strong> — this is very likely the same patient.
            We strongly recommend opening the existing record instead of creating a new one.
        </div>
    </div>
}

<div class="th-card mb-3">
    <div class="th-card-header"><h5 class="th-card-title">Candidate matches</h5></div>
    <div class="th-card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Hospital #</th>
                        <th>Name</th>
                        <th>Sex / DOB</th>
                        <th>Phone / NIN</th>
                        <th>Confidence</th>
                        <th>Reasons</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in matches)
                    {
                        var p = m.Patient;
                        <tr>
                            <td><span class="font-monospace">@p.HospitalNumber</span></td>
                            <td><strong>@p.FullName</strong></td>
                            <td>@p.Sex @(p.DateOfBirth?.ToString("dd MMM yyyy") ?? "—")</td>
                            <td><small class="text-muted">@p.Phone<br />@p.Nin</small></td>
                            <td>
                                <span class="th-pill @(m.Score >= 90 ? "th-pill-danger" : "th-pill-warning")">@m.Score.ToString("F0")%</span>
                            </td>
                            <td><small class="text-muted">@string.Join(", ", m.Reasons)</small></td>
                            <td class="text-end">
                                <a asp-action="Profile" asp-route-id="@p.Id" class="btn btn-sm btn-primary"><i class="bi bi-folder2-open me-1"></i> Open this record</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form asp-action="Register" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PatientsRegister">
    @Html.HiddenFor(m => m.FirstName)
    @Html.HiddenFor(m => m.LastName)
    @Html.HiddenFor(m => m.MiddleName)
    @Html.HiddenFor(m => m.Title)
    @Html.HiddenFor(m => m.DateOfBirth)
    @Html.HiddenFor(m => m.IsDateOfBirthEstimated)
    @Html.HiddenFor(m => m.Sex)
    @Html.HiddenFor(m => m.Gender)
    @Html.HiddenFor(m => m.Phone)
    @Html.HiddenFor(m => m.AlternatePhone)
    @Html.HiddenFor(m => m.WhatsAppOptIn)
    @Html.HiddenFor(m => m.Email)
    @Html.HiddenFor(m => m.StreetAddress)
    @Html.HiddenFor(m => m.Lga)
    @Html.HiddenFor(m => m.State)
    @Html.HiddenFor(m => m.Postcode)
    @Html.HiddenFor(m => m.MaritalStatus)
    @Html.HiddenFor(m => m.Occupation)
    @Html.HiddenFor(m => m.Religion)
    @Html.HiddenFor(m => m.StateOfOrigin)
    @Html.HiddenFor(m => m.EthnicGroup)
    @Html.HiddenFor(m => m.PreferredLanguage)
    @Html.HiddenFor(m => m.Nin)
    @Html.HiddenFor(m => m.DriversLicense)
    @Html.HiddenFor(m => m.VotersCard)
    @Html.HiddenFor(m => m.Passport)
    @Html.HiddenFor(m => m.NextOfKinName)
    @Html.HiddenFor(m => m.NextOfKinRelationship)
    @Html.HiddenFor(m => m.NextOfKinPhone)
    @Html.HiddenFor(m => m.NextOfKinAddress)
    @Html.HiddenFor(m => m.PrimaryPayerType)
    @Html.HiddenFor(m => m.PrimaryPayerName)
    @Html.HiddenFor(m => m.PrimaryPayerMembershipNumber)
    <input type="hidden" name="ConfirmAcceptDuplicate" value="true" />

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Register" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i> Edit details</a>
        <button class="btn btn-warning" type="submit"><i class="bi bi-person-plus me-1"></i> Create new record anyway</button>
    </div>
</form>
