@model IEnumerable<ThriveHealth.Web.Models.ViewModels.PharmacyWorklistRow>
@{ ViewData["Title"] = "Pharmacy worklist"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Pharmacy worklist</h1>
        <p class="th-section-sub mb-0">Prescriptions awaiting dispense. Oldest at the bottom.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Stock" class="btn btn-outline-primary"><i class="bi bi-box-seam me-1"></i> Stock</a>
        <a asp-action="ControlledRegister" class="btn btn-outline-warning"><i class="bi bi-shield-lock me-1"></i> Controlled register</a>
    </div>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Any())
{
    <div class="th-empty m-4"><i class="bi bi-prescription2"></i><h5 class="mt-2">No prescriptions waiting</h5><p>When a clinician issues an Rx in OPD it appears here.</p></div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Issued</th><th>Patient</th><th>Prescriber</th><th>Items</th><th>Outstanding</th><th>Status</th><th class="text-end"></th></tr></thead>
            <tbody>
            @foreach (var row in Model)
            {
                var r = row.Prescription;
                var statusTone = r.Status switch
                {
                    ThriveHealth.Web.Models.Clinical.PrescriptionStatus.Issued => "th-pill-warning",
                    ThriveHealth.Web.Models.Clinical.PrescriptionStatus.PartiallyDispensed => "th-pill-info",
                    ThriveHealth.Web.Models.Clinical.PrescriptionStatus.Dispensed => "th-pill-success",
                    _ => "th-pill-muted"
                };
                <tr>
                    <td>@r.IssuedAt.ToLocalTime().ToString("dd MMM HH:mm")<br /><small class="text-muted">Rx #@r.Id</small></td>
                    <td><strong>@r.Patient!.FullName</strong><br /><small class="font-monospace text-muted">@r.Patient.HospitalNumber</small></td>
                    <td>@r.PrescribedBy?.FullName<br /><small class="text-muted">@r.PrescribedBy?.LicenseBody @r.PrescribedBy?.LicenseNumber</small></td>
                    <td><span class="th-pill th-pill-muted">@row.ItemCount line@(row.ItemCount == 1 ? "" : "s")</span></td>
                    <td>@row.OutstandingItems lines · @row.OutstandingQuantity units</td>
                    <td><span class="th-pill @statusTone">@r.Status</span></td>
                    <td class="text-end">
                        <a asp-action="Dispense" asp-route-prescriptionId="@r.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PharmacyDispense" class="btn btn-sm btn-primary"><i class="bi bi-bag-check me-1"></i> Dispense</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
</div></div>
