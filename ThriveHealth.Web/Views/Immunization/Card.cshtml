@model ThriveHealth.Web.Models.ViewModels.ImmunizationCardViewModel
@using ThriveHealth.Web.Models.Immunization
@{
    ViewData["Title"] = $"Immunization card · {Model.Patient.FullName}";
    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var ageMo = (today.Year - Model.DateOfBirth.Year) * 12 + (today.Month - Model.DateOfBirth.Month);
    var grouped = Model.Rows.GroupBy(r => r.VaccineCode).OrderBy(g => g.First().VaccineCode).ToList();

    string Tone(DoseStatus s) => s switch
    {
        DoseStatus.Administered => "th-pill-success",
        DoseStatus.Missed => "th-pill-warning",
        DoseStatus.Refused => "th-pill-danger",
        DoseStatus.NotApplicable => "th-pill-muted",
        _ => "th-pill-info"
    };
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2 d-print-none">
    <div>
        <h1 class="th-section-title mb-1">@Model.Patient.FullName</h1>
        <div class="d-flex gap-2 flex-wrap">
            <span class="th-pill th-pill-muted font-monospace">@Model.Patient.HospitalNumber</span>
            <span class="th-pill th-pill-info">@Model.Patient.Sex · @(ageMo >= 24 ? $"{ageMo / 12} yr" : $"{ageMo} mo")</span>
            <span class="th-pill th-pill-muted">DOB: @Model.DateOfBirth.ToString("dd MMM yyyy")</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Worklist" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Worklist</a>
        <button class="btn btn-outline-primary" onclick="window.print()"><i class="bi bi-printer me-1"></i> Print card</button>
    </div>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="row g-3 mb-3 d-print-none">
    <div class="col-md-3"><div class="th-stat tone-success"><div class="th-stat-icon"><i class="bi bi-check2-all"></i></div><div class="th-stat-label">Administered</div><div class="th-stat-value">@Model.AdministeredCount</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-warning"><div class="th-stat-icon"><i class="bi bi-clock"></i></div><div class="th-stat-label">Due / pending</div><div class="th-stat-value">@Model.DueOrOverdueCount</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-info"><div class="th-stat-icon"><i class="bi bi-list-check"></i></div><div class="th-stat-label">Total scheduled</div><div class="th-stat-value">@Model.Rows.Count</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-primary"><div class="th-stat-icon"><i class="bi bi-graph-up"></i></div><div class="th-stat-label">Coverage</div><div class="th-stat-value">@(Model.Rows.Count == 0 ? "—" : ((int)(Model.AdministeredCount * 100.0 / Model.Rows.Count)) + "%")</div></div></div>
</div>

@foreach (var g in grouped)
{
    var first = g.First();
    <div class="th-card mb-3"><div class="th-card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="mb-0"><i class="bi bi-bandaid me-1"></i>@first.VaccineName <span class="text-muted small">· @first.VaccineCode</span></h6>
            <span class="th-pill th-pill-success">@g.Count(r => r.Status == DoseStatus.Administered) / @g.Count() given</span>
        </div>
        <table class="table align-middle mb-0">
            <thead><tr><th>Dose</th><th>Due</th><th>Administered</th><th>Batch</th><th>Status</th><th class="text-end d-print-none"></th></tr></thead>
            <tbody>
            @foreach (var r in g.OrderBy(x => x.RecommendedAgeWeeks))
            {
                <tr>
                    <td><span class="font-monospace small">@r.DoseLabel</span><div class="small text-muted">~@r.RecommendedAgeWeeks wk</div></td>
                    <td>@r.DueDate.ToString("dd MMM yyyy")</td>
                    <td>@(r.AdministeredAt?.ToLocalTime().ToString("dd MMM yyyy") ?? "—")</td>
                    <td><small>@r.BatchNumber</small></td>
                    <td><span class="th-pill @Tone(r.Status)">@r.Status</span></td>
                    <td class="text-end d-print-none">
                        @if (r.Status == DoseStatus.Due && r.ExistingDoseId.HasValue)
                        {
                            <button type="button" class="btn btn-sm btn-success js-give"
                                    data-bs-toggle="modal" data-bs-target="#giveDose"
                                    data-id="@r.ExistingDoseId" data-label="@r.DoseLabel · @r.VaccineName"
                                    asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ImmunizationAdminister">
                                <i class="bi bi-check-lg me-1"></i> Administer
                            </button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div></div>
}

<div class="modal fade d-print-none" id="giveDose" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Administer" method="post" class="modal-content" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ImmunizationAdminister">
            @Html.AntiForgeryToken()
            <input type="hidden" name="DoseId" id="dose_id" />
            <input type="hidden" name="PatientId" value="@Model.Patient.Id" />
            <div class="modal-header"><h5 class="modal-title">Administer dose</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-2"><strong id="dose_label"></strong></div>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Batch / lot #</label><input name="BatchNumber" class="form-control" maxlength="40" /></div>
                    <div class="col-md-6"><label class="form-label">Expiry</label><input name="ExpiryDate" type="date" class="form-control" /></div>
                    <div class="col-md-6"><label class="form-label">Site</label><input name="Site" class="form-control" maxlength="40" placeholder="Right deltoid…" /></div>
                    <div class="col-12"><label class="form-label">Notes</label><textarea name="Notes" class="form-control" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success"><i class="bi bi-check2-circle me-1"></i> Record dose</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('giveDose').addEventListener('show.bs.modal', function (e) {
        var btn = e.relatedTarget;
        document.getElementById('dose_id').value = btn.dataset.id;
        document.getElementById('dose_label').textContent = btn.dataset.label;
    });
</script>
}
