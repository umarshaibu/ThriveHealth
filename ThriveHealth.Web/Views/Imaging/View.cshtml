@model ThriveHealth.Web.Models.Clinical.ImagingOrder
@{
    ViewData["Title"] = "Imaging report";
    var rep = Model.Report;
    var stage = rep is null ? "Awaiting performance"
              : !rep.PerformedAt.HasValue ? "Awaiting performance"
              : !rep.ReportedAt.HasValue ? "Performed · drafting"
              : !rep.AuthorizedAt.HasValue ? "Reported · awaiting auth"
              : "Authorised";
    var stageTone = rep is null || !rep.PerformedAt.HasValue ? "th-pill-info"
                  : !rep.ReportedAt.HasValue ? "th-pill-warning"
                  : !rep.AuthorizedAt.HasValue ? "th-pill-warning" : "th-pill-success";
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <span class="th-pill @stageTone">@stage</span>
        @if (rep?.HasCriticalFinding == true) { <span class="th-pill th-pill-danger ms-2"><i class="bi bi-exclamation-octagon-fill"></i> CRITICAL</span> }
        <h1 class="th-section-title mt-2">@Model.Modality · @Model.StudyDescription</h1>
        <p class="th-section-sub mb-0">
            <strong>@Model.Patient!.FullName</strong> · <span class="font-monospace">@Model.Patient.HospitalNumber</span>
            @if (!string.IsNullOrEmpty(Model.AccessionNumber)) { <span> · <span class="font-monospace">@Model.AccessionNumber</span></span> }
            · Ordered @Model.OrderedAt.ToLocalTime().ToString("dd MMM HH:mm") by @Model.OrderedBy?.FullName
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Worklist" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Worklist</a>
        @if (rep is not null && !rep.AuthorizedAt.HasValue && rep.ReportedAt.HasValue)
        {
            <form asp-action="Authorize" asp-route-id="@Model.Id" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ImagingReport">
                @Html.AntiForgeryToken()
                <button class="btn btn-success"><i class="bi bi-shield-check me-1"></i> Authorise report</button>
            </form>
        }
        @if (rep is not null && !rep.AuthorizedAt.HasValue)
        {
            <a asp-action="Report" asp-route-id="@Model.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ImagingReport" class="btn btn-primary"><i class="bi bi-pencil me-1"></i> Edit report</a>
        }
        <button onclick="window.print()" class="btn btn-outline-primary"><i class="bi bi-printer me-1"></i> Print</button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small">Study</h6>
            <div class="row small">
                <div class="col-5 text-muted">Modality</div><div class="col-7 fw-semibold">@Model.Modality</div>
                <div class="col-5 text-muted">Study</div><div class="col-7 fw-semibold">@Model.StudyDescription</div>
                <div class="col-5 text-muted">Indication</div><div class="col-7">@(Model.ClinicalIndication ?? "—")</div>
                <div class="col-5 text-muted">Urgency</div><div class="col-7">@Model.Urgency</div>
                @if (rep != null)
                {
                    <div class="col-5 text-muted">Technique</div><div class="col-7">@(rep.Technique ?? "—")</div>
                    <div class="col-5 text-muted">Contrast</div><div class="col-7">@(rep.Contrast ?? "—")</div>
                }
            </div>
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small">DICOM &amp; workflow</h6>
            <div class="row small">
                <div class="col-5 text-muted">Performed</div><div class="col-7">@(rep?.PerformedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</div>
                <div class="col-5 text-muted">By</div><div class="col-7">@(rep?.PerformedBy?.FullName ?? "—")</div>
                <div class="col-5 text-muted">Reported</div><div class="col-7">@(rep?.ReportedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</div>
                <div class="col-5 text-muted">By</div><div class="col-7">@(rep?.ReportedBy?.FullName ?? "—")</div>
                <div class="col-5 text-muted">Authorised</div><div class="col-7">@(rep?.AuthorizedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</div>
                <div class="col-5 text-muted">By</div><div class="col-7">@(rep?.AuthorizedBy?.FullName ?? "—")</div>
                @if (rep != null && !string.IsNullOrEmpty(rep.DicomStudyUid))
                { <div class="col-5 text-muted">Study UID</div><div class="col-7 font-monospace small">@rep.DicomStudyUid</div> }
                @if (rep != null && !string.IsNullOrEmpty(rep.DicomViewerUrl))
                { <div class="col-12 mt-2"><a href="@rep.DicomViewerUrl" target="_blank" class="btn btn-sm btn-outline-info w-100"><i class="bi bi-image me-1"></i> Open DICOM viewer</a></div> }
            </div>
        </div></div>
    </div>
</div>

@if (rep != null && (!string.IsNullOrEmpty(rep.Findings) || !string.IsNullOrEmpty(rep.Impression)))
{
    <div class="th-card mb-3"><div class="th-card-body">
        @if (!string.IsNullOrEmpty(rep.Findings))
        { <h5 class="text-uppercase text-muted small">Findings</h5><pre class="mb-3" style="white-space:pre-wrap;font-family:inherit;">@rep.Findings</pre> }
        @if (!string.IsNullOrEmpty(rep.Impression))
        { <h5 class="text-uppercase text-muted small">Impression</h5><pre class="mb-3" style="white-space:pre-wrap;font-family:inherit;font-weight:600;">@rep.Impression</pre> }
        @if (!string.IsNullOrEmpty(rep.Recommendation))
        { <h5 class="text-uppercase text-muted small">Recommendation</h5><pre class="mb-0" style="white-space:pre-wrap;font-family:inherit;">@rep.Recommendation</pre> }
    </div></div>
}
else
{
    <div class="th-empty"><i class="bi bi-hourglass-split"></i><h5 class="mt-2">Report not yet entered</h5></div>
}
