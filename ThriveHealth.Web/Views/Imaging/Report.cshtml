@model ThriveHealth.Web.Models.ViewModels.ImagingReportEntryViewModel
@{
    ViewData["Title"] = "Imaging report";
    var ai = ViewBag.AiSuggestion as ThriveHealth.Web.Models.Ai.AiSuggestion;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="th-pill th-pill-info">@Model.Order.Modality</span>
        <h1 class="th-section-title mt-2">@Model.Order.StudyDescription</h1>
        <p class="th-section-sub mb-0">
            <strong>@Model.Patient.FullName</strong> · <span class="font-monospace">@Model.Patient.HospitalNumber</span>
            @if (!string.IsNullOrEmpty(Model.Order.AccessionNumber)) { <span> · <span class="font-monospace text-muted">@Model.Order.AccessionNumber</span></span> }
            · Indication: @(Model.Order.ClinicalIndication ?? "—")
        </p>
    </div>
    <a asp-action="Worklist" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Worklist</a>
</div>

<div class="th-card mb-3" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiImagingDraft">
    <div class="th-card-header d-flex justify-content-between align-items-center">
        <h5 class="th-card-title mb-0"><i class="bi bi-stars me-1 text-primary"></i> AI report draft <span class="th-pill th-pill-info ms-2">DRAFT — radiologist must verify</span></h5>
        <form asp-action="DraftImaging" asp-route-id="@Model.Order.Id" method="post" class="d-inline" id="aiImagingForm" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiImagingDraft">
            @Html.AntiForgeryToken()
            <input type="hidden" name="findings" id="aiFindings" />
            <input type="hidden" name="technique" id="aiTechnique" />
            <input type="hidden" name="contrast" id="aiContrast" />
            <button type="button" onclick="aiCopyAndSubmit()" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-clockwise me-1"></i> @(ai == null ? "Draft" : "Re-draft")</button>
        </form>
    </div>
    <div class="th-card-body">
        @if (ai == null)
        {
            <p class="text-muted small mb-0">Enter findings (and optional technique/contrast) above, then click <em>Draft</em>. The AI will draft an Impression and Recommendation. Review and copy into the form before saving.</p>
        }
        else if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Failed)
        {
            <div class="alert alert-warning mb-0"><strong>AI failed:</strong> @ai.ErrorMessage</div>
        }
        else
        {
            <div class="small text-muted mb-2">
                Generated @ai.CreatedAtUtc.ToLocalTime().ToString("dd MMM HH:mm") · @ai.Provider/@ai.Model · status <strong>@ai.Status</strong>
            </div>
            <pre class="mb-2" style="white-space:pre-wrap;font-family:inherit">@(ai.EditedContent ?? ai.Response)</pre>
            @if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Pending)
            {
                <form asp-action="ReviewImagingDraft" method="post" class="d-flex gap-2 flex-wrap" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiImagingDraft">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="suggestionId" value="@ai.Id" />
                    <button name="status" value="Accepted" class="btn btn-sm btn-success"><i class="bi bi-check2-circle me-1"></i> Accept</button>
                    <button name="status" value="Rejected" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle me-1"></i> Reject</button>
                </form>
            }
        }
    </div>
</div>

<form asp-action="Report" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ImagingPerform">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
    <input type="hidden" name="Order.Id" value="@Model.Order.Id" />

    <div class="row g-3">
        <div class="col-md-3"><label asp-for="Technique" class="form-label"></label><input asp-for="Technique" class="form-control" placeholder="PA chest, supine AP..." /></div>
        <div class="col-md-3"><label asp-for="Contrast" class="form-label"></label><input asp-for="Contrast" class="form-control" placeholder="None / IV iodinated / Barium..." /></div>
        <div class="col-md-3"><label asp-for="DicomStudyUid" class="form-label">DICOM Study UID</label><input asp-for="DicomStudyUid" class="form-control" /></div>
        <div class="col-md-3"><label asp-for="DicomViewerUrl" class="form-label">DICOM viewer URL</label><input asp-for="DicomViewerUrl" class="form-control" /></div>

        <div class="col-12">
            <div class="th-card"><div class="th-card-body">
                <label asp-for="Findings" class="form-label fw-bold">Findings</label>
                <textarea asp-for="Findings" rows="6" class="form-control" placeholder="Describe systematically: bones, soft tissue, lungs, heart, mediastinum..."></textarea>
            </div></div>
        </div>
        <div class="col-12">
            <div class="th-card"><div class="th-card-body">
                <label asp-for="Impression" class="form-label fw-bold">Impression</label>
                <textarea asp-for="Impression" rows="4" class="form-control" placeholder="Concise summary diagnoses, in order of importance..."></textarea>
            </div></div>
        </div>
        <div class="col-12">
            <div class="th-card"><div class="th-card-body">
                <label asp-for="Recommendation" class="form-label">Recommendation</label>
                <input asp-for="Recommendation" class="form-control" placeholder="Suggest CT abdomen, repeat in 4 weeks..." />
            </div></div>
        </div>

        <div class="col-12">
            <div class="alert alert-warning d-flex align-items-center gap-2">
                <input asp-for="HasCriticalFinding" class="form-check-input" type="checkbox" />
                <label asp-for="HasCriticalFinding" class="form-check-label fw-bold">
                    <i class="bi bi-exclamation-octagon-fill text-danger me-1"></i> Critical finding — flag urgently
                </label>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">
        <a asp-action="Worklist" class="btn btn-outline-secondary">Cancel</a>
        <button name="Finalize" value="false" class="btn btn-outline-primary"><i class="bi bi-save me-1"></i> Save draft</button>
        <button name="Finalize" value="true" class="btn btn-primary"><i class="bi bi-check2-circle me-1"></i> Save &amp; finalise report</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function aiCopyAndSubmit() {
            var f = document.getElementById('Findings');
            var t = document.getElementById('Technique');
            var c = document.getElementById('Contrast');
            document.getElementById('aiFindings').value = f ? f.value : '';
            document.getElementById('aiTechnique').value = t ? t.value : '';
            document.getElementById('aiContrast').value = c ? c.value : '';
            document.getElementById('aiImagingForm').submit();
        }
    </script>
}
