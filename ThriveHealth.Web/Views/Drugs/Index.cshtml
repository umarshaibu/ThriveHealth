@model ThriveHealth.Web.Models.ViewModels.DrugListViewModel
@{ ViewData["Title"] = "Drug master"; }

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Drug master</h1>
        <p class="th-section-sub mb-0">@Model.Total drug@(Model.Total == 1 ? "" : "s") on the formulary. NAFDAC numbers required for regulated dispensing.</p>
    </div>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex" style="min-width:280px;">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="search" name="q" value="@Model.Search" class="form-control border-start-0" placeholder="Generic, brand, NAFDAC, category…" />
            </div>
        </form>
        <a asp-action="Create" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PharmacyStock" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add drug</a>
    </div>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Drugs.Any())
{
    <div class="th-empty m-4"><i class="bi bi-capsule"></i><h5 class="mt-2">No drugs match</h5></div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Generic</th><th>Brand</th><th>Strength</th><th>Form</th>
                    <th>NAFDAC #</th><th>Category</th><th>Schedule</th><th>Price (₦)</th><th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Drugs)
                {
                    var schTone = d.Schedule == ThriveHealth.Web.Models.Pharmacy.DrugCategory.OverTheCounter ? "th-pill-success"
                                : d.IsControlled ? "th-pill-danger" : "th-pill-warning";
                    <tr>
                        <td><strong>@d.GenericName</strong></td>
                        <td>@(d.BrandName ?? "—")</td>
                        <td>@d.Strength</td>
                        <td>@d.DoseForm</td>
                        <td><span class="font-monospace small">@(d.NafdacNumber ?? "—")</span></td>
                        <td><small class="text-muted">@d.Category</small></td>
                        <td><span class="th-pill @schTone">@d.Schedule</span></td>
                        <td>@d.UnitPrice?.ToString("N0")</td>
                        <td class="text-end"><a asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div></div>
