@model List<ThriveHealth.Web.Controllers.RolesController.RoleRow>
@using ThriveHealth.Web.Models.Identity
@{
    ViewData["Title"] = "Roles & permissions";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Roles &amp; permissions</h1>
        <p class="th-section-sub mb-0">@Model.Count role@(Model.Count == 1 ? "" : "s") · permissions are checked on every action</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> New role</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="th-card"><div class="th-card-body p-0">
    <table class="table align-middle mb-0">
        <thead><tr><th>Role</th><th>Users</th><th>Permissions</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var r in Model)
        {
            var isBuiltIn = Roles.All.Contains(r.Name);
            <tr>
                <td>
                    <strong>@r.Name</strong>
                    @if (isBuiltIn) { <span class="th-pill th-pill-muted ms-1">Built-in</span> }
                </td>
                <td>@r.UserCount</td>
                <td>
                    @if (r.PermissionCount == 0) { <span class="th-pill th-pill-warning">No permissions</span> }
                    else { <span class="th-pill th-pill-success">@r.PermissionCount permission@(r.PermissionCount == 1 ? "" : "s")</span> }
                </td>
                <td class="text-end">
                    <a asp-action="Permissions" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-shield-check me-1"></i> Edit permissions</a>
                    @if (!isBuiltIn && r.UserCount == 0)
                    {
                        <form asp-action="Delete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@r.Id" />
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete role @r.Name?')"><i class="bi bi-trash"></i></button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div></div>
