@model ThriveHealth.Web.Models.ViewModels.AdmitViewModel
@{
    ViewData["Title"] = "Admit patient";
    var beds = ViewBag.Beds as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="th-section-title">Admit patient</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<form asp-action="Admit" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AdmissionsManage">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
    <input type="hidden" asp-for="SourceEncounterId" />

    <div class="row g-3">
        <div class="col-md-6">
            <div class="th-card h-100"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-person me-1"></i> Patient</h6>
                <label class="form-label">Search</label>
                <div class="position-relative">
                    <input type="text" id="patientSearch" class="form-control" placeholder="Hospital #, name, phone…" autocomplete="off" value="@Model.PatientLabel" />
                    <input type="hidden" asp-for="PatientId" id="patientId" />
                    <div id="patientResults" class="list-group position-absolute w-100" style="z-index:1000;"></div>
                </div>
                <div id="patientPick" class="mt-3 p-2 border rounded-3 bg-light @(Model.PatientId.HasValue ? "" : "d-none")">
                    <i class="bi bi-person-fill text-primary"></i> <span id="patientPickLabel">@Model.PatientLabel</span>
                </div>
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="th-card h-100"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-hospital me-1"></i> Ward &amp; bed</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="WardId" class="form-label">Ward</label>
                        <select asp-for="WardId" asp-items="ViewBag.Wards" id="wardSelect" class="form-select"><option value="">--</option></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BedId" class="form-label">Bed</label>
                        <select asp-for="BedId" id="bedSelect" class="form-select"><option value="">--</option></select>
                    </div>
                    <div class="col-md-12">
                        <label asp-for="AdmittingDoctorId" class="form-label">Admitting doctor</label>
                        <select asp-for="AdmittingDoctorId" asp-items="ViewBag.Doctors" class="form-select"><option value="">--</option></select>
                    </div>
                </div>
            </div></div>
        </div>
        <div class="col-12">
            <div class="th-card"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-card-text me-1"></i> Clinical</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ReasonForAdmission" class="form-label"></label>
                        <input asp-for="ReasonForAdmission" class="form-control" placeholder="Severe malaria with anaemia for monitoring..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="WorkingDiagnosis" class="form-label"></label>
                        <input asp-for="WorkingDiagnosis" class="form-control" placeholder="?Severe malaria, ?co-existing typhoid" />
                    </div>
                </div>
            </div></div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary"><i class="bi bi-person-plus-fill me-1"></i> Admit patient</button>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
const beds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(beds));

const $search = document.getElementById('patientSearch');
const $results = document.getElementById('patientResults');
const $patientId = document.getElementById('patientId');
const $patientPick = document.getElementById('patientPick');
const $patientPickLabel = document.getElementById('patientPickLabel');

let timer;
$search.addEventListener('input', () => {
    clearTimeout(timer);
    const q = $search.value.trim();
    if (q.length < 2) { $results.innerHTML = ''; return; }
    timer = setTimeout(async () => {
        const r = await fetch('/Patients/Search?q=' + encodeURIComponent(q));
        const items = await r.json();
        $results.innerHTML = items.map(p =>
            `<a href="#" data-id="${p.id}" data-label="${p.name} · ${p.hospitalNumber}" class="list-group-item list-group-item-action small">
                <strong>${p.name}</strong> <span class="font-monospace text-muted">${p.hospitalNumber}</span>${p.phone ? `<br><small class="text-muted">${p.phone}</small>` : ''}
            </a>`).join('');
        $results.querySelectorAll('a').forEach(el => el.addEventListener('click', e => {
            e.preventDefault();
            $patientId.value = el.dataset.id;
            $patientPickLabel.textContent = el.dataset.label;
            $patientPick.classList.remove('d-none');
            $search.value = el.dataset.label;
            $results.innerHTML = '';
        }));
    }, 200);
});

const $ward = document.getElementById('wardSelect');
const $bed = document.getElementById('bedSelect');
function refreshBeds() {
    const wid = parseInt($ward.value, 10);
    const filtered = isNaN(wid) ? [] : beds.filter(b => b.wardId === wid);
    $bed.innerHTML = '<option value="">--</option>' + filtered.map(b => `<option value="${b.id}">${b.display}</option>`).join('');
}
$ward.addEventListener('change', refreshBeds);
refreshBeds();
</script>
}
