@model ThriveHealth.Web.Models.ViewModels.HealthCheckViewModel
@{ ViewData["Title"] = "Security & hardening"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Security &amp; hardening</h1>
        <p class="th-section-sub mb-0">Operational status of security controls, integrations, and database</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Audit" class="btn btn-outline-secondary"><i class="bi bi-journal-text me-1"></i> Audit log</a>
        <a asp-action="Integrations" class="btn btn-outline-secondary"><i class="bi bi-plug me-1"></i> Integrations</a>
        <a href="/health" target="_blank" class="btn btn-outline-success"><i class="bi bi-heart-pulse me-1"></i> /health</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-database-check me-1"></i> Application & database</h6>
            <dl class="row mb-0">
                <dt class="col-5">App version</dt><dd class="col-7"><span class="font-monospace">@Model.AppVersion</span></dd>
                <dt class="col-5">Server time (UTC)</dt><dd class="col-7">@Model.ServerTimeUtc.ToString("dd MMM yyyy HH:mm:ss")</dd>
                <dt class="col-5">Database</dt><dd class="col-7">@if (Model.DbReachable) { <span class="th-pill th-pill-success"><i class="bi bi-check-circle me-1"></i>Reachable</span> } else { <span class="th-pill th-pill-danger"><i class="bi bi-x-circle me-1"></i>Unreachable</span> }</dd>
                <dt class="col-5">PostgreSQL version</dt><dd class="col-7"><small class="font-monospace">@Model.DbVersion</small></dd>
                <dt class="col-5">Migrations applied</dt><dd class="col-7">@Model.MigrationsApplied</dd>
            </dl>
        </div></div>

        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-shield-lock me-1"></i> Security controls</h6>
            <dl class="row mb-0">
                <dt class="col-5">HTTPS redirect</dt><dd class="col-7"><span class="th-pill th-pill-success">Enabled</span></dd>
                <dt class="col-5">HSTS</dt><dd class="col-7">@if (Model.HstsEnabled) { <span class="th-pill th-pill-success">Enabled (production)</span> } else { <span class="th-pill th-pill-warning">Disabled</span> }</dd>
                <dt class="col-5">Rate limiting</dt><dd class="col-7">@if (Model.RateLimitingEnabled) { <span class="th-pill th-pill-success">Auth: 10/min · Portal: 5/min</span> } else { <span class="th-pill th-pill-warning">Disabled</span> }</dd>
                <dt class="col-5">Account lockout</dt><dd class="col-7"><span class="th-pill th-pill-success">5 fail/10 min</span></dd>
                <dt class="col-5">Antiforgery tokens</dt><dd class="col-7"><span class="th-pill th-pill-success">All POST forms</span></dd>
                <dt class="col-5">Two-cookie auth</dt><dd class="col-7"><span class="th-pill th-pill-success">Staff + Portal isolated</span></dd>
                <dt class="col-5">Audit logging</dt><dd class="col-7"><span class="th-pill th-pill-success">Active</span></dd>
            </dl>
        </div></div>
    </div>

    <div class="col-lg-6">
        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-list-check me-1"></i> HTTP security headers</h6>
            <table class="table table-sm mb-0">
                <thead><tr><th>Header</th><th>Status / value</th></tr></thead>
                <tbody>
                @foreach (var kv in Model.SecurityHeaders)
                {
                    <tr><td class="font-monospace small">@kv.Key</td><td><small>@kv.Value</small></td></tr>
                }
                </tbody>
            </table>
        </div></div>

        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-plug me-1"></i> Integration providers</h6>
            <dl class="row mb-0">
                <dt class="col-5">SMS</dt><dd class="col-7"><span class="th-pill th-pill-info">@Model.SmsProvider</span></dd>
                <dt class="col-5">Email</dt><dd class="col-7"><span class="th-pill th-pill-info">@Model.EmailProvider</span></dd>
                <dt class="col-5">Payment</dt><dd class="col-7"><span class="th-pill th-pill-info">@Model.PaymentProvider</span></dd>
                <dt class="col-5">Telemed video</dt><dd class="col-7"><span class="th-pill th-pill-info">In-app token rooms (provider pluggable)</span></dd>
            </dl>
            <hr />
            <small class="text-muted">Swap providers in <code>Program.cs</code> by replacing the <code>ISmsGateway</code>, <code>IEmailGateway</code>, and <code>IPaymentGateway</code> registrations with concrete adapters (Termii, SendGrid, Paystack, etc.).</small>
        </div></div>
    </div>
</div>
