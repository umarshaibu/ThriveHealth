@model ThriveHealth.Web.Models.ViewModels.AuditFilterViewModel
@using ThriveHealth.Web.Models.Audit
@{
    ViewData["Title"] = "Audit log";
    string CTone(AuditCategory c) => c switch
    {
        AuditCategory.Authentication => "th-pill-info",
        AuditCategory.SecurityEvent => "th-pill-danger",
        AuditCategory.DataChange => "th-pill-warning",
        AuditCategory.BusinessAction => "th-pill-primary",
        _ => "th-pill-muted"
    };
    string OTone(AuditOutcome o) => o switch
    {
        AuditOutcome.Success => "th-pill-success",
        AuditOutcome.Failure => "th-pill-danger",
        AuditOutcome.Warning => "th-pill-warning",
        _ => "th-pill-muted"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Audit log</h1>
        <p class="th-section-sub mb-0">@Model.Entries.Count visible · @Model.TotalLast24h events in last 24h · @Model.FailuresLast24h failure(s)</p>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-primary" onclick="aiAuditScan()" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiAuditAnomaly"><i class="bi bi-stars me-1"></i> AI anomaly scan</button>
        <a asp-action="Hardening" class="btn btn-outline-secondary"><i class="bi bi-shield-check me-1"></i> Hardening</a>
    </div>
</div>

<div id="aiAuditCard" class="th-card mb-3" style="display:none">
    <div class="th-card-header"><h5 class="th-card-title mb-0"><i class="bi bi-stars me-1 text-primary"></i> AI audit-log anomaly scan <span class="th-pill th-pill-info ms-2">SUGGESTION — security officer decides</span></h5></div>
    <div class="th-card-body"><pre id="aiAuditOut" class="mb-0" style="white-space:pre-wrap;font-family:inherit"></pre></div>
</div>

<form method="get" class="th-card mb-3"><div class="th-card-body">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small mb-1">Category</label>
            <select name="category" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var c in Enum.GetValues<AuditCategory>())
                {
                    <option value="@c" selected="@(Model.Category == c)">@c</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small mb-1">Outcome</label>
            <select name="outcome" class="form-select form-select-sm">
                <option value="">All</option>
                @foreach (var o in Enum.GetValues<AuditOutcome>())
                {
                    <option value="@o" selected="@(Model.Outcome == o)">@o</option>
                }
            </select>
        </div>
        <div class="col-md-3"><label class="form-label small mb-1">Action contains</label><input name="action" value="@Model.Action" class="form-control form-control-sm" placeholder="bill.payment, idsr.ncdc…" /></div>
        <div class="col-md-2"><label class="form-label small mb-1">Since</label><input name="since" value="@(Model.Since?.ToString("yyyy-MM-dd"))" type="date" class="form-control form-control-sm" /></div>
        <div class="col-md-2"><button class="btn btn-primary btn-sm w-100"><i class="bi bi-funnel me-1"></i>Filter</button></div>
    </div>
</div></form>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Entries.Any())
{
    <div class="th-empty m-4"><i class="bi bi-journal-text"></i><h5 class="mt-2">No audit events match</h5></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Time</th><th>Action</th><th>Category</th><th>Actor</th><th>Entity</th><th>Outcome</th><th>Summary</th><th>IP</th></tr></thead>
        <tbody>
        @foreach (var e in Model.Entries)
        {
            <tr class="@(e.Outcome == AuditOutcome.Failure ? "table-danger" : "")">
                <td><small>@e.AtUtc.ToLocalTime().ToString("dd MMM HH:mm:ss")</small></td>
                <td><span class="font-monospace small">@e.Action</span></td>
                <td><span class="th-pill @CTone(e.Category)">@e.Category</span></td>
                <td><small>@(e.ActorUser?.FullName ?? e.ActorName ?? "—")@if (!string.IsNullOrEmpty(e.ActorScheme)) { <span class="text-muted ms-1">[@e.ActorScheme]</span> }</small></td>
                <td><small>@e.EntityType@(string.IsNullOrEmpty(e.EntityKey) ? "" : " #" + e.EntityKey)</small></td>
                <td><span class="th-pill @OTone(e.Outcome)">@e.Outcome</span></td>
                <td><small>@e.Summary</small></td>
                <td><small class="text-muted">@e.IpAddress</small></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>

@section Scripts {
<script>
async function aiAuditScan() {
    var card = document.getElementById('aiAuditCard');
    var out = document.getElementById('aiAuditOut');
    card.style.display = 'block';
    out.textContent = 'Scanning last 24h…';
    try {
        var r = await fetch('/Ai/AuditAnomalyRun?hours=24', { method: 'POST' });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
</script>
}
