@model ThriveHealth.Web.Models.Identity.ApplicationUser
@using ThriveHealth.Web.Models.Identity
@{
    ViewData["Title"] = Model.FullName;
    var roles = (IList<string>)ViewBag.Roles;
    var allRoles = (List<string>)ViewBag.AllRoles;
    var tenant = ViewBag.Tenant as ThriveHealth.Web.Models.Tenancy.Tenant;
    var facility = ViewBag.Facility as ThriveHealth.Web.Models.Identity.Facility;
    var tempPassword = TempData["TempPassword"] as string;
}

<a asp-action="Index" class="small">← Back to all users</a>

<div class="d-flex justify-content-between align-items-start mt-2 mb-3">
    <div>
        <h1 class="sa-h1">@Model.FullName</h1>
        <p class="sa-sub mb-0">@Model.Email · @(Model.Designation ?? "—") · staff# @(Model.StaffNumber ?? "—")</p>
    </div>
    <div class="text-end">
        @if (Model.IsActive) { <span class="badge-pill badge-active" style="font-size:.85rem;">Active</span> }
        else { <span class="badge-pill badge-suspended" style="font-size:.85rem;">Inactive</span> }
        @if (Model.LastLoginAt.HasValue)
        { <div class="small text-muted mt-1">last login @Model.LastLoginAt?.ToString("dd MMM yyyy HH:mm")</div> }
    </div>
</div>

@if (!string.IsNullOrEmpty(tempPassword))
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center">
        <div>
            <strong>One-time temporary password — copy now, won't be shown again:</strong>
            <code class="ms-2" style="font-size: 1.1rem; user-select: all;">@tempPassword</code>
        </div>
        <button class="btn btn-sm btn-outline-dark" onclick="navigator.clipboard.writeText('@tempPassword'); this.textContent='Copied!';">Copy</button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="sa-card h-100">
            <div class="sa-section-title">Identity</div>
            <div class="row g-2 small">
                <div class="col-5 text-muted">Email</div>
                <div class="col-7"><code>@Model.Email</code></div>
                <div class="col-5 text-muted">Phone</div>
                <div class="col-7">@(Model.PhoneNumber ?? "—")</div>
                <div class="col-5 text-muted">Created</div>
                <div class="col-7">@Model.CreatedAt.ToString("dd MMM yyyy")</div>
                <div class="col-5 text-muted">Last login</div>
                <div class="col-7">@(Model.LastLoginAt?.ToString("dd MMM HH:mm") ?? "never")</div>
                @if (!string.IsNullOrEmpty(Model.LicenseBody))
                {
                    <div class="col-5 text-muted">License</div>
                    <div class="col-7">@Model.LicenseBody · @Model.LicenseNumber</div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="sa-card h-100">
            <div class="sa-section-title">Tenant &amp; facility</div>
            @if (tenant != null)
            {
                <div class="mb-2">
                    <div><a asp-controller="SuperAdminTenants" asp-action="Detail" asp-route-id="@tenant.Id">@tenant.LegalName</a></div>
                    <div class="small text-muted">@tenant.Slug · @tenant.CountryCode</div>
                </div>
            }
            else if (roles.Contains(Roles.SuperAdmin))
            {
                <div class="text-muted small">No tenant — Super Admin operates platform-wide.</div>
            }
            else
            {
                <div class="text-muted small">— unattached —</div>
            }
            @if (facility != null)
            {
                <div class="mt-3 pt-3" style="border-top:1px dashed #334155;">
                    <div class="small text-muted">Facility</div>
                    <div>@facility.Name</div>
                    <div class="small text-muted">@facility.Code · @facility.Type</div>
                </div>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="sa-card h-100">
            <div class="sa-section-title">Account actions</div>

            <form asp-action="ResetPassword" asp-route-id="@Model.Id" method="post" class="mb-2">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-warning w-100" type="submit"
                        onclick="return confirm('Reset @Model.Email password? A new temporary password will be generated and shown once.');">
                    <i class="bi bi-key-fill me-1"></i> Reset password
                </button>
            </form>

            <form asp-action="ToggleActive" asp-route-id="@Model.Id" method="post" class="mb-2">
                @Html.AntiForgeryToken()
                @if (Model.IsActive)
                {
                    <button class="btn btn-outline-danger w-100" type="submit"
                            onclick="return confirm('Deactivate @Model.Email? They will be unable to log in.');">
                        <i class="bi bi-pause-circle me-1"></i> Deactivate
                    </button>
                }
                else
                {
                    <button class="btn btn-outline-success w-100" type="submit">
                        <i class="bi bi-play-circle me-1"></i> Reactivate
                    </button>
                }
            </form>
        </div>
    </div>
</div>

<div class="sa-card mb-4">
    <div class="sa-section-title">Roles</div>
    @if (roles.Any())
    {
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var r in roles)
            {
                <form asp-action="RemoveRole" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="role" value="@r" />
                    <span class="badge d-inline-flex align-items-center gap-2"
                          style="@(r == Roles.SuperAdmin ? "background:rgba(168,85,247,.18);color:#a855f7;" : "background:rgba(96,165,250,.18);color:#60a5fa;") padding:6px 10px;">
                        @r
                        <button class="btn btn-link p-0 m-0" style="color:inherit;line-height:1;" type="submit"
                                onclick="return confirm('Remove role @r from @Model.Email?');">
                            <i class="bi bi-x"></i>
                        </button>
                    </span>
                </form>
            }
        </div>
    }
    else
    {
        <p class="text-muted small">No roles assigned.</p>
    }

    <form asp-action="AddRole" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
        @Html.AntiForgeryToken()
        <select name="role" class="form-select form-select-sm" style="max-width:280px;" required>
            <option value="">Add a role…</option>
            @foreach (var r in allRoles.Where(x => !roles.Contains(x)))
            {
                <option value="@r">@r</option>
            }
        </select>
        <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-plus-lg"></i> Add</button>
    </form>
</div>
