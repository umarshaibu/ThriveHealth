@model ThriveHealth.Web.Models.ViewModels.DispositionViewModel
@{
    ViewData["Title"] = "A&E disposition";
    var enc = (ThriveHealth.Web.Models.Clinical.Encounter?)ViewBag.Encounter;
    var beds = ViewBag.Beds as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title"><i class="bi bi-box-arrow-right me-1"></i> Dispose A&amp;E encounter</h1>
        @if (enc?.Patient != null)
        { <p class="th-section-sub mb-0">@enc.Patient.FullName · @enc.Patient.HospitalNumber · A&amp;E since @enc.StartedAt.ToLocalTime().ToString("HH:mm")</p> }
    </div>
    <a asp-action="Encounter" asp-route-id="@Model.EncounterId" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<form asp-action="Dispose" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AdmissionsManage">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
    <input type="hidden" asp-for="EncounterId" />

    <div class="th-card mb-3"><div class="th-card-body">
        <h6 class="text-uppercase text-muted small mb-3">Disposition</h6>
        <div class="row g-2">
            @{
                var options = new[]
                {
                    (1, "Discharged home", "bi-house", "success"),
                    (2, "Discharged with follow-up", "bi-arrow-repeat", "success"),
                    (3, "Admitted", "bi-hospital", "warning"),
                    (4, "To theatre", "bi-scissors", "info"),
                    (5, "Transferred out", "bi-truck", "info"),
                    (6, "Deceased", "bi-x-octagon", "danger"),
                    (7, "Left without being seen", "bi-arrow-up-right", "muted"),
                    (8, "DAMA", "bi-pen", "warning")
                };
            }
            @foreach (var o in options)
            {
                <div class="col-md-3">
                    <input class="form-check-input" type="radio" name="Disposition" id="d-@o.Item1" value="@o.Item1" @(((int)Model.Disposition) == o.Item1 ? "checked" : "") />
                    <label for="d-@o.Item1" class="form-check-label w-100 p-2 border rounded-3 d-block" style="cursor:pointer;">
                        <i class="bi @o.Item2 text-@o.Item4 me-1"></i> @o.Item3
                    </label>
                </div>
            }
        </div>
    </div></div>

    <div class="th-card mb-3" id="admitPanel" style="display:none;"><div class="th-card-body">
        <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-hospital me-1"></i> Admission details</h6>
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">Ward</label>
                <select name="AdmitWardId" id="admitWard" asp-items="ViewBag.Wards" class="form-select"><option value="">--</option></select>
            </div>
            <div class="col-md-4"><label class="form-label">Bed</label>
                <select name="AdmitBedId" id="admitBed" class="form-select"><option value="">--</option></select>
            </div>
            <div class="col-md-4"><label class="form-label">Admitting doctor</label>
                <select name="AdmitDoctorId" asp-items="ViewBag.Doctors" class="form-select"><option value="">--</option></select>
            </div>
            <div class="col-md-12"><label class="form-label">Reason for admission</label>
                <input name="AdmitReason" class="form-control" value="@Model.AdmitReason" />
            </div>
        </div>
    </div></div>

    <div class="th-card mb-3"><div class="th-card-body">
        <div class="row g-3">
            <div class="col-md-12"><label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" rows="5" class="form-control" placeholder="Course in A&E, response to treatment, complications..."></textarea>
            </div>
            <div class="col-md-12"><label asp-for="FollowUp" class="form-label"></label>
                <input asp-for="FollowUp" class="form-control" placeholder="GOPD review in 1 week. Continue oral antibiotics." />
            </div>
        </div>
    </div></div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Encounter" asp-route-id="@Model.EncounterId" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-success btn-lg"><i class="bi bi-check2-circle me-1"></i> Confirm disposition</button>
    </div>
</form>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
const beds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(beds));
const $admitPanel = document.getElementById('admitPanel');
const $admitWard = document.getElementById('admitWard');
const $admitBed = document.getElementById('admitBed');

function refreshBeds() {
    const wid = parseInt($admitWard.value, 10);
    const filtered = isNaN(wid) ? [] : beds.filter(b => b.wardId === wid);
    $admitBed.innerHTML = '<option value="">--</option>' + filtered.map(b => `<option value="${b.id}">${b.display}</option>`).join('');
}
$admitWard.addEventListener('change', refreshBeds);

document.querySelectorAll('input[name="Disposition"]').forEach(r => {
    r.addEventListener('change', () => {
        $admitPanel.style.display = r.value === '3' && r.checked ? 'block' : (document.querySelector('input[name="Disposition"]:checked')?.value === '3' ? 'block' : 'none');
    });
});
$admitPanel.style.display = document.querySelector('input[name="Disposition"]:checked')?.value === '3' ? 'block' : 'none';
refreshBeds();
</script>
}
