@model ThriveHealth.Web.Models.ViewModels.EmergencyEncounterViewModel
@{
    var enc = Model.Encounter;
    var t = Model.Triage;
    var p = Model.Patient;
    ViewData["Title"] = $"A&E · {p.FullName}";

    string ColourHex(ThriveHealth.Web.Models.Emergency.TriageColour c) => c switch
    {
        ThriveHealth.Web.Models.Emergency.TriageColour.Red => "#c81e1e",
        ThriveHealth.Web.Models.Emergency.TriageColour.Orange => "#ff8c00",
        ThriveHealth.Web.Models.Emergency.TriageColour.Yellow => "#d4a017",
        ThriveHealth.Web.Models.Emergency.TriageColour.Green => "#1f9d55",
        ThriveHealth.Web.Models.Emergency.TriageColour.Blue => "#0d8aaa",
        _ => "#5b6b85"
    };
    var hasSevereAllergy = p.Allergies.Any(x => x.IsActive && x.Severity >= ThriveHealth.Web.Models.Patients.AllergySeverity.Severe);
    var inResus = enc.ResusBayId.HasValue;
    var minutesSince = (int)(DateTime.UtcNow - t.TriagedAt).TotalMinutes;
    var overdueMin = (int)(DateTime.UtcNow - t.TargetSeenByUtc).TotalMinutes;
    var active = enc.Status == ThriveHealth.Web.Models.Clinical.EncounterStatus.InProgress;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <span class="th-pill" style="background:@ColourHex(t.Colour);color:#fff;"><i class="bi bi-bandaid"></i> A&amp;E · @t.Colour</span>
        @if (inResus) { <span class="th-pill th-pill-danger ms-2"><i class="bi bi-heart-pulse"></i> In Resus · @enc.ResusBay?.Code</span> }
        @if (t.IsForensicCase) { <span class="th-pill th-pill-warning ms-2"><i class="bi bi-shield-exclamation"></i> Forensic · @t.ForensicCategory</span> }
        @if (t.IsTrauma) { <span class="th-pill th-pill-warning ms-2"><i class="bi bi-bandaid"></i> Trauma</span> }
        <h1 class="th-section-title mt-2">@p.FullName <small class="text-muted">· @p.HospitalNumber</small></h1>
        <p class="th-section-sub mb-0">
            @p.Sex @if (p.AgeYears.HasValue) { <span> · @p.AgeYears y</span> }
            · Triaged @t.TriagedAt.ToLocalTime().ToString("HH:mm") by @t.TriagedBy?.FullName
            · @minutesSince min in dept
            @if (overdueMin > 0 && active) { <span class="text-danger"> · <strong>@overdueMin min over target</strong></span> }
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Patients" asp-action="Profile" asp-route-id="@p.Id" class="btn btn-outline-secondary"><i class="bi bi-folder2-open me-1"></i> Chart</a>
        @if (active)
        {
            <a asp-action="Dispose" asp-route-id="@enc.Id" class="btn btn-success"><i class="bi bi-box-arrow-right me-1"></i> Dispose / Sign off</a>
        }
    </div>
</div>

@if (p.Allergies.Any(x => x.IsActive))
{
    <div class="alert @(hasSevereAllergy ? "alert-danger" : "alert-warning") d-flex align-items-center gap-2 mb-3">
        <i class="bi bi-exclamation-octagon-fill"></i>
        <div><strong>Allergies:</strong>
            @foreach (var a in p.Allergies.Where(x => x.IsActive)) { <span class="me-2"><strong>@a.Substance</strong> <small>(@a.Severity)</small></span> }
        </div>
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-md-8">
        <div class="th-card h-100"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2">Chief complaint</h6>
            <p class="mb-2">@t.ChiefComplaint</p>
            @if (!string.IsNullOrEmpty(t.MechanismOfInjury))
            {
                <h6 class="text-uppercase text-muted small">Mechanism</h6>
                <p class="mb-2">@t.MechanismOfInjury</p>
            }
            <div class="row small">
                <div class="col-3 text-muted">Arrival</div><div class="col-9">@t.ArrivalMode</div>
                <div class="col-3 text-muted">AVPU / GCS</div><div class="col-9">@(t.Avpu?.ToString() ?? "—") / @(t.GcsTotal?.ToString() ?? "—")</div>
                @if (t.IsPregnant) { <div class="col-3 text-muted">Pregnant</div><div class="col-9 fw-bold">Yes</div> }
                @if (t.LastMealUtc.HasValue) { <div class="col-3 text-muted">Last meal</div><div class="col-9">@t.LastMealUtc.Value.ToLocalTime().ToString("dd MMM HH:mm")</div> }
                @if (!string.IsNullOrEmpty(t.KnownAllergies)) { <div class="col-3 text-muted">Allergies</div><div class="col-9">@t.KnownAllergies</div> }
                @if (!string.IsNullOrEmpty(t.CurrentMedications)) { <div class="col-3 text-muted">Meds</div><div class="col-9">@t.CurrentMedications</div> }
                @if (t.IsForensicCase)
                {
                    <div class="col-3 text-muted">Police report</div><div class="col-9">@(t.PoliceReportNumber ?? "—")</div>
                    <div class="col-3 text-muted">Accompanying</div><div class="col-9">@(t.AccompanyingPerson ?? "—")</div>
                }
            </div>
        </div></div>
    </div>

    <div class="col-md-4">
        <div class="th-card h-100"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-grid me-1"></i> Resus bay</h6>
            @if (inResus)
            {
                <div class="alert alert-danger py-2 mb-2"><strong>@enc.ResusBay?.Name</strong> · since @enc.ResusStartedAt?.ToLocalTime().ToString("HH:mm")</div>
                @if (active)
                {
                    <form asp-action="ReleaseBay" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EmergencyBoardRead">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="encounterId" value="@enc.Id" />
                        <button class="btn btn-sm btn-outline-secondary w-100"><i class="bi bi-arrow-up-square me-1"></i> Release bay</button>
                    </form>
                }
            }
            else if (active)
            {
                <form asp-action="AssignBay" method="post" class="d-flex gap-2" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EmergencyBoardRead">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="encounterId" value="@enc.Id" />
                    <select name="bayId" class="form-select form-select-sm" required>
                        <option value="">Pick a bay…</option>
                        @foreach (var bay in Model.Bays)
                        { <option value="@bay.Id">@bay.Code · @bay.Name</option> }
                    </select>
                    <button class="btn btn-sm btn-danger"><i class="bi bi-arrow-right"></i></button>
                </form>
            }
            else
            {
                <div class="text-muted">Consultation signed off.</div>
            }
        </div></div>
    </div>
</div>

@if (active)
{
    <div class="th-card mb-3">
        <div class="th-card-header">
            <h5 class="th-card-title"><i class="bi bi-lightning text-warning me-1"></i> Order set bundles · one-click</h5>
        </div>
        <div class="th-card-body">
            <div class="row g-2">
                @foreach (var os in Model.OrderSets)
                {
                    <div class="col-md-6 col-xl-4">
                        <form asp-action="ApplyOrderSet" method="post" class="border rounded-3 p-3 h-100" onsubmit="return confirm('Apply ' + @System.Text.Json.JsonSerializer.Serialize(os.Name) + '? This fires ' + @os.LabCount + ' labs, ' + @os.ImagingCount + ' imaging, ' + @os.DrugCount + ' drugs, ' + @os.ProcedureCount + ' procedures.');" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EmergencyBoardRead">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="encounterId" value="@enc.Id" />
                            <input type="hidden" name="setKey" value="@os.Key" />
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="fw-bold"><i class="bi @os.Icon text-@os.Tone me-1"></i> @os.Name</div>
                                    <small class="text-muted">@os.Description</small>
                                </div>
                                <button class="btn btn-sm btn-@os.Tone"><i class="bi bi-lightning-charge"></i></button>
                            </div>
                            <div class="mt-2 small text-muted">@os.LabCount labs · @os.ImagingCount imaging · @os.DrugCount drugs · @os.ProcedureCount procedures</div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
}

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#t-log">Resus log <span class="th-pill th-pill-muted ms-1">@Model.Events.Count</span></button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#t-orders">Orders <span class="th-pill th-pill-muted ms-1">@(enc.LabOrders.Count + enc.ImagingOrders.Count + enc.ProcedureOrders.Count + enc.Prescriptions.Sum(x => x.Items.Count))</span></button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#t-vitals">Vitals <span class="th-pill th-pill-muted ms-1">@Model.Vitals.Count</span></button></li>
    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#t-clinical">Clinical note</button></li>
</ul>

<div class="tab-content">

@* RESUS LOG *@
<div class="tab-pane fade show active" id="t-log">
    @if (active)
    {
        <div class="th-card mb-2"><div class="th-card-body">
            <form asp-action="AddResusEvent" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EmergencyBoardRead">
                @Html.AntiForgeryToken()
                <input type="hidden" name="EncounterId" value="@enc.Id" />
                <div class="row g-2">
                    <div class="col-md-2">
                        <select name="Kind" class="form-select form-select-sm">
                            <option value="1">Note</option>
                            <option value="2">Drug given</option>
                            <option value="3">Fluid</option>
                            <option value="4">Procedure</option>
                            <option value="5">Defibrillation</option>
                            <option value="6">Intubation</option>
                            <option value="7">CPR</option>
                            <option value="8">Imaging</option>
                            <option value="9">Lab</option>
                            <option value="10">Blood product</option>
                        </select>
                    </div>
                    <div class="col-md-7"><input class="form-control form-control-sm" name="Description" placeholder="What happened" /></div>
                    <div class="col-md-3">
                        <div class="d-flex gap-1">
                            <input class="form-control form-control-sm" name="Details" placeholder="Details (optional)" />
                            <button class="btn btn-sm btn-primary"><i class="bi bi-plus"></i></button>
                        </div>
                    </div>
                </div>
            </form>
        </div></div>
    }

    @if (!Model.Events.Any())
    {
        <div class="th-empty"><i class="bi bi-list-ul"></i><h6 class="mt-2">No events logged yet</h6></div>
    }
    else
    {
        <div class="th-card"><div class="th-card-body p-0"><div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Time</th><th>Kind</th><th>Description</th><th>Recorded by</th></tr></thead>
            <tbody>
            @foreach (var e in Model.Events)
            {
                <tr>
                    <td><small class="font-monospace text-nowrap">@e.AtUtc.ToLocalTime().ToString("HH:mm:ss")</small></td>
                    <td><span class="th-pill th-pill-muted">@e.Kind</span></td>
                    <td><strong>@e.Description</strong>@if (!string.IsNullOrEmpty(e.Details)) { <div class="small text-muted">@e.Details</div> }</td>
                    <td><small class="text-muted">@e.RecordedBy?.FullName</small></td>
                </tr>
            }
            </tbody>
        </table>
        </div></div></div>
    }
</div>

@* ORDERS *@
<div class="tab-pane fade" id="t-orders">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="th-card"><div class="th-card-header"><h6 class="th-card-title"><i class="bi bi-droplet-half me-1"></i> Lab</h6></div><div class="th-card-body p-0">
                @if (!enc.LabOrders.Any()) { <div class="p-3 text-muted small">No lab orders</div> }
                else
                {
                    <table class="table table-sm mb-0">
                    <tbody>
                    @foreach (var l in enc.LabOrders.OrderByDescending(x => x.OrderedAt))
                    {
                        <tr><td><strong>@l.TestName</strong> <small class="text-muted">@l.Specimen</small></td><td><span class="th-pill th-pill-warning">@l.Urgency</span></td><td>@l.Status</td></tr>
                    }
                    </tbody>
                    </table>
                }
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="th-card"><div class="th-card-header"><h6 class="th-card-title"><i class="bi bi-radioactive me-1"></i> Imaging</h6></div><div class="th-card-body p-0">
                @if (!enc.ImagingOrders.Any()) { <div class="p-3 text-muted small">No imaging orders</div> }
                else
                {
                    <table class="table table-sm mb-0">
                    <tbody>
                    @foreach (var i in enc.ImagingOrders.OrderByDescending(x => x.OrderedAt))
                    {
                        <tr><td>@i.Modality · <strong>@i.StudyDescription</strong></td><td><span class="th-pill th-pill-warning">@i.Urgency</span></td></tr>
                    }
                    </tbody>
                    </table>
                }
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="th-card"><div class="th-card-header"><h6 class="th-card-title"><i class="bi bi-prescription2 me-1"></i> Drugs</h6></div><div class="th-card-body p-0">
                @if (!enc.Prescriptions.Any()) { <div class="p-3 text-muted small">No prescriptions</div> }
                else
                {
                    <table class="table table-sm mb-0">
                    <tbody>
                    @foreach (var rx in enc.Prescriptions) { foreach (var i in rx.Items)
                    {
                        <tr><td><strong>@i.DrugName</strong></td><td><small>@i.Dose · @i.Route · @i.Frequency</small></td></tr>
                    } }
                    </tbody>
                    </table>
                }
            </div></div>
        </div>
        <div class="col-md-6">
            <div class="th-card"><div class="th-card-header"><h6 class="th-card-title"><i class="bi bi-tools me-1"></i> Procedures</h6></div><div class="th-card-body p-0">
                @if (!enc.ProcedureOrders.Any()) { <div class="p-3 text-muted small">No procedures</div> }
                else
                {
                    <table class="table table-sm mb-0">
                    <tbody>
                    @foreach (var p2 in enc.ProcedureOrders.OrderByDescending(x => x.OrderedAt))
                    {
                        <tr><td><strong>@p2.ProcedureName</strong>@if (!string.IsNullOrEmpty(p2.Notes)) { <div class="small text-muted">@p2.Notes</div> }</td></tr>
                    }
                    </tbody>
                    </table>
                }
            </div></div>
        </div>
    </div>
    @if (active)
    {
        <div class="alert alert-info mt-3 small">
            <i class="bi bi-info-circle me-1"></i>
            Need an ad-hoc order outside a bundle? Open the
            <a asp-controller="Consultations" asp-action="Edit" asp-route-id="@enc.Id">full consultation view</a>
            to add labs, imaging, prescriptions, or diagnoses individually.
        </div>
    }
</div>

@* VITALS *@
<div class="tab-pane fade" id="t-vitals">
    <div class="d-flex justify-content-between mb-2">
        <h6 class="mb-0">Vitals during this consultation</h6>
        @if (active) { <a asp-controller="Emr" asp-action="AddVitals" asp-route-patientId="@p.Id" class="btn btn-sm btn-primary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite"><i class="bi bi-plus-lg me-1"></i> Record vitals</a> }
    </div>
    @if (!Model.Vitals.Any())
    {
        <div class="th-empty"><i class="bi bi-heart-pulse"></i><h6 class="mt-2">No vitals yet</h6></div>
    }
    else
    {
        <div class="th-card"><div class="th-card-body p-0"><div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Time</th><th>BP</th><th>HR</th><th>RR</th><th>Temp</th><th>SpO₂</th><th>GCS</th><th>MEWS</th></tr></thead>
            <tbody>
            @foreach (var v in Model.Vitals)
            {
                var mt = (v.Mews ?? 0) <= 1 ? "th-pill-success" : (v.Mews ?? 0) <= 3 ? "th-pill-warning" : "th-pill-danger";
                <tr>
                    <td><small>@v.RecordedAt.ToLocalTime().ToString("HH:mm:ss")</small></td>
                    <td>@(v.SystolicBp.HasValue ? $"{v.SystolicBp}/{v.DiastolicBp}" : "—")</td>
                    <td>@v.HeartRate</td>
                    <td>@v.RespiratoryRate</td>
                    <td>@v.TemperatureCelsius</td>
                    <td>@v.SpO2</td>
                    <td>@v.GcsTotal</td>
                    <td>@if (v.Mews.HasValue) { <span class="th-pill @mt">@v.Mews</span> } else { <span>—</span> }</td>
                </tr>
            }
            </tbody>
        </table>
        </div></div></div>
    }
</div>

@* CLINICAL *@
<div class="tab-pane fade" id="t-clinical">
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-1"></i> Full clinical documentation (SOAP note, diagnoses, ad-hoc orders) is in the
        <a asp-controller="Consultations" asp-action="Edit" asp-route-id="@enc.Id">general consultation view</a>.
    </div>
    @if (enc.Soap is not null && (!string.IsNullOrEmpty(enc.Soap.Subjective) || !string.IsNullOrEmpty(enc.Soap.Plan)))
    {
        <div class="th-card mb-2"><div class="th-card-body">
            @if (!string.IsNullOrEmpty(enc.Soap.Subjective)) { <h6 class="text-muted">Subjective</h6><pre class="mb-3" style="white-space:pre-wrap;font-family:inherit;">@enc.Soap.Subjective</pre> }
            @if (!string.IsNullOrEmpty(enc.Soap.Plan)) { <h6 class="text-muted">Plan</h6><pre class="mb-0" style="white-space:pre-wrap;font-family:inherit;">@enc.Soap.Plan</pre> }
        </div></div>
    }
    @if (enc.Diagnoses.Any())
    {
        <div class="th-card"><div class="th-card-header"><h6 class="th-card-title">Diagnoses</h6></div><div class="th-card-body p-0">
            <table class="table mb-0"><tbody>
            @foreach (var d in enc.Diagnoses)
            {
                <tr><td><span class="font-monospace">@d.IcdCode</span></td><td>@d.Description</td><td>@d.Status</td>@if (d.IsPrimary) { <td><span class="th-pill th-pill-info">Primary</span></td> } else { <td></td> }</tr>
            }
            </tbody></table>
        </div></div>
    }
</div>

</div>
