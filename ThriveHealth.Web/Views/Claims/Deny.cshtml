@model ThriveHealth.Web.Models.ViewModels.ClaimDenyViewModel
@{
    ViewData["Title"] = "Deny claim";
    var c = (ThriveHealth.Web.Models.Insurance.Claim?)ViewBag.Claim;
}

<div class="row"><div class="col-lg-7">
    <h1 class="th-section-title">Mark claim denied</h1>
    @if (c != null) { <p class="th-section-sub">Claim @c.ClaimReference</p> }

    <form asp-action="Deny" method="post" class="th-card" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ClaimsManage">
        <div class="th-card-body">
            <input type="hidden" asp-for="ClaimId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="row g-3">
                <div class="col-md-12"><label asp-for="Reason" class="form-label"></label>
                    <input asp-for="Reason" class="form-control" placeholder="Service not covered, missing pre-auth, exceeded benefit cap..." />
                </div>
                <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" rows="3" class="form-control"></textarea></div>
            </div>
            <div class="mt-3 d-flex justify-content-end gap-2">
                <a asp-action="Details" asp-route-id="@Model.ClaimId" class="btn btn-outline-secondary">Cancel</a>
                <button class="btn btn-danger"><i class="bi bi-x-octagon me-1"></i> Mark denied</button>
            </div>
        </div>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
