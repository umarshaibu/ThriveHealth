@model ThriveHealth.Web.Models.ViewModels.ClaimSettleViewModel
@{
    ViewData["Title"] = "Settle claim";
    var c = (ThriveHealth.Web.Models.Insurance.Claim?)ViewBag.Claim;
}

<div class="row"><div class="col-lg-7">
    <h1 class="th-section-title">Record settlement</h1>
    @if (c != null) { <p class="th-section-sub">Claim @c.ClaimReference · Claimable ₦@c.ClaimableAmount.ToString("N2")</p> }

    <form asp-action="Settle" method="post" class="th-card" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ClaimsManage">
        <div class="th-card-body">
            <input type="hidden" asp-for="ClaimId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="row g-3">
                <div class="col-md-6"><label asp-for="ApprovedAmount" class="form-label"></label>
                    <div class="input-group"><span class="input-group-text">₦</span><input asp-for="ApprovedAmount" type="number" step="0.01" class="form-control" /></div>
                </div>
                <div class="col-md-6"><label asp-for="PaidAmount" class="form-label"></label>
                    <div class="input-group"><span class="input-group-text">₦</span><input asp-for="PaidAmount" type="number" step="0.01" class="form-control" /></div>
                </div>
                <div class="col-md-12"><label asp-for="PayerReference" class="form-label"></label><input asp-for="PayerReference" class="form-control" /></div>
                <div class="col-md-12"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" rows="3" class="form-control"></textarea></div>
            </div>
            <div class="mt-3 d-flex justify-content-end gap-2">
                <a asp-action="Details" asp-route-id="@Model.ClaimId" class="btn btn-outline-secondary">Cancel</a>
                <button class="btn btn-success"><i class="bi bi-check2-circle me-1"></i> Save settlement</button>
            </div>
        </div>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
