@model ThriveHealth.Web.Models.ViewModels.MortuaryListViewModel
@using ThriveHealth.Web.Models.Mortuary
@{
    ViewData["Title"] = "Mortuary register";
    string Tone(MortuaryStatus s) => s switch
    {
        MortuaryStatus.Received => "th-pill-warning",
        MortuaryStatus.Embalmed => "th-pill-info",
        MortuaryStatus.AwaitingRelease => "th-pill-warning",
        MortuaryStatus.Released => "th-pill-success",
        MortuaryStatus.Buried => "th-pill-success",
        MortuaryStatus.Transferred => "th-pill-muted",
        _ => "th-pill-muted"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Mortuary register</h1>
        <p class="th-section-sub mb-0">@Model.CurrentBodies in mortuary · @Model.ReleasedThisMonth released this month · @Model.OverdueLengthOfStay over 14 days</p>
    </div>
    <a asp-action="Receive" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.MortuaryManage" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Receive body</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="th-stat tone-warning"><div class="th-stat-icon"><i class="bi bi-archive"></i></div><div class="th-stat-label">Currently held</div><div class="th-stat-value">@Model.CurrentBodies</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-success"><div class="th-stat-icon"><i class="bi bi-box-arrow-up"></i></div><div class="th-stat-label">Released (month)</div><div class="th-stat-value">@Model.ReleasedThisMonth</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-danger"><div class="th-stat-icon"><i class="bi bi-clock-history"></i></div><div class="th-stat-label">Over 14 days</div><div class="th-stat-value">@Model.OverdueLengthOfStay</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-info"><div class="th-stat-icon"><i class="bi bi-list-ul"></i></div><div class="th-stat-label">Total visible</div><div class="th-stat-value">@Model.Entries.Count</div></div></div>
</div>

<div class="d-flex gap-2 mb-3 flex-wrap">
    <a asp-action="Index" class="btn btn-sm @(Model.FilterStatus is null ? "btn-primary" : "btn-outline-secondary")">All</a>
    @foreach (var s in Enum.GetValues<MortuaryStatus>())
    {
        <a asp-action="Index" asp-route-status="@s" class="btn btn-sm @(Model.FilterStatus == s ? "btn-primary" : "btn-outline-secondary")">@s</a>
    }
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Entries.Any())
{
    <div class="th-empty m-4"><i class="bi bi-archive"></i><h5 class="mt-2">No entries</h5></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Mortuary #</th><th>Deceased</th><th>Cabinet</th><th>Date of death</th><th>Cause</th><th>Days held</th><th>Status</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var e in Model.Entries)
        {
            var days = (int)((e.ReleasedAt ?? DateTime.UtcNow) - e.ReceivedAt).TotalDays;
            <tr class="@(days > 14 && e.ReleasedAt is null ? "table-warning" : "")">
                <td><span class="font-monospace small">@e.MortuaryNumber</span></td>
                <td><strong>@e.DeceasedName</strong>@if (e.IsUnidentified) { <span class="th-pill th-pill-danger ms-1">Unidentified</span> }<div class="small text-muted">@e.Sex · @(e.AgeYears?.ToString() ?? "—") yo</div></td>
                <td><small>@e.CabinetCode</small></td>
                <td>@e.DateOfDeathUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                <td><small>@e.CauseOfDeath</small></td>
                <td>@days</td>
                <td><span class="th-pill @Tone(e.Status)">@e.Status</span></td>
                <td class="text-end"><a asp-action="Detail" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open"></i></a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
