@model IReadOnlyList<ThriveHealth.Web.Models.Tenancy.Plan>
@{
    ViewData["Title"] = "Plans";
    var subCounts = (Dictionary<int, int>)ViewBag.SubCounts;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h1 class="sa-h1">Subscription plans</h1>
        <p class="sa-sub mb-0">Pricing, caps and feature toggles. Edits apply to new signups; existing subscriptions keep the price they were created with.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New plan</a>
</div>

<div class="sa-card p-0">
    <table class="table mb-0">
        <thead><tr>
            <th>Plan</th><th>Code</th><th>Monthly</th><th>Annual</th>
            <th>Caps</th><th>Active subs</th><th>Status</th><th></th>
        </tr></thead>
        <tbody>
            @foreach (var p in Model)
            {
                var subs = subCounts.TryGetValue(p.Id, out var c) ? c : 0;
                <tr>
                    <td>
                        <strong>@p.Name</strong>
                        @if (p.IsCustomQuote) { <span class="badge bg-info ms-1">Custom quote</span> }
                        <div class="small text-muted">@p.Tagline</div>
                    </td>
                    <td><code class="small">@p.Code</code></td>
                    <td>@(p.IsCustomQuote ? "—" : $"₦{p.MonthlyNgn:N0}")</td>
                    <td>@(p.IsCustomQuote ? "—" : $"₦{p.AnnualNgn:N0}")</td>
                    <td class="small text-muted">
                        @(p.MaxStaff?.ToString("N0") ?? "∞") staff ·
                        @(p.MaxFacilities?.ToString() ?? "∞") sites
                    </td>
                    <td>@subs</td>
                    <td>
                        @if (p.IsActive) { <span class="badge-pill badge-active">Active</span> }
                        else { <span class="badge-pill badge-cancelled">Hidden</span> }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="ToggleActive" asp-route-id="@p.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-secondary" type="submit"
                                        onclick="return confirm('@(p.IsActive ? "Hide" : "Show") @p.Name?');"
                                        title="@(p.IsActive ? "Hide from signup" : "Show on signup")">
                                    <i class="bi bi-@(p.IsActive ? "eye-slash" : "eye")"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center py-4 text-muted">No plans defined.</td></tr>
            }
        </tbody>
    </table>
</div>
