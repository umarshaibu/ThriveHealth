@model ThriveHealth.Web.Models.Clinical.LabOrder
@{
    ViewData["Title"] = "Lab result";
    var r = Model.Result;
    var test = Model.LabTest;
    var ai = ViewBag.AiSuggestion as ThriveHealth.Web.Models.Ai.AiSuggestion;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        @if (r != null)
        {
            var tone = r.Status switch
            {
                ThriveHealth.Web.Models.Diagnostics.LabResultStatus.Authorized => "th-pill-success",
                ThriveHealth.Web.Models.Diagnostics.LabResultStatus.Final => "th-pill-warning",
                _ => "th-pill-info"
            };
            <span class="th-pill @tone">@r.Status</span>
            @if (r.HasCriticalValue) { <span class="th-pill th-pill-danger ms-2"><i class="bi bi-exclamation-octagon-fill"></i> CRITICAL</span> }
        }
        else
        {
            <span class="th-pill th-pill-info">@Model.Status</span>
        }
        <h1 class="th-section-title mt-2">@Model.TestName</h1>
        <p class="th-section-sub mb-0">
            <strong>@Model.Patient!.FullName</strong> · <span class="font-monospace">@Model.Patient.HospitalNumber</span>
            @if (!string.IsNullOrEmpty(Model.AccessionNumber)) { <span> · <span class="font-monospace">@Model.AccessionNumber</span></span> }
            · Ordered @Model.OrderedAt.ToLocalTime().ToString("dd MMM HH:mm") by @Model.OrderedBy?.FullName
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Worklist" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Worklist</a>
        @if (Model.LabTestId.HasValue && Model.Status != ThriveHealth.Web.Models.Clinical.OrderStatus.Completed)
        {
            <a asp-action="Enter" asp-route-id="@Model.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.LabPerform" class="btn btn-primary"><i class="bi bi-pencil me-1"></i> Edit result</a>
        }
        @if (r != null && r.Status == ThriveHealth.Web.Models.Diagnostics.LabResultStatus.Final)
        {
            <form asp-action="Authorize" asp-route-id="@r.Id" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.LabAuthorize">
                @Html.AntiForgeryToken()
                <button class="btn btn-success"><i class="bi bi-shield-check me-1"></i> Authorise &amp; release</button>
            </form>
        }
        <button onclick="window.print()" class="btn btn-outline-primary"><i class="bi bi-printer me-1"></i> Print</button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small">Specimen &amp; collection</h6>
            <div class="row small">
                <div class="col-5 text-muted">Specimen</div><div class="col-7 fw-semibold">@(Model.Specimen ?? test?.Specimen ?? "—")</div>
                <div class="col-5 text-muted">Container</div><div class="col-7 fw-semibold">@(test?.Container ?? "—")</div>
                <div class="col-5 text-muted">Collected</div><div class="col-7 fw-semibold">@(Model.CollectedAt?.ToLocalTime().ToString("dd MMM HH:mm") ?? "—")</div>
                <div class="col-5 text-muted">Collected by</div><div class="col-7 fw-semibold">@(Model.CollectedBy?.FullName ?? "—")</div>
            </div>
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small">Order details</h6>
            <div class="row small">
                <div class="col-5 text-muted">Section</div><div class="col-7 fw-semibold">@(test?.Section.ToString() ?? "—")</div>
                <div class="col-5 text-muted">LOINC</div><div class="col-7 fw-semibold font-monospace">@(Model.LoincCode ?? "—")</div>
                <div class="col-5 text-muted">Urgency</div><div class="col-7 fw-semibold">@Model.Urgency</div>
                <div class="col-5 text-muted">Indication</div><div class="col-7">@(Model.ClinicalIndication ?? "—")</div>
            </div>
        </div></div>
    </div>
</div>

@if (r != null && r.Values.Any())
{
    <div class="th-card mb-3">
        <div class="th-card-header"><h5 class="th-card-title"><i class="bi bi-list-check me-1 text-primary"></i> Result values</h5></div>
        <div class="th-card-body p-0">
            <table class="table align-middle mb-0">
                <thead><tr><th>Analyte</th><th>Value</th><th>Unit</th><th>Reference</th><th>Flag</th></tr></thead>
                <tbody>
                @foreach (var v in r.Values.OrderBy(x => x.LabAnalyte?.SortOrder ?? 0))
                {
                    var ftone = v.Flag switch
                    {
                        ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.CriticalLow => "th-pill-danger",
                        ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.CriticalHigh => "th-pill-danger",
                        ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.Low => "th-pill-warning",
                        ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.High => "th-pill-warning",
                        ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.Abnormal => "th-pill-warning",
                        _ => "th-pill-success"
                    };
                    <tr class="@(v.Flag == ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.CriticalLow || v.Flag == ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.CriticalHigh ? "table-danger" : "")">
                        <td><strong>@v.AnalyteName</strong></td>
                        <td><strong class="@(v.Flag != ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.Normal ? "fw-bold" : "")">@v.Value</strong></td>
                        <td><small class="text-muted">@v.Unit</small></td>
                        <td><small class="text-muted">@v.RefRangeDisplay</small></td>
                        <td>@if (v.Flag != ThriveHealth.Web.Models.Diagnostics.AnalyteFlag.Normal) { <span class="th-pill @ftone">@v.Flag</span> }</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!string.IsNullOrEmpty(r.GeneralComment))
        {
            <div class="th-card-body border-top"><strong>Comment:</strong> @r.GeneralComment</div>
        }
        <div class="th-card-body border-top small text-muted">
            <div>Entered @r.EnteredAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") by @r.EnteredBy?.FullName</div>
            @if (r.AuthorizedAt.HasValue)
            {
                <div><strong>Authorised</strong> @r.AuthorizedAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm") by @r.AuthorizedBy?.FullName <span class="ms-1">@r.AuthorizedBy?.LicenseBody @r.AuthorizedBy?.LicenseNumber</span></div>
            }
        </div>
    </div>
}
else
{
    <div class="th-empty"><i class="bi bi-hourglass-split"></i><h5 class="mt-2">Result not yet entered</h5></div>
}

@if (r != null && r.Values.Any())
{
    <div class="th-card mb-3" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiLabInterpret">
        <div class="th-card-header d-flex justify-content-between align-items-center">
            <h5 class="th-card-title mb-0"><i class="bi bi-stars me-1 text-primary"></i> AI interpretation <span class="th-pill th-pill-info ms-2">DRAFT — clinician must verify</span></h5>
            <form asp-action="Interpret" asp-route-id="@Model.Id" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiLabInterpret">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-clockwise me-1"></i> @(ai == null ? "Generate" : "Re-generate")</button>
            </form>
        </div>
        <div class="th-card-body">
            @if (ai == null)
            {
                <p class="text-muted small mb-0">No AI interpretation yet. Click <em>Generate</em> to draft one. The output is a suggestion only and must be verified by a clinician before any action.</p>
            }
            else if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Failed)
            {
                <div class="alert alert-warning mb-0"><strong>AI failed:</strong> @ai.ErrorMessage</div>
            }
            else
            {
                <div class="small text-muted mb-2">
                    Generated @ai.CreatedAtUtc.ToLocalTime().ToString("dd MMM HH:mm") · @ai.Provider/@ai.Model · status <strong>@ai.Status</strong>
                    @if (ai.ReviewedAtUtc.HasValue) { <span> · reviewed @ai.ReviewedAtUtc.Value.ToLocalTime().ToString("HH:mm")</span> }
                </div>
                <pre class="mb-2" style="white-space:pre-wrap;font-family:inherit">@(ai.EditedContent ?? ai.Response)</pre>
                @if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Pending)
                {
                    <form asp-action="ReviewInterpretation" method="post" class="d-flex gap-2 flex-wrap" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiLabInterpret">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="suggestionId" value="@ai.Id" />
                        <button name="status" value="Accepted" class="btn btn-sm btn-success"><i class="bi bi-check2-circle me-1"></i> Accept</button>
                        <button name="status" value="Rejected" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle me-1"></i> Reject</button>
                    </form>
                }
            }
        </div>
    </div>
}
