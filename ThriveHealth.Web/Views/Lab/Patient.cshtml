@model ThriveHealth.Web.Models.ViewModels.PatientLabHistory
@{ ViewData["Title"] = $"Lab history · {Model.Patient.FullName}"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Lab history</h1>
        <p class="th-section-sub mb-0">@Model.Patient.FullName · @Model.Patient.HospitalNumber</p>
    </div>
    <a asp-controller="Patients" asp-action="Profile" asp-route-id="@Model.Patient.Id" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to chart</a>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Orders.Any())
{
    <div class="th-empty m-4"><i class="bi bi-droplet-half"></i><h5 class="mt-2">No lab orders</h5></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Ordered</th><th>Test</th><th>Status</th><th>Result</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var o in Model.Orders)
        {
            var crit = o.Result?.HasCriticalValue ?? false;
            <tr class="@(crit ? "table-danger" : "")">
                <td>
                    @o.OrderedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    @if (!string.IsNullOrEmpty(o.AccessionNumber))
                    {
                        <div><small class="font-monospace text-muted">@o.AccessionNumber</small></div>
                    }
                </td>
                <td><strong>@o.TestName</strong></td>
                <td><span class="th-pill @(o.Status == ThriveHealth.Web.Models.Clinical.OrderStatus.Completed ? "th-pill-success" : "th-pill-warning")">@o.Status</span></td>
                <td>
                    @if (crit) { <span class="th-pill th-pill-danger">CRITICAL</span> }
                    else if (o.Result?.Status == ThriveHealth.Web.Models.Diagnostics.LabResultStatus.Authorized) { <span class="th-pill th-pill-success">Authorised</span> }
                    else if (o.Result?.Status == ThriveHealth.Web.Models.Diagnostics.LabResultStatus.Final) { <span class="th-pill th-pill-warning">Final, awaiting auth</span> }
                    else if (o.Result != null) { <span class="th-pill th-pill-info">@o.Result.Status</span> }
                    else { <small class="text-muted">—</small> }
                </td>
                <td class="text-end"><a asp-action="View" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
