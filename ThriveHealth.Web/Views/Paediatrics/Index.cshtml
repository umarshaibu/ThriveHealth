@model ThriveHealth.Web.Models.ViewModels.ChildListViewModel
@{ ViewData["Title"] = "Paediatrics · child register"; }

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Children under 5</h1>
        <p class="th-section-sub mb-0">@Model.Rows.Count visible · @Model.Under1Count under 1 yr · @Model.OverdueCount with overdue immunizations</p>
    </div>
    <form method="get" class="d-flex"><input type="search" name="q" value="@Model.Search" class="form-control" placeholder="Name / hospital #…" /></form>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="th-stat tone-primary"><div class="th-stat-icon"><i class="bi bi-people"></i></div><div class="th-stat-label">Under 5</div><div class="th-stat-value">@Model.Under5Count</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-info"><div class="th-stat-icon"><i class="bi bi-baby"></i></div><div class="th-stat-label">Under 1 yr</div><div class="th-stat-value">@Model.Under1Count</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-danger"><div class="th-stat-icon"><i class="bi bi-shield-exclamation"></i></div><div class="th-stat-label">Overdue immunizations</div><div class="th-stat-value">@Model.OverdueCount</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-success"><div class="th-stat-icon"><i class="bi bi-graph-up"></i></div><div class="th-stat-label">In register</div><div class="th-stat-value">@Model.Rows.Count</div></div></div>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Rows.Any())
{
    <div class="th-empty m-4"><i class="bi bi-people"></i><h5 class="mt-2">No children registered</h5></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Child</th><th>Age</th><th>Last visit</th><th>Wt / Ht</th><th>Status</th><th>Doses overdue</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var r in Model.Rows)
        {
            <tr class="@(r.OverdueDoses > 0 ? "table-warning" : "")">
                <td><strong>@r.Patient.FullName</strong><div class="small text-muted">@r.Patient.HospitalNumber</div></td>
                <td>@if (r.AgeMonths.HasValue) { @(r.AgeMonths >= 24 ? $"{r.AgeMonths / 12} yr" : $"{r.AgeMonths} mo") } else { <span class="text-muted">—</span> }</td>
                <td>@(r.LastMeasurement?.DateOfMeasurement.ToString("dd MMM yyyy") ?? "—")</td>
                <td>
                    @if (r.LastMeasurement != null)
                    {
                        <small>@(r.LastMeasurement.WeightKg?.ToString("0.0") ?? "—") kg · @(r.LastMeasurement.HeightCm?.ToString("0.0") ?? "—") cm</small>
                    }
                </td>
                <td>@if (r.LastMeasurement?.NutritionalStatus != null) { <span class="th-pill @(r.LastMeasurement.NutritionalStatus.Contains("SAM") ? "th-pill-danger" : r.LastMeasurement.NutritionalStatus.Contains("MAM") ? "th-pill-warning" : "th-pill-success")">@r.LastMeasurement.NutritionalStatus</span> }</td>
                <td>@if (r.OverdueDoses > 0) { <span class="th-pill th-pill-danger">@r.OverdueDoses overdue</span> }</td>
                <td class="text-end">
                    <a asp-action="Profile" asp-route-id="@r.Patient.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open me-1"></i> Open</a>
                    <a asp-controller="Immunization" asp-action="Card" asp-route-patientId="@r.Patient.Id" class="btn btn-sm btn-outline-success" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ImmunizationAdminister"><i class="bi bi-bandaid me-1"></i> Card</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
