@model ThriveHealth.Web.Models.ViewModels.InventoryItemEditViewModel
<div class="row g-3">
    <div class="col-md-7"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control text-uppercase" /></div>
    <div class="col-md-2"><label asp-for="Barcode" class="form-label"></label><input asp-for="Barcode" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Category" class="form-label"></label>
        <select asp-for="Category" class="form-select">
            @foreach (var c in Enum.GetValues<ThriveHealth.Web.Models.Inventory.InventoryCategory>())
            { <option value="@((int)c)">@c</option> }
        </select>
    </div>
    <div class="col-md-3"><label asp-for="UnitOfIssue" class="form-label"></label><input asp-for="UnitOfIssue" class="form-control" placeholder="box, each, ml…" /></div>
    <div class="col-md-3"><label asp-for="UnitPrice" class="form-label"></label><input asp-for="UnitPrice" type="number" step="0.01" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="ReorderLevel" class="form-label"></label><input asp-for="ReorderLevel" type="number" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Manufacturer" class="form-label"></label><input asp-for="Manufacturer" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="NafdacNumber" class="form-label"></label><input asp-for="NafdacNumber" class="form-control" /></div>
    <div class="col-md-3 form-check ms-2 d-flex align-items-end pt-3"><div><input asp-for="IsExpiringTracked" class="form-check-input" /><label asp-for="IsExpiringTracked" class="form-check-label"></label></div></div>
    <div class="col-md-12 form-check ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Active</label></div>
</div>
