@{
    var patientName = User.Identity?.Name;
    var isAuthed = User.Identity?.IsAuthenticated == true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] · ThriveHealth Portal</title>
    <meta name="theme-color" content="#1f6feb" />
    <link rel="manifest" href="~/portal/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="~/portal/icons/icon-192.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .th-portal-nav { background: linear-gradient(135deg, #1f6feb, #1857c4); color: #fff; padding: .85rem 1rem; }
        .th-portal-nav a, .th-portal-nav a:hover { color: #fff; text-decoration: none; }
        .th-portal-tabbar { position: sticky; bottom: 0; background: #fff; border-top: 1px solid var(--th-border); padding: .25rem 0; display: flex; justify-content: space-around; z-index: 50; }
        .th-portal-tabbar a { color: var(--th-text-muted); padding: .5rem .75rem; text-align: center; font-size: .75rem; text-decoration: none; flex: 1; }
        .th-portal-tabbar a.active { color: var(--th-primary); }
        .th-portal-tabbar a i { display: block; font-size: 1.25rem; }
        @@media (min-width: 768px) { .th-portal-tabbar { position: static; border-top: none; padding: 0; } }
    </style>
</head>
<body style="background: var(--th-bg); min-height: 100vh; display: flex; flex-direction: column;">
    @if (isAuthed)
    {
        <header class="th-portal-nav d-flex justify-content-between align-items-center">
            <a asp-controller="Portal" asp-action="Index" class="d-flex align-items-center gap-2"><i class="bi bi-heart-pulse-fill fs-4"></i><span class="fw-bold">ThriveHealth</span></a>
            <div class="d-flex align-items-center gap-2">
                <span class="small d-none d-md-inline">@patientName</span>
                <form asp-controller="Portal" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-light"><i class="bi bi-box-arrow-right"></i></button>
                </form>
            </div>
        </header>
    }

    <main class="container py-3" style="flex: 1; max-width: 960px;">
        @RenderBody()
    </main>

    @if (isAuthed)
    {
        var current = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        <nav class="th-portal-tabbar">
            <a asp-controller="Portal" asp-action="Index" class="@(current == "Index" ? "active" : "")"><i class="bi bi-house"></i> Home</a>
            <a asp-controller="Portal" asp-action="Appointments" class="@(current == "Appointments" ? "active" : "")"><i class="bi bi-calendar2-week"></i> Visits</a>
            <a asp-controller="Portal" asp-action="Telemed" class="@(current == "Telemed" ? "active" : "")"><i class="bi bi-camera-video"></i> Telemed</a>
            <a asp-controller="Portal" asp-action="Chats" class="@(current == "Chats" || current == "Chat" ? "active" : "")"><i class="bi bi-chat-dots"></i> Chats</a>
            <a asp-controller="Portal" asp-action="Results" class="@(current == "Results" ? "active" : "")"><i class="bi bi-droplet-half"></i> Results</a>
            <a asp-controller="Portal" asp-action="Bills" class="@(current == "Bills" ? "active" : "")"><i class="bi bi-receipt"></i> Bills</a>
        </nav>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/portal/service-worker.js').catch(()=>{});
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
