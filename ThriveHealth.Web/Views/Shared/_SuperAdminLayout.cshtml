@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · ThriveHealth Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; }
        .sa-shell { min-height: 100vh; display: flex; }
        .sa-side { width: 240px; background: #020617; padding: 20px 16px; border-right: 1px solid #1e293b; }
        .sa-side .brand { font-weight: 800; color: #fff; margin-bottom: 24px; display: flex; align-items: center; gap: 8px; font-size: 1.05rem; }
        .sa-side .brand .pill { background: #ef4444; color: #fff; padding: 2px 8px; border-radius: 999px; font-size: .65rem; letter-spacing: .05em; text-transform: uppercase; }
        .sa-side a { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; color: #94a3b8; text-decoration: none; font-size: .9rem; margin-bottom: 4px; }
        .sa-side a:hover { background: #1e293b; color: #fff; }
        .sa-side a.active { background: #1f2937; color: #fff; }
        .sa-nav-group { color: #475569; font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; font-weight: 600; padding: 14px 12px 6px; }
        .sa-main { flex: 1; padding: 32px 36px; overflow-y: auto; }
        .sa-h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 4px; color: #fff; }
        .sa-sub { color: #94a3b8; font-size: .9rem; margin-bottom: 24px; }
        .sa-card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 20px; }
        .sa-card .label { color: #94a3b8; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; }
        .sa-card .value { font-size: 1.8rem; font-weight: 700; margin-top: 6px; color: #fff; }
        .table { color: #e2e8f0; }
        .table thead th { color: #94a3b8; font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #334155; }
        .table tbody td { border-bottom: 1px solid #1e293b; }
        .table tbody tr:hover { background: #1e293b; }
        .badge-pill { padding: 2px 10px; border-radius: 999px; font-size: .75rem; font-weight: 600; }
        .badge-trialing { background: #1d4ed8; color: #fff; }
        .badge-active { background: #16a34a; color: #fff; }
        .badge-pending { background: #f59e0b; color: #000; }
        .badge-pastdue { background: #dc2626; color: #fff; }
        .badge-suspended { background: #6b7280; color: #fff; }
        .badge-cancelled { background: #475569; color: #fff; }
        .badge-pendingverification { background: #6b7280; color: #fff; }
        .form-control, .form-select { background: #0f172a; border-color: #334155; color: #e2e8f0; }
        .form-control:focus, .form-select:focus { background: #0f172a; border-color: #3b82f6; color: #e2e8f0; }
        a { color: #60a5fa; }
        .btn-primary { background: #3b82f6; border: 0; }
    </style>
</head>
<body>
<div class="sa-shell">
    <aside class="sa-side">
        <div class="brand"><i class="bi bi-shield-fill-check"></i> ThriveHealth <span class="pill">Admin</span></div>
        <div class="sa-nav-group">Operations</div>
        <a asp-controller="SuperAdmin" asp-action="Index"><i class="bi bi-grid-1x2"></i> Dashboard</a>
        <a asp-controller="SuperAdminActivity" asp-action="Index"><i class="bi bi-activity"></i> Activity log</a>

        <div class="sa-nav-group">Tenants</div>
        <a asp-controller="SuperAdminTenants" asp-action="Index"><i class="bi bi-building"></i> All tenants</a>
        <a asp-controller="SuperAdminPayments" asp-action="Index"><i class="bi bi-receipt"></i> Bank-transfer review</a>

        <div class="sa-nav-group">Identity</div>
        <a asp-controller="SuperAdminUsers" asp-action="Index"><i class="bi bi-people-fill"></i> All users</a>

        <div class="sa-nav-group">Catalogue</div>
        <a asp-controller="SuperAdminPlans" asp-action="Index"><i class="bi bi-stack"></i> Subscription plans</a>

        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3 pt-3" style="border-top: 1px solid #1e293b;">
            @Html.AntiForgeryToken()
            <button type="submit" style="display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; color: #94a3b8; background: transparent; border: 0; font-size: .9rem; width: 100%; text-align: left; cursor: pointer;"
                    onmouseover="this.style.background='#1e293b'; this.style.color='#fff'"
                    onmouseout="this.style.background='transparent'; this.style.color='#94a3b8'">
                <i class="bi bi-box-arrow-right"></i> Sign out
            </button>
        </form>
    </aside>
    <main class="sa-main">
        @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
        @if (TempData["Error"] != null) { <div class="alert alert-warning">@TempData["Error"]</div> }
        @RenderBody()
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
