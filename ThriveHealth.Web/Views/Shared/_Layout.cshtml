                        <a asp-controller="Grn" asp-action="Index" class="th-nav-link"><i class="bi bi-truck"></i> GRNs</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.StockTakeManage))
                    {
                        <a asp-controller="StockTake" asp-action="Index" class="th-nav-link"><i class="bi bi-clipboard-check"></i> Stock takes</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.InventoryRead))
                    {
                        <a asp-controller="Inventory" asp-action="Stock" class="th-nav-link"><i class="bi bi-box-seam"></i> Inventory stock</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage))
                    {
                        <a asp-controller="Suppliers" asp-action="Index" class="th-nav-link"><i class="bi bi-building"></i> Suppliers</a>
                        <a asp-controller="InventoryItems" asp-action="Index" class="th-nav-link"><i class="bi bi-box"></i> Item master</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.HrRead,
                            ThriveHealth.Web.Models.Identity.Permissions.RosterManage,
                            ThriveHealth.Web.Models.Identity.Permissions.LeaveDecide,
                            ThriveHealth.Web.Models.Identity.Permissions.LeaveRequest))
                {
                    <div class="th-nav-section">Human resources</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.HrRead))
                    {
                        <a asp-controller="Hr" asp-action="Index" class="th-nav-link"><i class="bi bi-person-vcard"></i> Staff &amp; licences</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.RosterManage))
                    {
                        <a asp-controller="Hr" asp-action="Roster" class="th-nav-link"><i class="bi bi-calendar2-week"></i> Duty roster</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.LeaveDecide) || Can(ThriveHealth.Web.Models.Identity.Permissions.LeaveRequest))
                    {
                        <a asp-controller="Hr" asp-action="Leave" class="th-nav-link"><i class="bi bi-calendar-x"></i> Leave</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.IdsrReport,
                            ThriveHealth.Web.Models.Identity.Permissions.NhmisGenerate,
                            ThriveHealth.Web.Models.Identity.Permissions.AnalyticsView))
                {
                    <div class="th-nav-section">Reporting &amp; analytics</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.IdsrReport))
                    {
                        <a asp-controller="Reporting" asp-action="Idsr" class="th-nav-link"><i class="bi bi-shield-shaded"></i> IDSR cases</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.NhmisGenerate))
                    {
                        <a asp-controller="Reporting" asp-action="Nhmis" class="th-nav-link"><i class="bi bi-file-earmark-bar-graph"></i> NHMIS monthly</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AnalyticsView))
                    {
                        <a asp-controller="Analytics" asp-action="Index" class="th-nav-link"><i class="bi bi-graph-up-arrow"></i> Analytics</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.AiNlSearch,
                            ThriveHealth.Web.Models.Identity.Permissions.AiPaedsDose,
                            ThriveHealth.Web.Models.Identity.Permissions.AiTranslate,
                            ThriveHealth.Web.Models.Identity.Permissions.AiAdherenceParse))
                {
                    <div class="th-nav-section">AI</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AiNlSearch))
                    {
                        <a asp-controller="Ai" asp-action="Search" class="th-nav-link"><i class="bi bi-stars"></i> AI search</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AiTranslate))
                    {
                        <a asp-controller="Ai" asp-action="Translate" class="th-nav-link"><i class="bi bi-translate"></i> AI translate</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AiAdherenceParse))
                    {
                        <a asp-controller="Ai" asp-action="AdherenceParse" class="th-nav-link"><i class="bi bi-chat-square-text"></i> Adherence parser</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AiPaedsDose))
                    {
                        <a asp-controller="Paediatrics" asp-action="DoseCheck" class="th-nav-link"><i class="bi bi-droplet"></i> Paeds dose check</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.StaffManage,
                            ThriveHealth.Web.Models.Identity.Permissions.ClinicsManage,
                            ThriveHealth.Web.Models.Identity.Permissions.WardsManage))
                {
                    <div class="th-nav-section">Administration</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.StaffManage))
                    {
                        <a asp-controller="Account" asp-action="StaffList" class="th-nav-link"><i class="bi bi-person-badge"></i> Staff</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.ClinicsManage))
                    {
                        <a asp-controller="Clinics" asp-action="Index" class="th-nav-link"><i class="bi bi-buildings"></i> Clinics</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.WardsManage))
                    {
                        <a asp-controller="Wards" asp-action="Index" class="th-nav-link"><i class="bi bi-grid-3x3"></i> Wards &amp; beds</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.AuditView,
                            ThriveHealth.Web.Models.Identity.Permissions.IntegrationsManage,
                            ThriveHealth.Web.Models.Identity.Permissions.HardeningView,
                            ThriveHealth.Web.Models.Identity.Permissions.RbacManage))
                {
                    <div class="th-nav-section">Operations</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AuditView))
                    {
                        <a asp-controller="Admin" asp-action="Audit" class="th-nav-link"><i class="bi bi-journal-text"></i> Audit log</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.IntegrationsManage))
                    {
                        <a asp-controller="Admin" asp-action="Integrations" class="th-nav-link"><i class="bi bi-plug"></i> Integrations</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.HardeningView))
                    {
                        <a asp-controller="Admin" asp-action="Hardening" class="th-nav-link"><i class="bi bi-shield-check"></i> Hardening</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.RbacManage))
                    {
                        <a asp-controller="Roles" asp-action="Index" class="th-nav-link"><i class="bi bi-shield-lock"></i> Roles &amp; permissions</a>
                    }
