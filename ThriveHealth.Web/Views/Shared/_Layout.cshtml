@using Microsoft.AspNetCore.Identity
@using ThriveHealth.Web.Models.Identity
@using ThriveHealth.Web.Services
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IPermissionService Perms
@{
    var isAuthed = SignInManager.IsSignedIn(User);
    ApplicationUser? currentUser = isAuthed ? await UserManager.GetUserAsync(User) : null;
    var roles = isAuthed && currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();

    var userPerms = isAuthed ? await Perms.GetForUserAsync(User) : new HashSet<string>();
    bool Can(string p) => userPerms.Contains(p);
    bool CanAny(params string[] ps) => ps.Any(p => userPerms.Contains(p));
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · ThriveHealth</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="th-app">
    @if (isAuthed)
    {
        <aside class="th-sidebar" id="thSidebar">
            <div class="th-brand">
                <span class="th-logo"><i class="bi bi-heart-pulse-fill"></i></span>
                <div>
                    <div class="th-brand-name">ThriveHealth</div>
                    <div class="th-brand-tag">Hospital OS</div>
                </div>
            </div>

            <nav class="th-nav">
                <div class="th-nav-section">Overview</div>
                <a asp-controller="Dashboard" asp-action="Index" class="th-nav-link">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                @{
                    var P = typeof(ThriveHealth.Web.Models.Identity.Permissions);
                }
                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.PatientsRead,
                            ThriveHealth.Web.Models.Identity.Permissions.AppointmentsRead,
                            ThriveHealth.Web.Models.Identity.Permissions.QueueRead,
                            ThriveHealth.Web.Models.Identity.Permissions.AdmissionsManage,
                            ThriveHealth.Web.Models.Identity.Permissions.WardsManage,
                            ThriveHealth.Web.Models.Identity.Permissions.EmergencyBoardRead,
                            ThriveHealth.Web.Models.Identity.Permissions.TheatreSchedule,
                            ThriveHealth.Web.Models.Identity.Permissions.AncManage,
                            ThriveHealth.Web.Models.Identity.Permissions.PaedsManage,
                            ThriveHealth.Web.Models.Identity.Permissions.ImmunizationAdminister,
                            ThriveHealth.Web.Models.Identity.Permissions.IcuChart,
                            ThriveHealth.Web.Models.Identity.Permissions.DialysisRun,
                            ThriveHealth.Web.Models.Identity.Permissions.TelemedicineClinician,
                            ThriveHealth.Web.Models.Identity.Permissions.QueueServe))
                {
                    <div class="th-nav-section">Clinical</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PatientsRead))
                    {
                        <a asp-controller="Patients" asp-action="Index" class="th-nav-link"><i class="bi bi-people"></i> Patients</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AppointmentsRead))
                    {
                        <a asp-controller="Appointments" asp-action="Index" class="th-nav-link"><i class="bi bi-calendar2-week"></i> Appointments</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.QueueRead))
                    {
                        <a asp-controller="Queue" asp-action="Index" class="th-nav-link"><i class="bi bi-list-check"></i> Queues</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.QueueServe))
                    {
                        <a asp-controller="Queue" asp-action="MyQueue" class="th-nav-link"><i class="bi bi-clipboard2-pulse"></i> My queue</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.WardsManage) || Can(ThriveHealth.Web.Models.Identity.Permissions.AdmissionsManage))
                    {
                        <a asp-controller="Wards" asp-action="Board" class="th-nav-link"><i class="bi bi-hospital"></i> Bed board</a>
                        <a asp-controller="Admissions" asp-action="Index" class="th-nav-link"><i class="bi bi-clipboard2-heart"></i> Admissions</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.EmergencyBoardRead))
                    {
                        <a asp-controller="Emergency" asp-action="Index" class="th-nav-link"><i class="bi bi-bandaid"></i> A&amp;E</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.TheatreSchedule))
                    {
                        <a asp-controller="Theatre" asp-action="Schedule" class="th-nav-link"><i class="bi bi-scissors"></i> Theatre</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AncManage))
                    {
                        <a asp-controller="Maternity" asp-action="Index" class="th-nav-link"><i class="bi bi-heart-pulse"></i> Maternity</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PaedsManage))
                    {
                        <a asp-controller="Paediatrics" asp-action="Index" class="th-nav-link"><i class="bi bi-people"></i> Paediatrics</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.ImmunizationAdminister))
                    {
                        <a asp-controller="Immunization" asp-action="Worklist" class="th-nav-link"><i class="bi bi-bandaid"></i> Immunization</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.IcuChart))
                    {
                        <a asp-controller="Icu" asp-action="Board" class="th-nav-link"><i class="bi bi-activity"></i> ICU board</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.DialysisRun))
                    {
                        <a asp-controller="Icu" asp-action="Dialysis" class="th-nav-link"><i class="bi bi-droplet"></i> Dialysis</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.TelemedicineClinician))
                    {
                        <a asp-controller="Telemedicine" asp-action="Index" class="th-nav-link"><i class="bi bi-camera-video"></i> Telemedicine</a>
                        <a asp-controller="Telemedicine" asp-action="Chats" class="th-nav-link"><i class="bi bi-chat-dots"></i> Chats</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.BloodBankManage,
                            ThriveHealth.Web.Models.Identity.Permissions.BloodBankCrossMatch,
                            ThriveHealth.Web.Models.Identity.Permissions.AlliedSession,
                            ThriveHealth.Web.Models.Identity.Permissions.MortuaryManage))
                {
                    <div class="th-nav-section">Specialised</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.BloodBankManage) || Can(ThriveHealth.Web.Models.Identity.Permissions.BloodBankCrossMatch))
                    {
                        <a asp-controller="BloodBank" asp-action="Index" class="th-nav-link"><i class="bi bi-droplet-fill"></i> Blood bank</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.AlliedSession))
                    {
                        <a asp-controller="Allied" asp-action="Index" class="th-nav-link"><i class="bi bi-clipboard2-pulse"></i> Allied (Dental/Physio/Optom)</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.MortuaryManage))
                    {
                        <a asp-controller="Mortuary" asp-action="Index" class="th-nav-link"><i class="bi bi-archive"></i> Mortuary</a>
                    }
