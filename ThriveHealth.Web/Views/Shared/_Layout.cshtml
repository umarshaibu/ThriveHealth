                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage,
                            ThriveHealth.Web.Models.Identity.Permissions.GrnReceive,
                            ThriveHealth.Web.Models.Identity.Permissions.StockTakeManage,
                            ThriveHealth.Web.Models.Identity.Permissions.InventoryRead))
                {
