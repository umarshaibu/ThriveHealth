                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage))
                    {
                        <a asp-controller="PurchaseOrders" asp-action="Index" class="th-nav-link"><i class="bi bi-cart"></i> Purchase orders</a>
