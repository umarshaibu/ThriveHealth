                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.PharmacyDispense,
                            ThriveHealth.Web.Models.Identity.Permissions.PharmacyStock,
                            ThriveHealth.Web.Models.Identity.Permissions.PharmacyControlled))
                {
                    <div class="th-nav-section">Pharmacy</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PharmacyDispense))
                    {
                        <a asp-controller="Pharmacy" asp-action="Worklist" class="th-nav-link"><i class="bi bi-prescription2"></i> Worklist</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PharmacyStock))
                    {
                        <a asp-controller="Pharmacy" asp-action="Stock" class="th-nav-link"><i class="bi bi-box-seam"></i> Stock</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PharmacyControlled))
                    {
                        <a asp-controller="Pharmacy" asp-action="ControlledRegister" class="th-nav-link"><i class="bi bi-shield-lock"></i> Controlled register</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PharmacyStock))
                    {
                        <a asp-controller="Drugs" asp-action="Index" class="th-nav-link"><i class="bi bi-capsule"></i> Drug master</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.LabPerform,
                            ThriveHealth.Web.Models.Identity.Permissions.ImagingPerform))
                {
                    <div class="th-nav-section">Diagnostics</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.LabPerform))
                    {
                        <a asp-controller="Lab" asp-action="Worklist" class="th-nav-link"><i class="bi bi-droplet-half"></i> Lab worklist</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.ImagingPerform))
                    {
                        <a asp-controller="Imaging" asp-action="Worklist" class="th-nav-link"><i class="bi bi-radioactive"></i> Imaging worklist</a>
                    }
                }

                @if (CanAny(ThriveHealth.Web.Models.Identity.Permissions.BillsRead,
                            ThriveHealth.Web.Models.Identity.Permissions.CashierShiftManage,
                            ThriveHealth.Web.Models.Identity.Permissions.ClaimsManage,
                            ThriveHealth.Web.Models.Identity.Permissions.PayersManage))
                {
                    <div class="th-nav-section">Finance</div>
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.BillsRead))
