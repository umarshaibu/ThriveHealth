                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.ClaimsManage))
                    {
                        <a asp-controller="Claims" asp-action="Index" class="th-nav-link"><i class="bi bi-file-earmark-medical"></i> Claims</a>
                    }
                    @if (Can(ThriveHealth.Web.Models.Identity.Permissions.PayersManage))
