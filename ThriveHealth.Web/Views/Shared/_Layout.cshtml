            <div class="th-sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-grid">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light btn-sm w-100">
                        <i class="bi bi-box-arrow-right me-1"></i> Sign out
                    </button>
                </form>
            </div>
        </aside>

        <main class="th-main">
            <header class="th-topbar">
                <button class="btn btn-light th-sidebar-toggle d-lg-none" type="button" onclick="thToggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <form class="th-search" asp-controller="Patients" asp-action="Index" method="get">
                    <i class="bi bi-search"></i>
                    <input type="search" name="q" class="form-control" placeholder="Search patients by name, hospital #, phone, NIN..." />
                </form>

                <div class="ms-auto d-flex align-items-center gap-2">
                    <span class="badge th-badge-soft"><i class="bi bi-shield-check"></i> NDPA</span>
                    <span class="badge th-badge-soft d-none d-md-inline"><i class="bi bi-broadcast"></i> Live</span>
                    <div class="dropdown">
                        <button class="btn th-user-btn dropdown-toggle" data-bs-toggle="dropdown">
                            <span class="th-avatar">@(currentUser?.FirstName?.Substring(0,1))@(currentUser?.LastName?.Substring(0,1))</span>
                            <span class="d-none d-sm-inline ms-2">
                                <span class="d-block small fw-semibold">@currentUser?.FullName</span>
                                <span class="d-block small text-muted">@(roles.FirstOrDefault() ?? "Staff")</span>
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-shield-lock me-2"></i>Change password</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                    <button class="btn btn-sm btn-outline-danger w-100" type="submit"><i class="bi bi-box-arrow-right me-1"></i>Sign out</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <div class="th-content">
                @if (TempData["Success"] is string okMsg)
                {
                    <div class="alert alert-success d-flex align-items-center"><i class="bi bi-check-circle me-2"></i>@okMsg</div>
                }
                @if (TempData["Error"] is string errMsg)
                {
                    <div class="alert alert-danger d-flex align-items-center"><i class="bi bi-exclamation-triangle me-2"></i>@errMsg</div>
                }
                @RenderBody()
            </div>
        </main>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function thToggleSidebar() {
            document.getElementById('thSidebar')?.classList.toggle('open');
        }

        // Highlight the sidebar item whose href best matches the current URL.
        // Uses the longest path prefix that aligns on a path-segment boundary, so e.g.
        // /Pharmacy/Stock matches the "Stock" link rather than the parent "Pharmacy" link.
        (function () {
            var raw = (window.location.pathname || '/').replace(/\/+$/, '');
            var path = (raw === '' ? '/' : raw).toLowerCase();

            function pathOf(a) {
                if (!a.href) return null;
                try {
                    var u = new URL(a.href, window.location.origin);
                    var p = (u.pathname || '/').replace(/\/+$/, '');
                    return (p === '' ? '/' : p).toLowerCase();
                } catch (e) { return null; }
            }

            var links = Array.from(document.querySelectorAll('.th-nav-link'));
            var best = null, bestLen = -1;
            for (var i = 0; i < links.length; i++) {
                var lp = pathOf(links[i]);
                if (!lp) continue;
                var matches = (lp === path) || (path === lp + '/') || path.indexOf(lp + '/') === 0;
                // Treat the root "/" specially — match dashboard / first link with controller "Dashboard"
                if (path === '/' && lp.indexOf('/dashboard') === 0) matches = true;
                if (matches && lp.length > bestLen) {
                    best = links[i];
                    bestLen = lp.length;
                }
            }
            if (best) best.classList.add('active');
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
