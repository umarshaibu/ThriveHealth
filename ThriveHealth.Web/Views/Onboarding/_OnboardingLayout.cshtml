@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] · ThriveHealth</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root { --th-primary: #0f3a8a; --th-primary-dark: #0a2a66; --th-accent: #14b8a6; --th-bg: #f5f7fa; --th-text: #0f172a; }
        body { font-family: 'Inter', system-ui, sans-serif; background: var(--th-bg); color: var(--th-text); }
        .th-nav { padding: 18px 32px; display: flex; justify-content: space-between; align-items: center; background: #fff; border-bottom: 1px solid #e2e8f0; position: sticky; top: 0; z-index: 50; }
        .th-nav .brand { font-weight: 800; font-size: 1.25rem; letter-spacing: -.02em; color: var(--th-primary); display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
        .th-nav .brand .mark { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--th-primary), var(--th-primary-dark)); color: #fff; display: inline-flex; align-items: center; justify-content: center; }
        .th-nav .links a { color: #475569; text-decoration: none; margin: 0 16px; font-weight: 500; font-size: .95rem; }
        .th-nav .links a:hover { color: var(--th-primary); }
        .th-nav .cta { background: linear-gradient(135deg, var(--th-primary), var(--th-primary-dark)); color: #fff; padding: 10px 18px; border-radius: 10px; font-weight: 600; text-decoration: none; box-shadow: 0 6px 20px rgba(15, 58, 138, .25); }
        .th-foot { padding: 36px 32px; color: #94a3b8; font-size: .85rem; text-align: center; border-top: 1px solid #e2e8f0; background: #fff; margin-top: 48px; }
    </style>
</head>
<body>
    <nav class="th-nav">
        <a class="brand" href="/"><span class="mark"><i class="bi bi-heart-pulse-fill"></i></span> ThriveHealth</a>
        <div class="links d-none d-md-block">
            <a href="/pricing">Pricing</a>
            <a href="/#features">Features</a>
            <a href="/#contact">Contact</a>
        </div>
        <a class="cta" href="/signup">Start free trial</a>
    </nav>

    @RenderBody()

    <footer class="th-foot">
        &copy; @DateTime.Now.Year ThriveHealth · Multi-tenant hospital management platform · Built for Nigerian healthcare
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
