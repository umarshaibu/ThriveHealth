@model ThriveHealth.Web.Models.Tenancy.Tenant
@{
    ViewData["Title"] = "Welcome to ThriveHealth";
    var loginUrl = $"https://{Model.Slug}.thrivehealth.ng/login";
    var devUrl = $"/?tenant={Model.Slug}";
}

<style>
    .th-welcome { max-width: 720px; margin: 64px auto; padding: 0 24px; text-align: center; }
    .th-welcome .icon { width: 88px; height: 88px; border-radius: 50%; background: linear-gradient(135deg, #14b8a6, #0d9488); color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 2.5rem; margin-bottom: 24px; }
    .th-welcome h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -.02em; margin-bottom: 12px; }
    .th-welcome .lead { color: #64748b; font-size: 1.05rem; line-height: 1.6; max-width: 520px; margin: 0 auto 32px; }
    .th-welcome .signin-card { background: #fff; border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 28px; text-align: left; max-width: 540px; margin: 0 auto 24px; }
    .th-welcome .signin-card .row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px dashed #e2e8f0; font-size: .95rem; }
    .th-welcome .signin-card .row:last-child { border: 0; }
    .th-welcome .signin-card .row .label { color: #64748b; }
    .th-welcome .signin-card .row .value { font-weight: 600; font-family: ui-monospace, monospace; }
    .th-welcome .cta { display: inline-block; padding: 14px 28px; background: linear-gradient(135deg, var(--th-primary), var(--th-primary-dark)); color: #fff; border-radius: 12px; font-weight: 700; text-decoration: none; box-shadow: 0 12px 36px rgba(15,58,138,.25); }
    .th-welcome .timeline { text-align: left; max-width: 540px; margin: 32px auto 0; }
    .th-welcome .timeline-item { display: flex; gap: 14px; padding: 16px 0; border-bottom: 1px dashed #e2e8f0; }
    .th-welcome .timeline-item .num { width: 28px; height: 28px; flex-shrink: 0; border-radius: 50%; background: var(--th-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .85rem; }
    .th-welcome .timeline-item h6 { margin: 0 0 4px; font-weight: 700; }
    .th-welcome .timeline-item p { margin: 0; color: #64748b; font-size: .9rem; line-height: 1.5; }
</style>

<div class="th-welcome">
    <div class="icon"><i class="bi bi-check-lg"></i></div>
    <h1>Your hospital is ready, @Model.OwnerName?.Split(' ').First()!</h1>
    <p class="lead">@Model.LegalName has been provisioned on ThriveHealth. Your 30-day free trial has started — full access to telemedicine, EMR, billing and more.</p>

    <div class="signin-card">
        <div class="row"><span class="label">Workspace URL</span><span class="value">@(Model.Slug + ".thrivehealth.ng")</span></div>
        <div class="row"><span class="label">Owner email</span><span class="value">@Model.OwnerEmail</span></div>
        <div class="row"><span class="label">Trial ends</span><span class="value">@Model.TrialEndsAt?.ToString("dd MMM yyyy")</span></div>
        <div class="row"><span class="label">Currency</span><span class="value">@Model.CurrencyCode</span></div>
    </div>

    <p class="text-muted small">We've emailed your temporary password to <strong>@Model.OwnerEmail</strong>. Sign in and change it right away.</p>

    <a class="cta" href="@devUrl">Open my workspace <i class="bi bi-arrow-right ms-1"></i></a>

    <div class="timeline">
        <div class="timeline-item"><div class="num">1</div><div><h6>Change your password</h6><p>Sign in with the temporary password we just emailed you, then set a strong one.</p></div></div>
        <div class="timeline-item"><div class="num">2</div><div><h6>Add your team</h6><p>Invite doctors, nurses, cashiers and front-desk staff. They'll get email invites with their roles.</p></div></div>
        <div class="timeline-item"><div class="num">3</div><div><h6>Customise your workspace</h6><p>Upload your logo, set your bank details for invoices, configure clinics and lab catalogues.</p></div></div>
        <div class="timeline-item"><div class="num">4</div><div><h6>Go live</h6><p>Register your first patient, raise your first bill, run your first tele-consult. We're here if you need us.</p></div></div>
    </div>
</div>
