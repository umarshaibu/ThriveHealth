@model ThriveHealth.Web.Models.Inventory.PurchaseOrder
@{
    ViewData["Title"] = $"PO {Model.PoNumber}";
    var statusTone = Model.Status switch
    {
        ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Draft => "th-pill-info",
        ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Approved => "th-pill-warning",
        ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Issued => "th-pill-warning",
        ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.PartiallyReceived => "th-pill-warning",
        ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Received => "th-pill-success",
        ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Cancelled => "th-pill-muted",
        _ => "th-pill-muted"
    };
    var canApprove = Model.Status == ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Draft;
    var canIssue = Model.Status == ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Approved;
    var canReceive = Model.Status == ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Issued
                  || Model.Status == ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.PartiallyReceived;
    var canCancel = Model.Status != ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Received
                 && Model.Status != ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Cancelled
                 && Model.Status != ThriveHealth.Web.Models.Inventory.PurchaseOrderStatus.Closed;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <span class="th-pill @statusTone">@Model.Status</span>
        <h1 class="th-section-title mt-2">@Model.PoNumber</h1>
        <p class="th-section-sub mb-0">
            <strong>@Model.Supplier?.Name</strong> · Delivery to <strong>@Model.Store?.Name</strong>
            · Created @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy") by @Model.CreatedBy?.FullName
            @if (Model.ExpectedDate.HasValue) { <span> · Expected @Model.ExpectedDate.Value.ToString("dd MMM yyyy")</span> }
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Worklist</a>
        @if (canApprove)
        {
            <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage">
                @Html.AntiForgeryToken()
                <button class="btn btn-warning"><i class="bi bi-check2-circle me-1"></i> Approve</button>
            </form>
        }
        @if (canIssue)
        {
            <form asp-action="Issue" asp-route-id="@Model.Id" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage">
                @Html.AntiForgeryToken()
                <button class="btn btn-primary"><i class="bi bi-send me-1"></i> Issue to supplier</button>
            </form>
        }
        @if (canReceive)
        {
            <a asp-controller="Grn" asp-action="Receive" asp-route-purchaseOrderId="@Model.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.GrnReceive" class="btn btn-success"><i class="bi bi-truck me-1"></i> Receive (GRN)</a>
        }
        @if (canCancel)
        {
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline" onsubmit="return confirm('Cancel this PO?');" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-danger"><i class="bi bi-x-octagon me-1"></i> Cancel</button>
            </form>
        }
    </div>
</div>

<div class="th-card mb-3">
    <div class="th-card-header"><h5 class="th-card-title"><i class="bi bi-list-ul me-1 text-primary"></i> Lines (@Model.Items.Count)</h5></div>
    <div class="th-card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>Type</th><th>Description</th><th class="text-end">Ordered</th><th class="text-end">Received</th><th class="text-end">Outstanding</th><th class="text-end">Unit ₦</th><th class="text-end">Line ₦</th></tr></thead>
            <tbody>
            @foreach (var i in Model.Items)
            {
                var kind = i.DrugId.HasValue ? "Drug" : (i.InventoryItemId.HasValue ? "Item" : "Free");
                var fully = i.QuantityReceived >= i.QuantityOrdered;
                <tr class="@(fully ? "" : "")">
                    <td><span class="th-pill @(i.DrugId.HasValue ? "th-pill-warning" : i.InventoryItemId.HasValue ? "th-pill-info" : "th-pill-muted")">@kind</span></td>
                    <td><strong>@i.Description</strong>@if (!string.IsNullOrEmpty(i.UnitOfIssue)) { <small class="text-muted ms-1">@i.UnitOfIssue</small> }</td>
                    <td class="text-end">@i.QuantityOrdered</td>
                    <td class="text-end">@i.QuantityReceived</td>
                    <td class="text-end">@(i.QuantityOrdered - i.QuantityReceived)</td>
                    <td class="text-end">@i.UnitPrice.ToString("N2")</td>
                    <td class="text-end">@i.LineTotal.ToString("N2")</td>
                </tr>
            }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <th colspan="6" class="text-end">Total</th>
                    <th class="text-end">@Model.TotalAmount.ToString("N2")</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@if (Model.Grns.Any())
{
    <div class="th-card">
        <div class="th-card-header"><h5 class="th-card-title"><i class="bi bi-truck me-1 text-primary"></i> Goods received notes (@Model.Grns.Count)</h5></div>
        <div class="th-card-body p-0">
            <table class="table align-middle mb-0">
                <thead><tr><th>GRN #</th><th>Received</th><th>Lines</th><th class="text-end">Value ₦</th><th class="text-end"></th></tr></thead>
                <tbody>
                @foreach (var g in Model.Grns.OrderByDescending(x => x.ReceivedAt))
                {
                    <tr>
                        <td><span class="font-monospace">@g.GrnNumber</span></td>
                        <td><small>@g.ReceivedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small></td>
                        <td>@g.Items.Count</td>
                        <td class="text-end">@g.TotalReceivedValue.ToString("N2")</td>
                        <td class="text-end"><a asp-controller="Grn" asp-action="Details" asp-route-id="@g.Id" class="btn btn-sm btn-outline-primary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.GrnReceive"><i class="bi bi-folder2-open"></i></a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
