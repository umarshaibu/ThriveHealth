@model ThriveHealth.Web.Models.ViewModels.LabBoardVm

<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="th-card h-100">
            <div class="th-card-header d-flex justify-content-between align-items-center">
                <h5 class="th-card-title mb-0"><i class="bi bi-droplet me-1 text-primary"></i> Specimens in progress</h5>
                <a asp-controller="Lab" asp-action="Index" class="small">Worklist →</a>
            </div>
            <div class="th-card-body p-0">
                @if (!Model.OpenSamples.Any())
                {
                    <div class="th-empty p-4">
                        <i class="bi bi-check2-circle"></i>
                        <h6 class="mt-2 mb-1">No open samples</h6>
                    </div>
                }
                else
                {
                    <table class="table mb-0 align-middle">
                        <thead><tr><th>Patient</th><th>Test</th><th>Status</th><th>Ordered</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var s in Model.OpenSamples)
                        {
                            var ageMin = (int)Math.Max(0, (DateTime.UtcNow - s.OrderedAt).TotalMinutes);
                            <tr>
                                <td class="fw-semibold">@s.PatientName</td>
                                <td class="small">@s.Tests</td>
                                <td><span class="th-pill th-pill-info">@s.Status</span></td>
                                <td class="small text-muted">@ageMin m</td>
                                <td><a asp-controller="Lab" asp-action="Order" asp-route-id="@s.LabOrderId" class="btn btn-sm btn-outline-primary">Open</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="th-card h-100">
            <div class="th-card-header">
                <h5 class="th-card-title mb-0"><i class="bi bi-shield-check me-1 text-warning"></i> Awaiting authorisation</h5>
            </div>
            <div class="th-card-body p-0">
                @if (!Model.AwaitingAuthorisation.Any())
                {
                    <div class="th-empty p-4">
                        <i class="bi bi-check2-circle"></i>
                        <h6 class="mt-2 mb-1">Nothing awaiting authorisation</h6>
                    </div>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                    @foreach (var s in Model.AwaitingAuthorisation)
                    {
                        <li class="border-bottom px-3 py-2 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">@s.PatientName</div>
                                <div class="small text-muted">@s.Tests</div>
                            </div>
                            <a asp-controller="Lab" asp-action="Order" asp-route-id="@s.LabOrderId" class="btn btn-sm btn-warning">Authorise</a>
                        </li>
                    }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<div class="th-card mb-4 border-danger">
    <div class="th-card-header bg-danger-subtle">
        <h5 class="th-card-title mb-0 text-danger"><i class="bi bi-exclamation-octagon-fill me-1"></i> Critical values — clinician not yet notified</h5>
    </div>
    <div class="th-card-body p-0">
        @if (!Model.CriticalUnnotified.Any())
        {
            <div class="th-empty p-4">
                <i class="bi bi-check2-circle"></i>
                <h6 class="mt-2 mb-1">No outstanding critical values</h6>
                <p class="mb-0 small">Every critical result has been called through to the ordering clinician.</p>
            </div>
        }
        else
        {
            <table class="table mb-0 align-middle">
                <thead><tr><th>Patient</th><th>Test</th><th>Value</th><th>Flagged</th><th></th></tr></thead>
                <tbody>
                @foreach (var c in Model.CriticalUnnotified)
                {
                    var ageMin = (int)Math.Max(0, (DateTime.UtcNow - c.FlaggedAt).TotalMinutes);
                    <tr class="table-danger">
                        <td class="fw-semibold">@c.PatientName</td>
                        <td class="small">@c.Test</td>
                        <td><strong>@c.Value</strong></td>
                        <td class="small">@ageMin m ago</td>
                        <td><a asp-controller="Lab" asp-action="Order" asp-route-id="@c.LabOrderId" class="btn btn-sm btn-danger">Notify now</a></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
