@model ThriveHealth.Web.Models.ViewModels.FinanceBoardVm

<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="th-card h-100">
            <div class="th-card-header"><h5 class="th-card-title mb-0"><i class="bi bi-cash-coin me-1 text-success"></i> Collected today</h5></div>
            <div class="th-card-body">
                <div class="display-6 fw-bold">₦@Model.CollectedToday.ToString("N0")</div>
                <hr class="my-3" />
                @if (Model.CollectedByMethod.Any())
                {
                    <div class="small">
                        @foreach (var m in Model.CollectedByMethod.OrderByDescending(x => x.Value))
                        {
                            <div class="d-flex justify-content-between py-1" style="border-bottom: 1px dashed #e2e8f0;">
                                <span>@m.Key</span>
                                <span class="fw-semibold">₦@m.Value.ToString("N0")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-0">No payments recorded today yet.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="th-card h-100">
            <div class="th-card-header d-flex justify-content-between align-items-center">
                <h5 class="th-card-title mb-0"><i class="bi bi-receipt me-1 text-primary"></i> Open bills</h5>
                <a asp-controller="Bills" asp-action="Index" class="small">All bills →</a>
            </div>
            <div class="th-card-body p-0">
                @if (!Model.OpenBills.Any())
                {
                    <div class="th-empty p-4">
                        <i class="bi bi-check2-circle"></i>
                        <h6 class="mt-2 mb-1">No open bills</h6>
                        <p class="mb-0 small">Bills will appear here as patients accumulate charges during their visit.</p>
                    </div>
                }
                else
                {
                    <table class="table mb-0 align-middle">
                        <thead><tr><th>Bill</th><th>Patient</th><th class="text-end">Total</th><th class="text-end">Outstanding</th><th>Opened</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var b in Model.OpenBills)
                        {
                            <tr>
                                <td class="font-monospace small">#@b.BillId</td>
                                <td class="fw-semibold">@b.PatientName</td>
                                <td class="text-end">₦@b.Total.ToString("N0")</td>
                                <td class="text-end text-danger fw-bold">₦@b.Outstanding.ToString("N0")</td>
                                <td class="small text-muted">@b.OpenedAt.ToLocalTime().ToString("dd MMM HH:mm")</td>
                                <td><a asp-controller="Cashier" asp-action="Bill" asp-route-id="@b.BillId" class="btn btn-sm btn-primary">Take payment</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<div class="th-card mb-4">
    <div class="th-card-header"><h5 class="th-card-title mb-0"><i class="bi bi-clock-history me-1 text-info"></i> Recent payments today</h5></div>
    <div class="th-card-body p-0">
        @if (!Model.RecentPayments.Any())
        {
            <div class="th-empty p-4">
                <i class="bi bi-cash"></i>
                <h6 class="mt-2 mb-1">No payments recorded yet today</h6>
            </div>
        }
        else
        {
            <table class="table mb-0 align-middle">
                <thead><tr><th>Time</th><th>Patient</th><th>Method</th><th class="text-end">Amount</th></tr></thead>
                <tbody>
                @foreach (var p in Model.RecentPayments)
                {
                    <tr>
                        <td class="font-monospace small">@p.At.ToLocalTime().ToString("HH:mm")</td>
                        <td class="fw-semibold">@p.PatientName</td>
                        <td><span class="th-pill th-pill-muted">@p.Method</span></td>
                        <td class="text-end fw-bold">₦@p.Amount.ToString("N0")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
