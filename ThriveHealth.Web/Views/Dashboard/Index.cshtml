@model ThriveHealth.Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4 gap-3">
    <div>
        <h1 class="th-section-title">Good @(DateTime.Now.Hour < 12 ? "morning" : DateTime.Now.Hour < 17 ? "afternoon" : "evening"), @Model.GreetingName 👋</h1>
        <p class="th-section-sub mb-0">@Model.FacilityName · <strong>@Model.Persona</strong> · @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
    </div>
    <div class="d-flex gap-2">
        <span class="th-pill th-pill-success"><i class="bi bi-circle-fill me-1" style="font-size:8px;"></i> All systems operational</span>
    </div>
</div>

@if (Model.ActiveAlerts.Any())
{
    <div class="alert alert-warning d-flex align-items-start gap-2 mb-4">
        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
        <div>
            <strong>Attention required</strong>
            <ul class="mb-0 mt-1 small">
                @foreach (var a in Model.ActiveAlerts) { <li>@a</li> }
            </ul>
        </div>
    </div>
}

@* KPI strip — shown for every persona (high-level summary above the working surface). *@
@if (Model.BoardKey != "Executive")  @* Executive partial owns its own KPI strip. *@
{
    <div class="row g-3 mb-4">
        @foreach (var s in Model.Stats)
        {
            <div class="col-sm-6 col-xl-3">
                <div class="th-stat tone-@s.Tone">
                    <div class="th-stat-icon"><i class="bi @(s.Icon ?? "bi-graph-up")"></i></div>
                    <div class="th-stat-label">@s.Label</div>
                    <div class="th-stat-value">@s.Value</div>
                </div>
            </div>
        }
    </div>
}

@* Role-specific working surface (real lists of items to action). *@
@if (!string.IsNullOrEmpty(Model.BoardKey) && Model.Board is not null)
{
    @await Html.PartialAsync($"Partials/_Board{Model.BoardKey}", Model.Board)
}

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="th-card">
            <div class="th-card-header">
                <h5 class="th-card-title"><i class="bi bi-bell me-1 text-primary"></i> Recent activity</h5>
            </div>
            <div class="th-card-body p-0">
                @if (!Model.RecentActivity.Any())
                {
                    <div class="th-empty p-4">
                        <i class="bi bi-clipboard2-pulse"></i>
                        <h6 class="mt-2 mb-1">Quiet for now</h6>
                        <p class="mb-0 small">Activity for your role will show here as it happens.</p>
                    </div>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var item in Model.RecentActivity)
                        {
                            <li class="border-bottom px-3 py-2 d-flex align-items-start gap-3">
                                <span class="th-pill th-pill-@item.Tone"><i class="bi @item.Icon"></i></span>
                                <div class="flex-grow-1">
                                    @if (!string.IsNullOrEmpty(item.LinkController) && !string.IsNullOrEmpty(item.LinkAction))
                                    {
                                        <a class="text-decoration-none fw-semibold" asp-controller="@item.LinkController" asp-action="@item.LinkAction" asp-route-id="@item.LinkId">@item.Title</a>
                                    }
                                    else { <span class="fw-semibold">@item.Title</span> }
                                    @if (!string.IsNullOrEmpty(item.Subtitle))
                                    {
                                        <div class="small text-muted">@item.Subtitle</div>
                                    }
                                </div>
                                <div class="small text-muted text-nowrap">@item.At.ToLocalTime().ToString("dd MMM HH:mm")</div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="th-card">
            <div class="th-card-header">
                <h5 class="th-card-title"><i class="bi bi-lightning me-1 text-warning"></i> Quick actions</h5>
            </div>
            <div class="th-card-body">
                <div class="d-flex flex-column gap-2">
                    @foreach (var a in Model.NextActions)
                    {
                        <a class="btn btn-outline-primary text-start" asp-controller="@a.Controller" asp-action="@a.Action" asp-permission="@a.Permission"><i class="bi @a.Icon me-1"></i>@a.Label</a>
                    }
                    @if (!Model.NextActions.Any())
                    {
                        <div class="text-muted small">No suggestions for your role.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
