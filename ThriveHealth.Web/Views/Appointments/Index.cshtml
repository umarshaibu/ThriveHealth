@model ThriveHealth.Web.Models.ViewModels.AppointmentListViewModel
@{ ViewData["Title"] = "Appointments"; }

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Appointments</h1>
        <p class="th-section-sub mb-0">@Model.Date.ToString("dddd, dd MMMM yyyy") · @Model.Appointments.Count scheduled</p>
    </div>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex">
            <input type="date" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" class="form-control me-2" onchange="this.form.submit()" />
        </form>
        <a asp-action="Book" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AppointmentsBook" class="btn btn-primary"><i class="bi bi-calendar-plus me-1"></i> Book appointment</a>
    </div>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Appointments.Any())
{
    <div class="th-empty m-4"><i class="bi bi-calendar2-week"></i><h5 class="mt-2">No appointments</h5><p>Nothing scheduled on this date.</p>
        <a asp-action="Book" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AppointmentsBook" class="btn btn-primary"><i class="bi bi-calendar-plus me-1"></i> Book appointment</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th>Time</th><th>Patient</th><th>Clinic</th><th>Clinician</th><th>Type</th><th>Priority</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var a in Model.Appointments)
            {
                var statusTone = a.Status switch
                {
                    ThriveHealth.Web.Models.Scheduling.AppointmentStatus.Scheduled => "th-pill-info",
                    ThriveHealth.Web.Models.Scheduling.AppointmentStatus.CheckedIn => "th-pill-warning",
                    ThriveHealth.Web.Models.Scheduling.AppointmentStatus.InProgress => "th-pill-success",
                    ThriveHealth.Web.Models.Scheduling.AppointmentStatus.Completed => "th-pill-success",
                    ThriveHealth.Web.Models.Scheduling.AppointmentStatus.Cancelled => "th-pill-muted",
                    ThriveHealth.Web.Models.Scheduling.AppointmentStatus.NoShow => "th-pill-danger",
                    _ => "th-pill-muted"
                };
                <tr>
                    <td><strong>@a.ScheduledStartUtc.ToLocalTime().ToString("HH:mm")</strong><br /><small class="text-muted">@a.DurationMinutes min</small></td>
                    <td><strong>@a.Patient!.FullName</strong><br /><small class="font-monospace text-muted">@a.Patient.HospitalNumber</small></td>
                    <td><span class="th-pill" style="background:@a.Clinic!.ColorHex;color:#fff;">@a.Clinic.Code</span> @a.Clinic.Name</td>
                    <td>@(a.Clinician?.FullName ?? "—")</td>
                    <td>@a.Type</td>
                    <td>@a.Priority</td>
                    <td><span class="th-pill @statusTone">@a.Status</span></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open"></i></a>
                        @if (a.Status == ThriveHealth.Web.Models.Scheduling.AppointmentStatus.Scheduled)
                        {
                            <a asp-controller="Queue" asp-action="CheckIn" asp-route-appointmentId="@a.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.QueueCheckIn" class="btn btn-sm btn-success"><i class="bi bi-door-open"></i> Check in</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
</div></div>
