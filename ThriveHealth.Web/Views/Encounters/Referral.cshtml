@{
    ViewData["Title"] = "Referral letter";
    var enc = (ThriveHealth.Web.Models.Clinical.Encounter)ViewBag.Encounter;
    var ai = ViewBag.AiSuggestion as ThriveHealth.Web.Models.Ai.AiSuggestion;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title"><i class="bi bi-stars text-primary me-1"></i> Referral letter <span class="th-pill th-pill-info ms-2">DRAFT — clinician must verify</span></h1>
        <p class="th-section-sub mb-0"><strong>@enc.Patient!.FullName</strong> · @enc.Patient.HospitalNumber · encounter @enc.StartedAt.ToLocalTime().ToString("dd MMM HH:mm")</p>
    </div>
    <a asp-action="Edit" asp-route-id="@enc.Id" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to encounter</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="th-card mb-3"><div class="th-card-body">
    <form asp-action="DraftReferral" method="post" class="row g-3" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiReferralDraft">
        @Html.AntiForgeryToken()
        <input type="hidden" name="EncounterId" value="@enc.Id" />
        <div class="col-md-6">
            <label class="form-label">Receiving facility / specialist</label>
            <input name="ReceivingFacility" class="form-control" placeholder="e.g. LUTH Cardiology Clinic, Dr. A. Adesanya" required />
        </div>
        <div class="col-md-6">
            <label class="form-label">Reason for referral (one line)</label>
            <input name="Reason" class="form-control" placeholder="Specialist evaluation of refractory hypertension" />
        </div>
        <div class="col-12 text-end">
            <button class="btn btn-primary"><i class="bi bi-stars me-1"></i> @(ai == null ? "Draft letter" : "Re-draft letter")</button>
        </div>
    </form>
</div></div>

@if (ai != null)
{
    <div class="th-card">
        <div class="th-card-header d-flex justify-content-between align-items-center">
            <h5 class="th-card-title mb-0">Drafted letter</h5>
            <div class="small text-muted">@ai.CreatedAtUtc.ToLocalTime().ToString("dd MMM HH:mm") · @ai.Provider/@ai.Model · status <strong>@ai.Status</strong></div>
        </div>
        <div class="th-card-body">
            @if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Failed)
            {
                <div class="alert alert-warning mb-0"><strong>AI failed:</strong> @ai.ErrorMessage</div>
            }
            else
            {
                <pre class="mb-3" style="white-space:pre-wrap;font-family:inherit">@(ai.EditedContent ?? ai.Response)</pre>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-primary" onclick="window.print()"><i class="bi bi-printer me-1"></i> Print</button>
                    @if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Pending)
                    {
                        <form asp-action="ReviewReferralDraft" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiReferralDraft">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="suggestionId" value="@ai.Id" />
                            <button name="status" value="Accepted" class="btn btn-success"><i class="bi bi-check2-circle me-1"></i> Accept</button>
                            <button name="status" value="Rejected" class="btn btn-outline-danger"><i class="bi bi-x-circle me-1"></i> Reject</button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
}
