@model ThriveHealth.Web.Models.ViewModels.ConsultationViewModel
@{
    ViewData["Title"] = $"Consultation · {Model.Patient.FullName}";
    var p = Model.Patient;
    var enc = Model.Encounter;
    var hasSevere = Model.Allergies.Any(a => a.Severity >= ThriveHealth.Web.Models.Patients.AllergySeverity.Severe);
    var ai = ViewBag.AiSuggestion as ThriveHealth.Web.Models.Ai.AiSuggestion;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <div class="th-pill th-pill-success mb-2"><i class="bi bi-clipboard2-pulse"></i> Consultation in progress</div>
        <h1 class="th-section-title">@p.FullName <small class="text-muted">· @p.HospitalNumber</small></h1>
        <p class="th-section-sub mb-0">
            @p.Sex
            @if (p.AgeYears.HasValue) { <span> · @p.AgeYears y</span> }
            · Started @enc.StartedAt.ToLocalTime().ToString("dd MMM HH:mm")
            · @enc.Clinic?.Name
            · @enc.Clinician?.FullName
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Patients" asp-action="Profile" asp-route-id="@p.Id" class="btn btn-outline-secondary"><i class="bi bi-folder2-open me-1"></i> Open chart</a>
        <a asp-action="Referral" asp-route-id="@enc.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiReferralDraft" class="btn btn-outline-primary"><i class="bi bi-stars me-1"></i> Referral letter</a>
        <button type="button" class="btn btn-warning text-dark fw-semibold" data-bs-toggle="modal" data-bs-target="#admitModal" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AdmissionsManage"><i class="bi bi-hospital me-1"></i> Admit</button>
        <button type="button" class="btn btn-outline-primary" onclick="aiDocQuality(@enc.Id)" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiDocQuality"><i class="bi bi-stars me-1"></i> AI quality check</button>
        <form asp-action="SignOff" asp-route-id="@enc.Id" method="post" onsubmit="return confirm('Sign off this consultation? This locks the record.');" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
            @Html.AntiForgeryToken()
            <button class="btn btn-success" type="submit"><i class="bi bi-check2-circle me-1"></i> Sign off</button>
        </form>
    </div>
</div>

@if (Model.Allergies.Any())
{
    <div class="alert @(hasSevere ? "alert-danger" : "alert-warning") d-flex align-items-center gap-2 mb-3">
        <i class="bi bi-exclamation-octagon-fill"></i>
        <div><strong>Allergies:</strong>
            @foreach (var a in Model.Allergies)
            { <span class="me-2"><strong>@a.Substance</strong> <small>(@a.Severity)</small></span> }
        </div>
    </div>
}

<div class="th-card mb-3" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiDifferential">
    <div class="th-card-header d-flex justify-content-between align-items-center">
        <h5 class="th-card-title mb-0"><i class="bi bi-stars me-1 text-primary"></i> AI differential diagnosis <span class="th-pill th-pill-info ms-2">DRAFT — clinician must verify</span></h5>
        <form asp-action="SuggestDifferential" asp-route-id="@enc.Id" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiDifferential">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-clockwise me-1"></i> @(ai == null ? "Suggest" : "Re-suggest")</button>
        </form>
    </div>
    <div class="th-card-body">
        @if (ai == null)
        {
            <p class="text-muted small mb-0">Document chief complaint and HPI in SOAP, then click <em>Suggest</em> to get an AI-generated differential. Review and verify clinically — never act on AI output without independent judgement.</p>
        }
        else if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Failed)
        {
            <div class="alert alert-warning mb-0"><strong>AI failed:</strong> @ai.ErrorMessage</div>
        }
        else
        {
            <div class="small text-muted mb-2">
                Generated @ai.CreatedAtUtc.ToLocalTime().ToString("dd MMM HH:mm") · @ai.Provider/@ai.Model · status <strong>@ai.Status</strong>
            </div>
            <pre class="mb-2" style="white-space:pre-wrap;font-family:inherit">@(ai.EditedContent ?? ai.Response)</pre>
            @if (ai.Status == ThriveHealth.Web.Models.Ai.AiSuggestionStatus.Pending)
            {
                <form asp-action="ReviewDifferential" method="post" class="d-flex gap-2 flex-wrap" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiDifferential">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="suggestionId" value="@ai.Id" />
                    <button name="status" value="Accepted" class="btn btn-sm btn-success"><i class="bi bi-check2-circle me-1"></i> Accept</button>
                    <button name="status" value="Rejected" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle me-1"></i> Reject</button>
                </form>
            }
        }
    </div>
</div>

<div id="aiDocQualityCard" class="th-card mb-3" style="display:none">
    <div class="th-card-header"><h5 class="th-card-title mb-0"><i class="bi bi-stars me-1 text-primary"></i> AI documentation quality check <span class="th-pill th-pill-info ms-2">SUGGESTION — clinician decides</span></h5></div>
    <div class="th-card-body"><pre id="aiDocQualityOut" class="mb-0" style="white-space:pre-wrap;font-family:inherit"></pre></div>
</div>

<div class="th-card mb-3" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiEcgInterpret">
    <div class="th-card-header d-flex justify-content-between align-items-center">
        <h5 class="th-card-title mb-0"><i class="bi bi-activity me-1 text-primary"></i> AI ECG interpretation <span class="th-pill th-pill-info ms-2">DRAFT — clinician must verify</span></h5>
    </div>
    <div class="th-card-body">
        <textarea id="aiEcgFindings" class="form-control mb-2" rows="3" placeholder="e.g. HR 110 sinus rhythm, PR 200 ms, QRS 90 ms, ST elevation V2-V4, no Q waves..."></textarea>
        <button type="button" class="btn btn-sm btn-outline-primary" onclick="aiEcg(@enc.Id)"><i class="bi bi-arrow-clockwise me-1"></i> Interpret</button>
        <pre id="aiEcgOut" class="mt-2 mb-0 small text-muted" style="white-space:pre-wrap;font-family:inherit"></pre>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-8">
        @* VOICE → SOAP *@
        <div class="th-card mb-3" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiSoapStructure">
            <div class="th-card-header d-flex justify-content-between align-items-center">
                <h5 class="th-card-title mb-0"><i class="bi bi-mic me-1 text-primary"></i> Dictate &amp; structure (voice → SOAP) <span class="th-pill th-pill-info ms-2">DRAFT — clinician must verify</span></h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-danger" id="aiDictBtn" onclick="aiDictToggle()"><i class="bi bi-mic-fill me-1"></i> Start dictation</button>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="aiStructureSoap(@enc.Id)"><i class="bi bi-stars me-1"></i> Structure</button>
                </div>
            </div>
            <div class="th-card-body">
                <textarea id="aiNarrative" class="form-control mb-2" rows="3" placeholder="Click 'Start dictation' to use your microphone, or type/paste a stream-of-consciousness narrative here. The AI will structure it into SOAP."></textarea>
                <pre id="aiSoapOut" class="mb-0 small text-muted" style="white-space:pre-wrap;font-family:inherit"></pre>
            </div>
        </div>

        @* SOAP NOTE *@
        <div class="th-card mb-3">
            <div class="th-card-header d-flex align-items-center justify-content-between">
                <h5 class="th-card-title"><i class="bi bi-journal-text me-1 text-primary"></i> Clinical note (SOAP)</h5>
                <span id="soapStatus" class="th-pill th-pill-muted">idle</span>
            </div>
            <div class="th-card-body">
                <input type="hidden" id="encounterId" value="@enc.Id" />
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">S — Subjective</label>
                        <textarea id="soap-s" class="form-control soap-input" rows="3" placeholder="Chief complaint, history of presenting illness, ROS…">@enc.Soap?.Subjective</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">O — Objective</label>
                        <textarea id="soap-o" class="form-control soap-input" rows="3" placeholder="Vitals, examination findings, investigations available…">@enc.Soap?.Objective</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">A — Assessment</label>
                        <textarea id="soap-a" class="form-control soap-input" rows="2" placeholder="Clinical impression / differentials…">@enc.Soap?.Assessment</textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label">P — Plan</label>
                        <textarea id="soap-p" class="form-control soap-input" rows="3" placeholder="Investigations, treatment, follow-up…">@enc.Soap?.Plan</textarea>
                    </div>
                </div>
                <div class="small text-muted mt-2">
                    <i class="bi bi-info-circle"></i> Auto-saves every 20s. Type <code>.</code> followed by trigger for dotphrase expansion.
                </div>
            </div>
        </div>

        @* DIAGNOSES *@
        <div class="th-card mb-3">
            <div class="th-card-header">
                <h5 class="th-card-title"><i class="bi bi-list-ul me-1 text-primary"></i> Diagnoses (@enc.Diagnoses.Count)</h5>
                <button class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#dxAdd"><i class="bi bi-plus-lg me-1"></i> Add</button>
            </div>
            <div id="dxAdd" class="collapse">
                <div class="th-card-body border-bottom bg-light">
                    <form asp-action="AddDiagnosis" method="post" class="row g-2 align-items-end" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EncounterId" value="@enc.Id" />
                        <div class="col-md-7 position-relative">
                            <label class="form-label d-flex justify-content-between">
                                <span>Search ICD or describe (e.g. "fever", "body hot", "I10")</span>
                                <a href="#" onclick="aiIcdSuggest(@enc.Id);return false;" class="small text-decoration-none" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiIcdCoding"><i class="bi bi-stars"></i> AI ICD-10 suggest</a>
                            </label>
                            <input type="text" id="icdSearch" class="form-control" autocomplete="off" placeholder="malaria, hypertension…" />
                            <input type="hidden" name="IcdCode" id="icdCode" />
                            <input type="hidden" name="Description" id="icdDesc" />
                            <div id="icdResults" class="list-group position-absolute w-100" style="z-index:10;"></div>
                            <pre id="aiIcdOutput" class="small text-muted mt-1 mb-0" style="white-space:pre-wrap;font-family:inherit"></pre>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Status</label>
                            <select name="Status" class="form-select">
                                <option value="1">Working</option>
                                <option value="2">Confirmed</option>
                                <option value="3">Ruled out</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-center">
                            <div class="form-check ms-2 mt-3">
                                <input class="form-check-input" type="checkbox" name="IsPrimary" value="true" id="dxPrimary" />
                                <label class="form-check-label" for="dxPrimary">Primary</label>
                            </div>
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-primary w-100"><i class="bi bi-check"></i></button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="th-card-body p-0">
                @if (!enc.Diagnoses.Any())
                {
                    <div class="th-empty m-4"><i class="bi bi-list-ul"></i><h6 class="mt-2">No diagnoses yet</h6><p class="mb-0 small">At least one is required to sign off.</p></div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0 align-middle">
                            <thead><tr><th>Code</th><th>Diagnosis</th><th>Status</th><th></th><th class="text-end"></th></tr></thead>
                            <tbody>
                            @foreach (var d in enc.Diagnoses.OrderByDescending(x => x.IsPrimary))
                            {
                                <tr>
                                    <td><span class="font-monospace">@d.IcdCode</span></td>
                                    <td>@d.Description</td>
                                    <td><span class="th-pill @(d.Status == ThriveHealth.Web.Models.Clinical.DiagnosisStatus.Confirmed ? "th-pill-success" : d.Status == ThriveHealth.Web.Models.Clinical.DiagnosisStatus.RuledOut ? "th-pill-muted" : "th-pill-warning")">@d.Status</span></td>
                                    <td>@if (d.IsPrimary) { <span class="th-pill th-pill-info">Primary</span> }</td>
                                    <td class="text-end">
                                        <form asp-action="RemoveDiagnosis" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="diagnosisId" value="@d.Id" />
                                            <input type="hidden" name="encounterId" value="@enc.Id" />
                                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Remove this diagnosis?');"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @* ORDERS *@
        <div class="th-card mb-3">
            <div class="th-card-header">
                <h5 class="th-card-title"><i class="bi bi-clipboard-plus me-1 text-primary"></i> Orders</h5>
            </div>
            <div class="th-card-body">
                <ul class="nav nav-pills mb-3" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tab-rx">Prescription <span class="th-pill th-pill-muted ms-1">@enc.Prescriptions.SelectMany(r=>r.Items).Count()</span></button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-lab">Lab <span class="th-pill th-pill-muted ms-1">@enc.LabOrders.Count</span></button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-img">Imaging <span class="th-pill th-pill-muted ms-1">@enc.ImagingOrders.Count</span></button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tab-proc">Procedure <span class="th-pill th-pill-muted ms-1">@enc.ProcedureOrders.Count</span></button></li>
                </ul>
                <div class="tab-content">
                    @* PRESCRIPTION *@
                    <div class="tab-pane fade show active" id="tab-rx">
                        <div id="rxWarnings"></div>
                        <form asp-action="AddPrescription" method="post" id="rxForm" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="EncounterId" value="@enc.Id" />
                            <div id="rxItems">
                                <div class="rx-row mb-2 border rounded-3 p-2 bg-light position-relative">
                                    <div class="row g-2">
                                        <div class="col-md-5 position-relative">
                                            <input class="form-control rx-drug" name="Items[0].DrugName" placeholder="Search drug (generic or brand)…" autocomplete="off" />
                                            <input type="hidden" name="Items[0].DrugId" class="rx-drug-id" />
                                            <div class="rx-results list-group position-absolute w-100" style="z-index:50;"></div>
                                        </div>
                                        <div class="col-md-2"><input class="form-control" name="Items[0].Dose" placeholder="Dose" /></div>
                                        <div class="col-md-2"><input class="form-control" name="Items[0].Frequency" placeholder="Freq" /></div>
                                        <div class="col-md-2"><input class="form-control" name="Items[0].Duration" placeholder="Duration" /></div>
                                        <div class="col-md-1"><input class="form-control" name="Items[0].Route" placeholder="Route" /></div>
                                        <div class="col-md-2"><input class="form-control" name="Items[0].Quantity" type="number" placeholder="Qty (units)" /></div>
                                        <div class="col-md-10"><input class="form-control" name="Items[0].Instructions" placeholder="Instructions for patient…" /></div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="addRxRow"><i class="bi bi-plus-lg me-1"></i> Add drug</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-2" onclick="aiDrugCheck(@enc.Id)" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiDrugCheck"><i class="bi bi-stars me-1"></i> AI drug-check</button>
                            <input class="form-control mt-2" name="Notes" placeholder="Prescription notes (optional)" />
                            <div class="text-end mt-2">
                                <button class="btn btn-primary"><i class="bi bi-prescription2 me-1"></i> Issue prescription</button>
                            </div>
                        </form>
                        <pre id="aiDrugCheckOutput" class="small text-muted mt-2 mb-0" style="white-space:pre-wrap;font-family:inherit"></pre>
                        @if (enc.Prescriptions.Any())
                        {
                            <hr />
                            @foreach (var rx in enc.Prescriptions)
                            {
                                <div class="border rounded-3 p-3 mb-2">
                                    <div class="small text-muted mb-2">Issued @rx.IssuedAt.ToLocalTime().ToString("dd MMM HH:mm") · @rx.Status</div>
                                    @foreach (var i in rx.Items)
                                    {
                                        <div><strong>@i.DrugName</strong> <small class="text-muted">@i.Dose @i.Route @i.Frequency × @i.Duration</small></div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @* LAB *@
                    <div class="tab-pane fade" id="tab-lab">
                        <form asp-action="AddLabOrder" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="EncounterId" value="@enc.Id" />
                            <div class="row g-2">
                                <div class="col-md-5 position-relative">
                                    <input class="form-control lab-test-input" name="TestName" placeholder="Search lab test (FBC, MP, U&E, HBA1c)…" autocomplete="off" />
                                    <input type="hidden" name="LabTestId" id="labTestId" />
                                    <div id="labTestResults" class="list-group position-absolute w-100" style="z-index:50;"></div>
                                </div>
                                <div class="col-md-3"><input class="form-control" id="labSpecimen" name="Specimen" placeholder="Specimen" /></div>
                                <div class="col-md-2">
                                    <select name="Urgency" class="form-select">
                                        <option value="1">Routine</option><option value="2">Urgent</option><option value="3">STAT</option>
                                    </select>
                                </div>
                                <div class="col-md-2"><button class="btn btn-primary w-100">Order</button></div>
                                <div class="col-md-12"><input class="form-control" name="ClinicalIndication" placeholder="Clinical indication" /></div>
                            </div>
                        </form>
                        @if (enc.LabOrders.Any())
                        {
                            <hr />
                            <table class="table table-sm">
                                <thead><tr><th>Test</th><th>Specimen</th><th>Urgency</th><th>Status</th><th>Result</th><th class="text-end"></th></tr></thead>
                                <tbody>
                                @foreach (var l in enc.LabOrders)
                                {
                                    <tr>
                                        <td><strong>@l.TestName</strong>@if (!string.IsNullOrEmpty(l.AccessionNumber)) { <small class="font-monospace text-muted ms-1">@l.AccessionNumber</small> }</td>
                                        <td>@l.Specimen</td>
                                        <td>@l.Urgency</td>
                                        <td>@l.Status</td>
                                        <td><small class="text-muted">@l.OrderedAt.ToLocalTime().ToString("dd MMM HH:mm")</small></td>
                                        <td class="text-end"><a asp-controller="Lab" asp-action="View" asp-route-id="@l.Id" class="btn btn-sm btn-outline-primary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.LabRead"><i class="bi bi-eye"></i></a></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                    </div>

                    @* IMAGING *@
                    <div class="tab-pane fade" id="tab-img">
                        <form asp-action="AddImagingOrder" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="EncounterId" value="@enc.Id" />
                            <div class="row g-2">
                                <div class="col-md-2">
                                    <select name="Modality" class="form-select">
                                        <option value="1">X-Ray</option><option value="2">Ultrasound</option>
                                        <option value="3">CT</option><option value="4">MRI</option>
                                        <option value="5">Mammography</option><option value="6">Fluoroscopy</option>
                                    </select>
                                </div>
                                <div class="col-md-6"><input class="form-control" name="StudyDescription" placeholder="Study (Chest PA, Abdomen US, CT brain plain)" /></div>
                                <div class="col-md-2">
                                    <select name="Urgency" class="form-select">
                                        <option value="1">Routine</option><option value="2">Urgent</option><option value="3">STAT</option>
                                    </select>
                                </div>
                                <div class="col-md-2"><button class="btn btn-primary w-100">Order</button></div>
                                <div class="col-md-12"><input class="form-control" name="ClinicalIndication" placeholder="Clinical indication" /></div>
                            </div>
                        </form>
                        @if (enc.ImagingOrders.Any())
                        {
                            <hr />
                            <table class="table table-sm">
                                <thead><tr><th>Modality</th><th>Study</th><th>Urgency</th><th>Status</th><th>Ordered</th></tr></thead>
                                <tbody>
                                @foreach (var i in enc.ImagingOrders)
                                {
                                    <tr><td>@i.Modality</td><td><strong>@i.StudyDescription</strong></td><td>@i.Urgency</td><td>@i.Status</td><td><small class="text-muted">@i.OrderedAt.ToLocalTime().ToString("dd MMM HH:mm")</small></td></tr>
                                }
                                </tbody>
                            </table>
                        }
                    </div>

                    @* PROCEDURE *@
                    <div class="tab-pane fade" id="tab-proc">
                        <form asp-action="AddProcedureOrder" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="EncounterId" value="@enc.Id" />
                            <div class="row g-2">
                                <div class="col-md-7"><input class="form-control" name="ProcedureName" placeholder="Procedure (Suturing, I&D, biopsy)" /></div>
                                <div class="col-md-2"><input class="form-control" name="CptCode" placeholder="CPT" /></div>
                                <div class="col-md-2">
                                    <select name="Urgency" class="form-select">
                                        <option value="1">Routine</option><option value="2">Urgent</option><option value="3">STAT</option>
                                    </select>
                                </div>
                                <div class="col-md-1"><button class="btn btn-primary w-100">Order</button></div>
                                <div class="col-12"><input class="form-control" name="Notes" placeholder="Notes" /></div>
                            </div>
                        </form>
                        @if (enc.ProcedureOrders.Any())
                        {
                            <hr />
                            <table class="table table-sm">
                                <thead><tr><th>Procedure</th><th>CPT</th><th>Urgency</th><th>Status</th></tr></thead>
                                <tbody>
                                @foreach (var p2 in enc.ProcedureOrders)
                                { <tr><td><strong>@p2.ProcedureName</strong></td><td>@p2.CptCode</td><td>@p2.Urgency</td><td>@p2.Status</td></tr> }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* RIGHT RAIL: PATIENT CONTEXT *@
    <div class="col-xl-4">
        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase small text-muted"><i class="bi bi-heart-pulse me-1"></i> Latest vitals</h6>
            @if (Model.LatestVitals is null) { <div class="text-muted">No vitals recorded.</div> }
            else
            {
                var v = Model.LatestVitals;
                <div class="row small">
                    <div class="col-6 text-muted">BP</div><div class="col-6 fw-bold">@(v.SystolicBp.HasValue ? $"{v.SystolicBp}/{v.DiastolicBp}" : "—")</div>
                    <div class="col-6 text-muted">HR</div><div class="col-6 fw-bold">@(v.HeartRate?.ToString() ?? "—") bpm</div>
                    <div class="col-6 text-muted">RR</div><div class="col-6 fw-bold">@(v.RespiratoryRate?.ToString() ?? "—") /min</div>
                    <div class="col-6 text-muted">Temp</div><div class="col-6 fw-bold">@(v.TemperatureCelsius?.ToString("F1") ?? "—") °C</div>
                    <div class="col-6 text-muted">SpO₂</div><div class="col-6 fw-bold">@(v.SpO2?.ToString() ?? "—") %</div>
                    @if (v.Mews.HasValue) {
                        var t = v.Mews <= 1 ? "th-pill-success" : v.Mews <= 3 ? "th-pill-warning" : "th-pill-danger";
                        <div class="col-6 text-muted">MEWS</div><div class="col-6"><span class="th-pill @t">@v.Mews</span></div>
                    }
                </div>
                <div class="small text-muted mt-2">@v.RecordedAt.ToLocalTime().ToString("dd MMM HH:mm")</div>
            }
            <a asp-controller="Emr" asp-action="AddVitals" asp-route-patientId="@p.Id" class="btn btn-sm btn-outline-primary mt-2 w-100" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.EncountersWrite"><i class="bi bi-plus-lg me-1"></i> Record vitals</a>
        </div></div>

        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase small text-muted"><i class="bi bi-list-ul me-1"></i> Active problems</h6>
            @if (!Model.ActiveProblems.Any()) { <div class="text-muted">None.</div> }
            else { foreach (var x in Model.ActiveProblems) {
                <div><span class="font-monospace small">@x.IcdCode</span> @x.Description <span class="th-pill th-pill-muted">@x.Status</span></div>
            } }
        </div></div>

        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase small text-muted"><i class="bi bi-capsule me-1"></i> Current medications</h6>
            @if (!Model.CurrentMedications.Any()) { <div class="text-muted">None.</div> }
            else { foreach (var m in Model.CurrentMedications) {
                <div><strong>@m.DrugName</strong> <small class="text-muted">@m.Dose @m.Frequency</small></div>
            } }
        </div></div>

        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase small text-muted"><i class="bi bi-clock-history me-1"></i> Past consultations</h6>
            @if (!Model.PastEncounters.Any()) { <div class="text-muted">None.</div> }
            else { foreach (var e in Model.PastEncounters) {
                <div class="border-bottom pb-2 mb-2 small">
                    <div class="fw-semibold">@e.StartedAt.ToLocalTime().ToString("dd MMM yyyy") · @e.Type</div>
                    <div class="text-muted">@(e.Clinician?.FullName ?? "—") · @e.Clinic?.Name</div>
                    @foreach (var d in e.Diagnoses.Take(2))
                    { <div><span class="font-monospace">@d.IcdCode</span> @d.Description</div> }
                </div>
            } }
        </div></div>
    </div>
</div>

@section Scripts {
<script>
async function aiIcdSuggest(encounterId) {
    var out = document.getElementById('aiIcdOutput');
    var text = document.getElementById('icdSearch')?.value?.trim() || document.getElementById('icdDesc')?.value?.trim();
    if (!text) { out.textContent = 'Type a diagnosis description first.'; return; }
    out.textContent = 'Thinking…';
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        var r = await fetch('/Consultations/IcdSuggest', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify({ encounterId: encounterId, diagnosisText: text }) });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
var aiDictRec = null;
function aiDictToggle() {
    var btn = document.getElementById('aiDictBtn');
    if (aiDictRec) { aiDictRec.stop(); aiDictRec = null; btn.innerHTML = '<i class="bi bi-mic-fill me-1"></i> Start dictation'; btn.classList.remove('btn-danger'); btn.classList.add('btn-outline-danger'); return; }
    var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { alert('Speech recognition not available in this browser. Type or paste the narrative instead.'); return; }
    var rec = new SR(); rec.continuous = true; rec.interimResults = true; rec.lang = 'en-NG';
    var ta = document.getElementById('aiNarrative');
    var baseText = ta.value;
    rec.onresult = function (e) {
        var interim = ''; var final = '';
        for (var i = e.resultIndex; i < e.results.length; i++) {
            var t = e.results[i][0].transcript;
            if (e.results[i].isFinal) final += t + ' '; else interim += t;
        }
        ta.value = (baseText ? baseText + ' ' : '') + final + (interim ? ' [' + interim + ']' : '');
        if (final) baseText = ta.value.replace(/ \[.*\]$/, '');
    };
    rec.onerror = function () { aiDictToggle(); };
    rec.onend = function () { if (aiDictRec === rec) aiDictRec = null; btn.innerHTML = '<i class="bi bi-mic-fill me-1"></i> Start dictation'; btn.classList.remove('btn-danger'); btn.classList.add('btn-outline-danger'); };
    rec.start(); aiDictRec = rec;
    btn.innerHTML = '<i class="bi bi-stop-fill me-1"></i> Stop dictation';
    btn.classList.add('btn-danger'); btn.classList.remove('btn-outline-danger');
}
async function aiStructureSoap(encounterId) {
    var out = document.getElementById('aiSoapOut');
    var n = document.getElementById('aiNarrative').value.trim();
    if (!n) { out.textContent = 'Dictate or type a narrative first.'; return; }
    out.textContent = 'Structuring…';
    try {
        var r = await fetch('/Consultations/SoapStructure', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ encounterId: encounterId, narrative: n }) });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
async function aiDocQuality(encounterId) {
    var card = document.getElementById('aiDocQualityCard');
    var out = document.getElementById('aiDocQualityOut');
    card.style.display = 'block';
    out.textContent = 'Reviewing…';
    try {
        var r = await fetch('/Consultations/DocQuality?id=' + encounterId, { method: 'POST' });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
async function aiEcg(encounterId) {
    var out = document.getElementById('aiEcgOut');
    var f = document.getElementById('aiEcgFindings').value.trim();
    if (!f) { out.textContent = 'Enter ECG findings first.'; return; }
    out.textContent = 'Interpreting…';
    try {
        var r = await fetch('/Consultations/EcgInterpret', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ encounterId: encounterId, findings: f }) });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
async function aiDrugCheck(encounterId) {
    var out = document.getElementById('aiDrugCheckOutput');
    var proposed = Array.from(document.querySelectorAll('input.rx-drug')).map(i => i.value.trim()).filter(Boolean);
    if (proposed.length === 0) { out.textContent = 'Add at least one drug to the prescription first.'; return; }
    out.textContent = 'Checking…';
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    try {
        var r = await fetch('/Consultations/DrugCheck', { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify({ encounterId: encounterId, proposed: proposed, existing: [] }) });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
</script>
<script>
// SOAP autosave
const $status = document.getElementById('soapStatus');
const inputs = document.querySelectorAll('.soap-input');
const encId = parseInt(document.getElementById('encounterId').value, 10);
let dirty = false;
inputs.forEach(i => i.addEventListener('input', () => { dirty = true; $status.textContent = 'unsaved…'; $status.className = 'th-pill th-pill-warning'; }));
async function autoSave(){
    if (!dirty) return;
    const body = { encounterId: encId,
        subjective: document.getElementById('soap-s').value,
        objective: document.getElementById('soap-o').value,
        assessment: document.getElementById('soap-a').value,
        plan: document.getElementById('soap-p').value };
    try {
        const r = await fetch('/Consultations/SaveSoap', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
        if (r.ok) { dirty = false; $status.textContent = 'saved ' + new Date().toLocaleTimeString(); $status.className = 'th-pill th-pill-success'; }
        else { $status.textContent = 'save failed'; $status.className = 'th-pill th-pill-danger'; }
    } catch(e) { $status.textContent = 'offline'; $status.className = 'th-pill th-pill-danger'; }
}
setInterval(autoSave, 20000);
window.addEventListener('beforeunload', () => { if (dirty) autoSave(); });

// ICD search
const $icd = document.getElementById('icdSearch');
const $icdRes = document.getElementById('icdResults');
const $icdCode = document.getElementById('icdCode');
const $icdDesc = document.getElementById('icdDesc');
let icdTimer;
$icd.addEventListener('input', () => {
    clearTimeout(icdTimer);
    const q = $icd.value.trim();
    icdTimer = setTimeout(async () => {
        const r = await fetch('/Icd/Search?q=' + encodeURIComponent(q));
        const items = await r.json();
        $icdRes.innerHTML = items.map(h =>
            `<a href="#" class="list-group-item list-group-item-action small" data-code="${h.code}" data-desc="${h.description.replace(/"/g,'&quot;')}">
                <strong class="font-monospace">${h.code}</strong> ${h.description}${h.category ? `<small class="text-muted ms-1">· ${h.category}</small>` : ''}
            </a>`).join('');
        $icdRes.querySelectorAll('a').forEach(el => el.addEventListener('click', e => {
            e.preventDefault();
            $icdCode.value = el.dataset.code;
            $icdDesc.value = el.dataset.desc;
            $icd.value = `${el.dataset.code} — ${el.dataset.desc}`;
            $icdRes.innerHTML = '';
        }));
    }, 200);
});

// Prescription rows + drug autocomplete + interaction check
const currentMeds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentMedications.Select(m => m.DrugName)));
let rxIndex = 1;

function rowTemplate(idx) {
    return `<div class="rx-row mb-2 border rounded-3 p-2 bg-light position-relative">
        <div class="row g-2">
            <div class="col-md-5 position-relative">
                <input class="form-control rx-drug" name="Items[${idx}].DrugName" placeholder="Search drug…" autocomplete="off" />
                <input type="hidden" name="Items[${idx}].DrugId" class="rx-drug-id" />
                <div class="rx-results list-group position-absolute w-100" style="z-index:50;"></div>
            </div>
            <div class="col-md-2"><input class="form-control" name="Items[${idx}].Dose" placeholder="Dose" /></div>
            <div class="col-md-2"><input class="form-control" name="Items[${idx}].Frequency" placeholder="Freq" /></div>
            <div class="col-md-2"><input class="form-control" name="Items[${idx}].Duration" placeholder="Duration" /></div>
            <div class="col-md-1"><input class="form-control" name="Items[${idx}].Route" placeholder="Route" /></div>
            <div class="col-md-2"><input class="form-control" name="Items[${idx}].Quantity" type="number" placeholder="Qty" /></div>
            <div class="col-md-10"><input class="form-control" name="Items[${idx}].Instructions" placeholder="Instructions" /></div>
        </div>
    </div>`;
}

document.getElementById('addRxRow').addEventListener('click', () => {
    const wrap = document.getElementById('rxItems');
    const div = document.createElement('div');
    div.innerHTML = rowTemplate(rxIndex);
    wrap.appendChild(div.firstElementChild);
    rxIndex++;
    bindDrugRows();
});

function bindDrugRows() {
    document.querySelectorAll('.rx-drug').forEach(input => {
        if (input.dataset.bound) return;
        input.dataset.bound = '1';
        let t;
        input.addEventListener('input', () => {
            clearTimeout(t);
            const q = input.value.trim();
            const results = input.parentElement.querySelector('.rx-results');
            if (q.length < 2) { results.innerHTML = ''; checkRx(); return; }
            t = setTimeout(async () => {
                const r = await fetch('/Drugs/Search?q=' + encodeURIComponent(q));
                const items = await r.json();
                results.innerHTML = items.map(d =>
                    `<a href="#" class="list-group-item list-group-item-action small" data-id="${d.id}" data-name="${(d.brand ? d.brand + ' (' + d.generic + ')' : d.generic) + ' ' + d.strength}" data-schedule="${d.schedule}">
                        <strong>${d.generic}</strong> ${d.brand ? '<span class="text-muted">(' + d.brand + ')</span>' : ''} ${d.strength} <span class="text-muted">· ${d.form}</span>${d.nafdac ? '<small class="text-muted ms-1 font-monospace">NAFDAC ' + d.nafdac + '</small>' : ''}${d.schedule >= 3 ? '<span class="th-pill th-pill-danger ms-1">Controlled</span>' : ''}
                    </a>`).join('');
                results.querySelectorAll('a').forEach(el => el.addEventListener('click', e => {
                    e.preventDefault();
                    input.value = el.dataset.name;
                    input.parentElement.querySelector('.rx-drug-id').value = el.dataset.id;
                    results.innerHTML = '';
                    checkRx();
                }));
            }, 200);
        });
        input.addEventListener('change', checkRx);
    });
}
bindDrugRows();

let warnTimer;
function checkRx() {
    clearTimeout(warnTimer);
    warnTimer = setTimeout(async () => {
        const proposed = Array.from(document.querySelectorAll('.rx-drug')).map(i => i.value).filter(Boolean);
        if (proposed.length === 0) { document.getElementById('rxWarnings').innerHTML = ''; return; }
        const res = await fetch('/Drugs/CheckInteractions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ proposed: proposed, existing: currentMeds })
        });
        if (!res.ok) return;
        const warnings = await res.json();
        const $w = document.getElementById('rxWarnings');
        if (warnings.length === 0) { $w.innerHTML = ''; return; }
        const hasSevere = warnings.some(w => w.severity >= 3);
        $w.innerHTML = `<div class="alert ${hasSevere ? 'alert-danger' : 'alert-warning'} mb-2">
            <strong><i class="bi bi-shield-exclamation me-1"></i> Drug interactions</strong>
            <ul class="mb-0 mt-1 small">${warnings.map(w => `<li><strong>${w.drugA} × ${w.drugB}</strong> · ${['','Minor','Moderate','Severe','Contraindicated'][w.severity]} — ${w.note}</li>`).join('')}</ul>
        </div>`;
    }, 300);
}

// Dotphrase expansion in SOAP fields
const dots = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DotPhrases.Select(d => new { trigger = d.Trigger, expansion = d.Expansion })));
inputs.forEach(area => {
    area.addEventListener('keyup', e => {
        if (e.key !== ' ' && e.key !== 'Enter' && e.key !== 'Tab') return;
        const v = area.value;
        for (const d of dots) {
            const tok = '.' + d.trigger;
            const idx = v.lastIndexOf(tok + (e.key === ' ' ? ' ' : ''));
            if (idx >= 0) {
                area.value = v.substring(0, idx) + d.expansion + v.substring(idx + tok.length + 1);
                dirty = true; $status.textContent = 'unsaved…'; $status.className = 'th-pill th-pill-warning';
                return;
            }
        }
    });
});

// Lab test autocomplete
const $labIn = document.querySelector('.lab-test-input');
const $labRes = document.getElementById('labTestResults');
const $labId = document.getElementById('labTestId');
const $labSpecimen = document.getElementById('labSpecimen');
if ($labIn) {
    let lt;
    $labIn.addEventListener('input', () => {
        clearTimeout(lt);
        const q = $labIn.value.trim();
        $labId.value = '';
        if (q.length < 2) { $labRes.innerHTML = ''; return; }
        lt = setTimeout(async () => {
            const r = await fetch('/Consultations/SearchLabTests?q=' + encodeURIComponent(q));
            const items = await r.json();
            $labRes.innerHTML = items.map(t =>
                `<a href="#" class="list-group-item list-group-item-action small" data-id="${t.id}" data-name="${t.name}" data-specimen="${t.specimen ?? ''}">
                    <strong>${t.name}</strong> <small class="text-muted">· ${t.code} · ${t.section}</small>${t.specimen ? `<br><small class="text-muted">${t.specimen}</small>` : ''}
                </a>`).join('');
            $labRes.querySelectorAll('a').forEach(el => el.addEventListener('click', e => {
                e.preventDefault();
                $labIn.value = el.dataset.name;
                $labId.value = el.dataset.id;
                if ($labSpecimen) $labSpecimen.value = el.dataset.specimen || '';
                $labRes.innerHTML = '';
            }));
        }, 200);
    });
}

// --------- Admit modal: cascade Bed dropdown to the selected Ward ----------
(function () {
    const wardSelect = document.getElementById('admitWardSelect');
    const bedSelect = document.getElementById('admitBedSelect');
    if (!wardSelect || !bedSelect) return;
    const allBeds = JSON.parse(document.getElementById('admitBedsData').textContent || '[]');
    function refillBeds() {
        const wid = parseInt(wardSelect.value || '0', 10);
        bedSelect.innerHTML = '<option value="">— pick a bed —</option>';
        allBeds.filter(b => b.wardId === wid).forEach(b => {
            const o = document.createElement('option');
            o.value = b.id; o.textContent = b.label;
            bedSelect.appendChild(o);
        });
    }
    wardSelect.addEventListener('change', refillBeds);
})();
</script>
}

@* ====================== Admit modal ====================== *@
@{
    var admitWards   = (System.Collections.IEnumerable?)ViewBag.AdmitWards ?? Array.Empty<object>();
    var admitBeds    = ViewBag.AdmitFreeBeds ?? new object[0];
    var admitDoctors = (System.Collections.IEnumerable?)ViewBag.AdmitDoctors ?? Array.Empty<object>();
}
<div class="modal fade" id="admitModal" tabindex="-1" aria-labelledby="admitModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form asp-controller="Admissions" asp-action="Admit" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AdmissionsManage">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PatientId" value="@p.Id" />
                <input type="hidden" name="SourceEncounterId" value="@enc.Id" />

                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title fw-bold" id="admitModalLabel"><i class="bi bi-hospital me-2"></i>Admit @p.FullName</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">From this consultation · @p.HospitalNumber</p>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small">Ward</label>
                            <select id="admitWardSelect" name="WardId" class="form-select" required>
                                <option value="">— select ward —</option>
                                @foreach (dynamic w in admitWards) { <option value="@w.Id">@w.Name</option> }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Bed</label>
                            <select id="admitBedSelect" name="BedId" class="form-select" required>
                                <option value="">— pick a ward first —</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small">Admitting doctor</label>
                            <select name="AdmittingDoctorId" class="form-select" required>
                                <option value="">— select doctor —</option>
                                @foreach (dynamic d in admitDoctors) { <option value="@d.Id">@d.Label</option> }
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small">Reason for admission</label>
                            <textarea name="ReasonForAdmission" class="form-control" rows="2" required placeholder="e.g. Severe malaria for IV therapy and monitoring."></textarea>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label small">Working diagnosis (optional)</label>
                            <input name="WorkingDiagnosis" class="form-control" placeholder="e.g. Falciparum malaria" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning text-dark fw-semibold"><i class="bi bi-hospital me-1"></i> Admit patient</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* JSON bag for cascading the bed dropdown. *@
<script id="admitBedsData" type="application/json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(admitBeds))</script>
