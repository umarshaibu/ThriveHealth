@model ThriveHealth.Web.Models.ViewModels.GrnReceiveViewModel
@{
    ViewData["Title"] = "Receive goods";
    var po = ViewBag.PurchaseOrder as ThriveHealth.Web.Models.Inventory.PurchaseOrder;
    var stores = ViewBag.Stores as List<ThriveHealth.Web.Models.Pharmacy.PharmacyStore>;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title"><i class="bi bi-truck text-primary me-1"></i> Receive goods (GRN)</h1>
        @if (po != null) { <p class="th-section-sub mb-0">PO <strong class="font-monospace">@po.PoNumber</strong> · @po.Supplier?.Name</p> }
    </div>
    <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-secondary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage"><i class="bi bi-arrow-left me-1"></i> Back to PO</a>
</div>

<form asp-action="Receive" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.GrnReceive">
    <input type="hidden" asp-for="PurchaseOrderId" />

    <div class="th-card mb-3"><div class="th-card-body">
        <div class="row g-3">
            <div class="col-md-3"><label asp-for="StoreId" class="form-label">Receiving store</label>
                <select asp-for="StoreId" class="form-select">
                    @foreach (var s in stores ?? new()) { <option value="@s.Id" selected="@(Model.StoreId == s.Id)">@s.Code · @s.Name</option> }
                </select>
            </div>
            <div class="col-md-3"><label asp-for="SupplierInvoiceNumber" class="form-label">Supplier invoice #</label><input asp-for="SupplierInvoiceNumber" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="DeliveryNoteNumber" class="form-label">Delivery note #</label><input asp-for="DeliveryNoteNumber" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Notes" class="form-label">Notes</label><input asp-for="Notes" class="form-control" /></div>
        </div>
    </div></div>

    <div class="th-card mb-3">
        <div class="th-card-header"><h5 class="th-card-title"><i class="bi bi-list-ul me-1 text-primary"></i> Lines (@Model.Lines.Count)</h5></div>
        <div class="th-card-body p-0">
            <table class="table align-middle mb-0">
                <thead><tr><th>Description</th><th class="text-end">Ordered</th><th class="text-end">Already</th><th class="text-end">Outstanding</th><th>Receiving qty</th><th>Batch #</th><th>Expiry</th><th>Unit cost ₦</th></tr></thead>
                <tbody>
                @for (int idx = 0; idx < Model.Lines.Count; idx++)
                {
                    var l = Model.Lines[idx];
                    <tr>
                        <td>
                            <input type="hidden" name="Lines[@idx].PurchaseOrderItemId" value="@l.PurchaseOrderItemId" />
                            <strong>@l.Description</strong>
                        </td>
                        <td class="text-end">@l.QuantityOrdered</td>
                        <td class="text-end">@l.QuantityAlreadyReceived</td>
                        <td class="text-end"><strong>@l.Outstanding</strong></td>
                        <td><input class="form-control form-control-sm" type="number" min="0" max="@l.Outstanding" name="Lines[@idx].Quantity" value="@l.Quantity" /></td>
                        <td><input class="form-control form-control-sm" name="Lines[@idx].BatchNumber" value="@l.BatchNumber" placeholder="Batch" /></td>
                        <td><input class="form-control form-control-sm" name="Lines[@idx].ExpiryDate" type="date" value="@l.ExpiryDate?.ToString("yyyy-MM-dd")" /></td>
                        <td><input class="form-control form-control-sm" type="number" step="0.01" name="Lines[@idx].UnitCost" value="@l.UnitCost" /></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="alert alert-info small">
        <i class="bi bi-info-circle me-1"></i>
        Receiving posts immediately: drug stock + StockMovement (Receive), or InventoryStock + InventoryStockMovement (Receive). PO status auto-rolls (Issued → PartiallyReceived → Received). All movements are audited.
    </div>

    <div class="d-flex justify-content-end gap-2">
        <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-secondary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage">Cancel</a>
        <button class="btn btn-primary"><i class="bi bi-check2-circle me-1"></i> Post GRN to stock</button>
    </div>
</form>
