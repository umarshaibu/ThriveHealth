@model ThriveHealth.Web.Models.Inventory.Grn
@{ ViewData["Title"] = $"GRN {Model.GrnNumber}"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="th-pill th-pill-success">@Model.Status</span>
        <h1 class="th-section-title mt-2">@Model.GrnNumber</h1>
        <p class="th-section-sub mb-0">
            PO <strong class="font-monospace">@Model.PurchaseOrder?.PoNumber</strong> · @Model.PurchaseOrder?.Supplier?.Name
            · Received @Model.ReceivedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") by @Model.ReceivedBy?.FullName
            · Store @Model.Store?.Code
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> All GRNs</a>
        <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@Model.PurchaseOrderId" class="btn btn-outline-secondary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage"><i class="bi bi-cart me-1"></i> Open PO</a>
        <button onclick="window.print()" class="btn btn-primary"><i class="bi bi-printer me-1"></i> Print</button>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small">Delivery details</h6>
            <div class="row small">
                <div class="col-5 text-muted">Supplier invoice</div><div class="col-7 fw-semibold">@(Model.SupplierInvoiceNumber ?? "—")</div>
                <div class="col-5 text-muted">Delivery note</div><div class="col-7 fw-semibold">@(Model.DeliveryNoteNumber ?? "—")</div>
                <div class="col-5 text-muted">Posted</div><div class="col-7 fw-semibold">@Model.PostedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                <div class="col-5 text-muted">Posted by</div><div class="col-7 fw-semibold">@Model.PostedBy?.FullName</div>
            </div>
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="th-card"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small">Total received</h6>
            <h2 class="fw-bold">₦@Model.TotalReceivedValue.ToString("N2")</h2>
            <small class="text-muted">@Model.Items.Count line@(Model.Items.Count == 1 ? "" : "s")</small>
            @if (!string.IsNullOrEmpty(Model.Notes)) { <div class="mt-2 small"><strong>Notes:</strong> @Model.Notes</div> }
        </div></div>
    </div>
</div>

<div class="th-card">
    <div class="th-card-header"><h5 class="th-card-title">Lines received</h5></div>
    <div class="th-card-body p-0">
        <table class="table align-middle mb-0">
            <thead><tr><th>Type</th><th>Description</th><th>Batch</th><th>Expiry</th><th class="text-end">Qty</th><th class="text-end">Unit ₦</th><th class="text-end">Line ₦</th></tr></thead>
            <tbody>
            @foreach (var i in Model.Items)
            {
                var poItem = i.PurchaseOrderItem;
                var kind = poItem?.DrugId.HasValue == true ? "Drug" : (poItem?.InventoryItemId.HasValue == true ? "Item" : "Other");
                <tr>
                    <td><span class="th-pill @(kind == "Drug" ? "th-pill-warning" : kind == "Item" ? "th-pill-info" : "th-pill-muted")">@kind</span></td>
                    <td><strong>@poItem?.Description</strong></td>
                    <td><span class="font-monospace small">@i.BatchNumber</span></td>
                    <td>@i.ExpiryDate?.ToString("MMM yyyy")</td>
                    <td class="text-end">@i.QuantityReceived</td>
                    <td class="text-end">@i.UnitCost.ToString("N2")</td>
                    <td class="text-end">@i.LineTotal.ToString("N2")</td>
                </tr>
            }
            </tbody>
            <tfoot class="table-light"><tr><th colspan="6" class="text-end">Total</th><th class="text-end">@Model.TotalReceivedValue.ToString("N2")</th></tr></tfoot>
        </table>
    </div>
</div>
