@model IEnumerable<ThriveHealth.Web.Models.Scheduling.Clinic>
@{ ViewData["Title"] = "Queues"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Live queues</h1>
        <p class="th-section-sub mb-0">Pick a clinic to view and manage its waiting queue.</p>
    </div>
    <a asp-action="CheckIn" class="btn btn-primary"><i class="bi bi-door-open me-1"></i> Check in walk-in</a>
</div>

<div class="row g-3">
    @foreach (var c in Model)
    {
        <div class="col-md-6 col-lg-4">
            <a asp-action="Board" asp-route-clinicId="@c.Id" class="text-decoration-none">
                <div class="th-card h-100"><div class="th-card-body">
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="th-pill" style="background:@c.ColorHex;color:#fff;">@c.Code</span>
                        <i class="bi bi-arrow-right text-muted"></i>
                    </div>
                    <h5 class="mt-3 mb-1">@c.Name</h5>
                    <small class="text-muted">@c.Specialty · @c.DefaultSlotMinutes-min slots</small>
                </div></div>
            </a>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12"><div class="th-empty"><i class="bi bi-building"></i><h5 class="mt-2">No clinics yet</h5></div></div>
    }
</div>
