@model ThriveHealth.Web.Models.ViewModels.QueueBoardViewModel
@{
    ViewData["Title"] = $"Display · {Model.Clinic.Name}";
    Layout = null;
    var inConsult = Model.Entries.FirstOrDefault(e => e.Status == ThriveHealth.Web.Models.Scheduling.QueueStatus.InConsultation
                                                  || e.Status == ThriveHealth.Web.Models.Scheduling.QueueStatus.Called);
    var waiting = Model.Entries.Where(e => e.Status == ThriveHealth.Web.Models.Scheduling.QueueStatus.Waiting
                                       || e.Status == ThriveHealth.Web.Models.Scheduling.QueueStatus.Triaged).ToList();
    var facilityId = (int)(ViewBag.FacilityId ?? 0);
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>@Model.Clinic.Name Queue</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800;900&display=swap" rel="stylesheet" />
<style>
:root { --th-primary:@Model.Clinic.ColorHex; }
body { background:#0b2447; color:#fff; font-family:'Inter',sans-serif; min-height:100vh; margin:0; padding:24px; }
.brand { font-weight:800; letter-spacing:.5px; }
.now-card { background:linear-gradient(135deg,var(--th-primary),#0b2447); border-radius:24px; padding:36px; min-height:280px; box-shadow:0 30px 80px rgba(0,0,0,.4); }
.now-name { font-size:4.2rem; font-weight:900; line-height:1.05; letter-spacing:-.01em; }
.now-ticket { font-size:1.6rem; font-weight:700; color:rgba(255,255,255,.65); letter-spacing:.04em; }
.queue-item { background:rgba(255,255,255,.06); border-radius:14px; padding:20px; }
.queue-item .name { font-size:1.9rem; font-weight:800; line-height:1.1; }
.queue-item .ticket { font-size:1rem; font-weight:600; color:rgba(255,255,255,.6); letter-spacing:.04em; }
.priority-emergency { background:rgba(200,30,30,.4)!important; }
.priority-urgent { background:rgba(180,106,0,.4)!important; }
</style>
</head>
<body>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="brand fs-2"><i class="bi bi-heart-pulse-fill" style="color:var(--th-primary)"></i> @Model.Clinic.Name</div>
        <div class="text-white-50">Live waiting board</div>
    </div>
    <div class="text-end"><div class="fs-1 fw-bold" id="clock">--:--</div><div class="text-white-50" id="dateLabel">@DateTime.Now.ToString("dddd, dd MMM yyyy")</div></div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="text-uppercase small text-white-50 mb-2">Now serving</div>
        <div class="now-card">
            @if (inConsult is null)
            {
                <div class="text-white-50 fs-2">No one being served</div>
            }
            else
            {
                <div class="now-name">@(inConsult.Patient?.FullName ?? "—")</div>
                <div class="now-ticket mt-3">Ticket @inConsult.TicketNumber</div>
                <div class="text-white-50">@(inConsult.Status == ThriveHealth.Web.Models.Scheduling.QueueStatus.Called ? "Please come in" : "In consultation")</div>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="text-uppercase small text-white-50 mb-2">Up next (@waiting.Count)</div>
        <div class="d-flex flex-column gap-2">
            @foreach (var e in waiting.Take(6))
            {
                var prio = e.Priority == ThriveHealth.Web.Models.Scheduling.AppointmentPriority.Emergency ? "priority-emergency"
                         : e.Priority == ThriveHealth.Web.Models.Scheduling.AppointmentPriority.Urgent ? "priority-urgent" : "";
                <div class="queue-item @prio d-flex justify-content-between align-items-center">
                    <div>
                        <div class="name">@(e.Patient?.FirstName ?? "—") @(string.IsNullOrEmpty(e.Patient?.LastName) ? "" : e.Patient!.LastName!.Substring(0,1) + ".")</div>
                        <div class="ticket">Ticket @e.TicketNumber</div>
                    </div>
                    <div class="text-end">
                        <div class="small text-white-50">@e.Priority</div>
                    </div>
                </div>
            }
            @if (!waiting.Any())
            {
                <div class="queue-item text-white-50">No one waiting</div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
<script>
function tick(){const d=new Date();document.getElementById('clock').textContent=String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0');}
tick();setInterval(tick,1000);
const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/queue').withAutomaticReconnect().build();
conn.on('queueUpdated', () => window.location.reload());
conn.start().then(() => conn.invoke('SubscribeQueue', @facilityId, @Model.Clinic.Id)).catch(console.error);
setInterval(() => window.location.reload(), 60000);
</script>
</body>
</html>
