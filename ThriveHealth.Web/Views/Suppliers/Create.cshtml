@model ThriveHealth.Web.Models.ViewModels.SupplierEditViewModel
@{ ViewData["Title"] = "New supplier"; }

<div class="row"><div class="col-lg-8">
    <h1 class="th-section-title">Add supplier</h1>
    <form asp-action="Create" method="post" class="th-card" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PurchaseOrderManage">
        <div class="th-card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            @await Html.PartialAsync("_SupplierFields", Model)
            <div class="mt-3 d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button class="btn btn-primary"><i class="bi bi-check2-circle me-1"></i> Create supplier</button>
            </div>
        </div>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
