@model IEnumerable<ThriveHealth.Web.Models.Insurance.Payer>
@{ ViewData["Title"] = "Payers"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Payers &amp; insurance</h1>
        <p class="th-section-sub mb-0">@Model.Count() payers configured. NHIA, HMOs, state schemes, corporate retainers.</p>
    </div>
    <a asp-action="Create" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PayersManage" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> New payer</a>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Any())
{
    <div class="th-empty m-4"><i class="bi bi-building"></i><h5 class="mt-2">No payers</h5></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Code</th><th>Name</th><th>Type</th><th>Plans</th><th>Contact</th><th>Status</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var p in Model)
        {
            var typeTone = p.OrgType switch
            {
                ThriveHealth.Web.Models.Insurance.PayerOrgType.Nhia => "th-pill-info",
                ThriveHealth.Web.Models.Insurance.PayerOrgType.Hmo => "th-pill-success",
                ThriveHealth.Web.Models.Insurance.PayerOrgType.StateInsurance => "th-pill-warning",
                ThriveHealth.Web.Models.Insurance.PayerOrgType.Corporate => "th-pill-info",
                ThriveHealth.Web.Models.Insurance.PayerOrgType.OutOfPocket => "th-pill-muted",
                _ => "th-pill-muted"
            };
            <tr>
                <td><span class="font-monospace">@p.Code</span></td>
                <td><strong>@p.Name</strong></td>
                <td><span class="th-pill @typeTone">@p.OrgType</span></td>
                <td><span class="th-pill th-pill-muted">@p.Plans.Count plan@(p.Plans.Count == 1 ? "" : "s")</span></td>
                <td><small class="text-muted">@p.Phone @if (!string.IsNullOrEmpty(p.ClaimsDispatchEmail)) { <span><br />@p.ClaimsDispatchEmail</span> }</small></td>
                <td>@if (p.IsActive) { <span class="th-pill th-pill-success">Active</span> } else { <span class="th-pill th-pill-muted">Inactive</span> }</td>
                <td class="text-end"><a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open"></i></a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
