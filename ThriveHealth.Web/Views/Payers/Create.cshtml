@model ThriveHealth.Web.Models.ViewModels.PayerEditViewModel
@{ ViewData["Title"] = "New payer"; }

<div class="row"><div class="col-lg-8">
    <h1 class="th-section-title">Add payer</h1>
    <form asp-action="Create" method="post" class="th-card" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.PayersManage">
        <div class="th-card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="row g-3">
                <div class="col-md-8"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Code" class="form-label"></label><input asp-for="Code" class="form-control text-uppercase" maxlength="20" /></div>
                <div class="col-md-6"><label asp-for="OrgType" class="form-label"></label>
                    <select asp-for="OrgType" class="form-select">
                        @foreach (var v in Enum.GetValues<ThriveHealth.Web.Models.Insurance.PayerOrgType>())
                        { <option value="@((int)v)">@v</option> }
                    </select>
                </div>
                <div class="col-md-6"><label asp-for="RegulatorRegistrationNumber" class="form-label"></label><input asp-for="RegulatorRegistrationNumber" class="form-control" /></div>
                <div class="col-md-6"><label asp-for="Phone" class="form-label"></label><input asp-for="Phone" class="form-control" /></div>
                <div class="col-md-6"><label asp-for="Email" class="form-label"></label><input asp-for="Email" class="form-control" /></div>
                <div class="col-md-12"><label asp-for="ClaimsDispatchEmail" class="form-label"></label><input asp-for="ClaimsDispatchEmail" class="form-control" /></div>
                <div class="col-md-12"><label asp-for="Address" class="form-label"></label><input asp-for="Address" class="form-control" /></div>
                <div class="col-md-12 form-check ms-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Active</label></div>
            </div>
            <div class="mt-3 d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button class="btn btn-primary"><i class="bi bi-check2-circle me-1"></i> Create payer</button>
            </div>
        </div>
    </form>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
