@model ThriveHealth.Web.Models.Insurance.Payer
@{ ViewData["Title"] = Model.Name; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="th-pill th-pill-info">@Model.OrgType</span>
        <h1 class="th-section-title mt-2">@Model.Name <small class="text-muted">· <span class="font-monospace">@Model.Code</span></small></h1>
        <p class="th-section-sub mb-0">@Model.Phone @if (!string.IsNullOrEmpty(Model.Email)) { <span> · @Model.Email</span> } @if (!string.IsNullOrEmpty(Model.ClaimsDispatchEmail)) { <span> · claims to @Model.ClaimsDispatchEmail</span> }</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i> Edit</a>
        <a asp-action="AddPlan" asp-route-payerId="@Model.Id" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Add plan</a>
    </div>
</div>

<div class="th-card">
    <div class="th-card-header"><h5 class="th-card-title"><i class="bi bi-card-list me-1 text-primary"></i> Plans</h5></div>
    <div class="th-card-body p-0">
        @if (!Model.Plans.Any())
        {
            <div class="th-empty m-4"><i class="bi bi-card-list"></i><h6 class="mt-2">No plans configured</h6></div>
        }
        else
        {
            <table class="table align-middle mb-0">
                <thead><tr><th>Code</th><th>Name</th><th>Tariff multiplier</th><th>Default copay</th><th>Capitation</th><th>Pre-auth</th><th>Formulary</th></tr></thead>
                <tbody>
                @foreach (var p in Model.Plans)
                {
                    <tr>
                        <td><span class="font-monospace">@p.Code</span></td>
                        <td><strong>@p.Name</strong></td>
                        <td>× @p.TariffMultiplier.ToString("F2")</td>
                        <td>@p.DefaultCopayPercent.ToString("F0") %</td>
                        <td>@(p.CapitationRatePerEnrolleeMonth > 0 ? $"₦{p.CapitationRatePerEnrolleeMonth:N0}" : "—")</td>
                        <td>@if (p.RequiresPreAuthorization) { <span class="th-pill th-pill-warning">Required</span> } else { <span class="text-muted small">Optional</span> }</td>
                        <td><span class="th-pill th-pill-muted">@p.Formulary.Count drug@(p.Formulary.Count == 1 ? "" : "s")</span></td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>
