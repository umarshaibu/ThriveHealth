@{
    ViewData["Title"] = "Access denied";
    Layout = "_AuthLayout";
}

<div class="d-flex align-items-center justify-content-center" style="min-height:100vh; padding:24px;">
    <div class="th-card" style="max-width:520px; width:100%;">
        <div class="th-card-body text-center">
            <i class="bi bi-shield-exclamation" style="font-size:3rem; color:var(--th-danger);"></i>
            <h2 class="mt-3 mb-1">Access denied</h2>
            <p class="text-muted">You don't have permission to view this page. If you believe this is a mistake, contact your facility administrator.</p>
            <a class="btn btn-primary mt-3" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-house-door me-1"></i> Back to dashboard
            </a>
        </div>
    </div>
</div>
