@model ThriveHealth.Web.Models.Identity.ApplicationUser
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = $"Manage · {Model.FullName}";
    var roles = (IList<string>)ViewBag.Roles;
    var allRoles = (List<string>)ViewBag.AllRoles;
    var facilities = (SelectList)ViewBag.Facilities;
    var tempPassword = TempData["TempPassword"] as string;
}

<a asp-action="StaffList" class="small text-muted">← Back to staff</a>

<div class="d-flex justify-content-between align-items-start mt-2 mb-3">
    <div>
        <h1 class="th-section-title mb-0">@Model.FullName</h1>
        <p class="th-section-sub mb-0">@Model.Email · @(Model.Designation ?? "—") · staff# @(Model.StaffNumber ?? "—")</p>
    </div>
    <div class="text-end">
        @if (Model.IsActive) { <span class="th-pill th-pill-success">Active</span> }
        else { <span class="th-pill th-pill-muted">Inactive</span> }
        @if (Model.LastLoginAt.HasValue)
        { <div class="small text-muted mt-1">last login @Model.LastLoginAt?.ToString("dd MMM HH:mm")</div> }
    </div>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-warning">@TempData["Error"]</div> }

@if (!string.IsNullOrEmpty(tempPassword))
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center">
        <div>
            <strong>Temporary password — copy now, won't be shown again:</strong>
            <code class="ms-2" style="font-size: 1.1rem; user-select: all;">@tempPassword</code>
        </div>
        <button class="btn btn-sm btn-outline-dark" type="button"
                onclick="navigator.clipboard.writeText('@tempPassword'); this.textContent='Copied!';">Copy</button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="th-card">
            <div class="th-card-body">
                <h5 class="mb-3">Profile</h5>
                <form asp-action="EditStaff" asp-route-id="@Model.Id" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-4">
                        <label class="form-label small">First name</label>
                        <input asp-for="FirstName" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Middle name</label>
                        <input asp-for="MiddleName" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Last name</label>
                        <input asp-for="LastName" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Phone</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Staff number</label>
                        <input asp-for="StaffNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Designation</label>
                        <input asp-for="Designation" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Department</label>
                        <input asp-for="Department" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Facility</label>
                        <select asp-for="FacilityId" asp-items="facilities" class="form-select">
                            <option value="">— None —</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">License (e.g. MDCN/2002/00099)</label>
                        <div class="input-group">
                            <input asp-for="LicenseBody" class="form-control" placeholder="Body" style="max-width: 100px;" />
                            <input asp-for="LicenseNumber" class="form-control" placeholder="Number" />
                        </div>
                    </div>
                    <div class="col-md-12 mt-2">
                        <button class="btn btn-primary"><i class="bi bi-check-lg"></i> Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="th-card mb-3">
            <div class="th-card-body">
                <h5 class="mb-3">Account</h5>

                <form asp-action="ResetStaffPassword" asp-route-id="@Model.Id" method="post" class="mb-2">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-warning w-100" type="submit"
                            onclick="return confirm('Reset password for @Model.FullName? A new temporary password will be generated and shown once.');">
                        <i class="bi bi-key-fill me-1"></i> Reset password
                    </button>
                </form>

                <form asp-action="ToggleStaffActive" asp-route-id="@Model.Id" method="post" class="mb-2">
                    @Html.AntiForgeryToken()
                    @if (Model.IsActive)
                    {
                        <button class="btn btn-outline-danger w-100" type="submit"
                                onclick="return confirm('Deactivate @Model.FullName? They will be unable to log in.');">
                            <i class="bi bi-pause-circle me-1"></i> Deactivate
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-success w-100" type="submit">
                            <i class="bi bi-play-circle me-1"></i> Reactivate
                        </button>
                    }
                </form>
            </div>
        </div>

        <div class="th-card">
            <div class="th-card-body">
                <h5 class="mb-3">Roles</h5>
                @if (roles.Any())
                {
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var r in roles)
                        {
                            <form asp-action="RemoveStaffRole" asp-route-id="@Model.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="role" value="@r" />
                                <span class="badge bg-light text-dark d-inline-flex align-items-center gap-1" style="padding: 6px 10px;">
                                    @r
                                    <button type="submit" class="btn btn-link p-0 m-0 text-dark"
                                            onclick="return confirm('Remove role @r from @Model.FullName?');">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </span>
                            </form>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small">No roles assigned.</p>
                }
                <form asp-action="AddStaffRole" asp-route-id="@Model.Id" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <select name="role" class="form-select form-select-sm" required>
                        <option value="">Add a role…</option>
                        @foreach (var r in allRoles.Where(x => !roles.Contains(x)))
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-outline-primary" type="submit"><i class="bi bi-plus-lg"></i></button>
                </form>
            </div>
        </div>
    </div>
</div>
