@model IEnumerable<ThriveHealth.Web.Models.Identity.ApplicationUser>
@{
    ViewData["Title"] = "Staff";
    var rolesByUser = (Dictionary<string, List<string>>)ViewBag.RolesByUser;
    var q = ViewBag.Q as string;
    var role = ViewBag.Role as string;
    var activeOnly = (bool)ViewBag.ActiveOnly;
    var allRoles = (List<string>)ViewBag.AllRoles;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="th-section-title">Staff directory</h1>
        <p class="th-section-sub mb-0">Clinical and administrative users at your facility.</p>
    </div>
    <a asp-action="RegisterStaff" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.StaffManage" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i> Register staff</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-warning">@TempData["Error"]</div> }

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="q" value="@q" placeholder="Search by name, email or staff number…" class="form-control" />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">Any role</option>
            @foreach (var r in allRoles)
            {
                <option value="@r" selected="@(role == r)">@r</option>
            }
        </select>
    </div>
    <div class="col-md-2 d-flex align-items-center">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="activeOnly" name="activeOnly" value="true"
                   @(activeOnly ? "checked" : "") />
            <label for="activeOnly" class="form-check-label small text-muted">Active only</label>
        </div>
    </div>
    <div class="col-md-2"><button class="btn btn-primary w-100"><i class="bi bi-search"></i> Filter</button></div>
</form>

<div class="th-card">
    <div class="th-card-body p-0">
        @if (!Model.Any())
        {
            <div class="th-empty m-4">
                <i class="bi bi-people"></i>
                <h5 class="mt-2 mb-1">No staff match this filter</h5>
                <p class="mb-3">Adjust the filters above or register the first staff member.</p>
                <a asp-action="RegisterStaff" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.StaffManage" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i> Register staff</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Staff #</th>
                            <th>Roles</th>
                            <th>Designation</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            var userRoles = rolesByUser.TryGetValue(u.Id, out var ur) ? ur : new List<string>();
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="th-avatar" style="width:32px;height:32px;font-size:11px;">@(u.FirstName.Length>0 ? u.FirstName[0].ToString() : "")@(u.LastName.Length>0 ? u.LastName[0].ToString() : "")</span>
                                        <span class="fw-semibold">@u.FullName</span>
                                    </div>
                                </td>
                                <td><span class="text-muted small">@u.Email</span></td>
                                <td>@(u.StaffNumber ?? "—")</td>
                                <td class="small">
                                    @foreach (var r in userRoles)
                                    {
                                        <span class="badge bg-light text-dark me-1">@r</span>
                                    }
                                </td>
                                <td class="small">@(u.Designation ?? "—")</td>
                                <td>
                                    @if (u.IsActive) { <span class="th-pill th-pill-success">Active</span> }
                                    else { <span class="th-pill th-pill-muted">Inactive</span> }
                                </td>
                                <td class="text-end">
                                    <a asp-action="EditStaff" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-square"></i> Manage
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
