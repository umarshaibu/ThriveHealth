@model IEnumerable<ThriveHealth.Web.Models.Identity.ApplicationUser>
@{
    ViewData["Title"] = "Staff";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="th-section-title">Staff directory</h1>
        <p class="th-section-sub mb-0">Clinical and administrative users at your facility.</p>
    </div>
    <a asp-action="RegisterStaff" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.StaffManage" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i> Register staff</a>
</div>

<div class="th-card">
    <div class="th-card-body p-0">
        @if (!Model.Any())
        {
            <div class="th-empty m-4">
                <i class="bi bi-people"></i>
                <h5 class="mt-2 mb-1">No staff yet</h5>
                <p class="mb-3">Register the first clinician, nurse, or administrator to get started.</p>
                <a asp-action="RegisterStaff" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.StaffManage" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i> Register staff</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Staff #</th>
                            <th>Department</th>
                            <th>Designation</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="th-avatar" style="width:32px;height:32px;font-size:11px;">@(u.FirstName.Length>0 ? u.FirstName[0].ToString() : "")@(u.LastName.Length>0 ? u.LastName[0].ToString() : "")</span>
                                        <span class="fw-semibold">@u.FullName</span>
                                    </div>
                                </td>
                                <td><span class="text-muted">@u.Email</span></td>
                                <td>@(u.StaffNumber ?? "—")</td>
                                <td>@(u.Department ?? "—")</td>
                                <td>@(u.Designation ?? "—")</td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="th-pill th-pill-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="th-pill th-pill-muted">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
