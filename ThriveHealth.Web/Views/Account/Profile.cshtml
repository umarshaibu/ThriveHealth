@model ThriveHealth.Web.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="th-section-title">My profile</h1>
        <p class="th-section-sub mb-0">Update your personal details and review your roles.</p>
    </div>
    <a asp-action="ChangePassword" class="btn btn-outline-primary"><i class="bi bi-shield-lock me-1"></i> Change password</a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="th-card">
            <div class="th-card-body text-center">
                <div class="th-avatar mx-auto" style="width:72px; height:72px; font-size:1.4rem;">
                    @(Model.FirstName.Length > 0 ? Model.FirstName[0].ToString() : "")@(Model.LastName.Length > 0 ? Model.LastName[0].ToString() : "")
                </div>
                <h4 class="mt-3 mb-0">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted">@Model.Designation @(string.IsNullOrEmpty(Model.Department) ? "" : "· " + Model.Department)</p>
                <hr />
                <div class="text-start">
                    <div class="small text-muted mb-1">Facility</div>
                    <div class="fw-semibold mb-3"><i class="bi bi-buildings me-1 text-muted"></i>@(Model.FacilityName ?? "—")</div>

                    <div class="small text-muted mb-1">Staff number</div>
                    <div class="fw-semibold mb-3">@(Model.StaffNumber ?? "—")</div>

                    <div class="small text-muted mb-1">Roles</div>
                    <div>
                        @foreach (var r in Model.Roles)
                        {
                            <span class="th-pill th-pill-info me-1 mb-1">@r</span>
                        }
                        @if (!Model.Roles.Any()) { <span class="text-muted">No roles assigned</span> }
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.LicenseBody))
        {
            <div class="th-card mt-3">
                <div class="th-card-body">
                    <h6 class="mb-3"><i class="bi bi-patch-check me-1 text-primary"></i>Practitioner licence</h6>
                    <div class="row small">
                        <div class="col-6 text-muted">Body</div><div class="col-6 fw-semibold">@Model.LicenseBody</div>
                        <div class="col-6 text-muted">Number</div><div class="col-6 fw-semibold">@Model.LicenseNumber</div>
                        <div class="col-6 text-muted">Expires</div>
                        <div class="col-6 fw-semibold">@(Model.LicenseExpiry?.ToString("dd MMM yyyy") ?? "—")</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-8">
        <div class="th-card">
            <div class="th-card-header"><h5 class="th-card-title">Personal details</h5></div>
            <div class="th-card-body">
                <form asp-action="Profile" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MiddleName" class="form-label"></label>
                            <input asp-for="MiddleName" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label"></label>
                            <input asp-for="Department" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Designation" class="form-label"></label>
                            <input asp-for="Designation" class="form-control" />
                        </div>
                    </div>
                    <div class="mt-4 d-flex justify-content-end">
                        <button class="btn btn-primary" type="submit"><i class="bi bi-save me-1"></i> Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
