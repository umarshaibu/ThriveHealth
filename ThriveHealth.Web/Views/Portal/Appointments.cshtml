@model IReadOnlyList<ThriveHealth.Web.Models.Scheduling.Appointment>
@using ThriveHealth.Web.Models.Scheduling
@{
    ViewData["Title"] = "My appointments";
    var now = DateTime.UtcNow;
    var upcoming = Model.Where(a => a.ScheduledStartUtc >= now && a.Status != AppointmentStatus.Cancelled).OrderBy(a => a.ScheduledStartUtc).ToList();
    var past = Model.Except(upcoming).OrderByDescending(a => a.ScheduledStartUtc).ToList();
}

<h1 class="th-section-title mb-3">My appointments</h1>

@if (upcoming.Any())
{
    <h6 class="text-uppercase text-muted small mb-2 mt-3">Upcoming</h6>
    <div class="th-card mb-3"><div class="th-card-body p-0">
        <ul class="list-group list-group-flush">
        @foreach (var a in upcoming)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>@a.ScheduledStartUtc.ToLocalTime().ToString("ddd, dd MMM · HH:mm")</strong>
                        <div class="small text-muted">@(a.Clinic?.Name ?? "—") · Dr @(a.Clinician?.LastName ?? "")</div>
                    </div>
                    <span class="th-pill th-pill-info">@a.Status</span>
                </div>
            </li>
        }
        </ul>
    </div></div>
}

@if (past.Any())
{
    <h6 class="text-uppercase text-muted small mb-2 mt-3">Past</h6>
    <div class="th-card"><div class="th-card-body p-0">
        <ul class="list-group list-group-flush">
        @foreach (var a in past)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>@a.ScheduledStartUtc.ToLocalTime().ToString("dd MMM yyyy · HH:mm")</strong>
                        <div class="small text-muted">@(a.Clinic?.Name ?? "—") · Dr @(a.Clinician?.LastName ?? "")</div>
                    </div>
                    <span class="th-pill th-pill-muted">@a.Status</span>
                </div>
            </li>
        }
        </ul>
    </div></div>
}

@if (!Model.Any())
{
    <div class="th-card"><div class="th-card-body th-empty"><i class="bi bi-calendar2-week"></i><h5 class="mt-2">No appointments</h5></div></div>
}
