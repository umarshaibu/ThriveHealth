@model ThriveHealth.Web.Models.ViewModels.PortalPayViewModel
@{ ViewData["Title"] = "Settle consult bill"; }

<h1 class="th-section-title mb-1">Pay for your consult</h1>
<p class="text-muted small mb-3">Once paid, the call appears in your tele-medicine list and a clinician can pick it up.</p>

<div class="th-card mb-3"><div class="th-card-body">
    <div class="row g-3">
        <div class="col-md-6">
            <h6 class="text-uppercase text-muted small mb-2">Session</h6>
            <div class="fw-semibold">@Model.SessionNumber</div>
            <div class="small text-muted">@Model.Mode call · scheduled for @Model.ScheduledStartUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
            @if (!string.IsNullOrEmpty(Model.ConsultationReason))
            {
                <div class="mt-2 small"><strong>Reason:</strong> @Model.ConsultationReason</div>
            }
        </div>
        <div class="col-md-6">
            <h6 class="text-uppercase text-muted small mb-2">Bill</h6>
            <div class="fw-semibold">@Model.BillNumber</div>
            <div class="display-6 mt-1">@Model.Currency @Model.Amount.ToString("N2")</div>
        </div>
    </div>
</div></div>

<form asp-action="Pay" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="teleSessionId" value="@Model.TeleSessionId" />
    <input type="hidden" name="billId" value="@Model.BillId" />
    <div class="alert alert-info small d-flex align-items-start gap-2">
        <i class="bi bi-info-circle-fill mt-1"></i>
        <div>You'll be redirected to the secure payment page to complete payment with your card, bank transfer or USSD.</div>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Telemed" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary"><i class="bi bi-credit-card me-1"></i> Pay @Model.Currency @Model.Amount.ToString("N0")</button>
    </div>
</form>
