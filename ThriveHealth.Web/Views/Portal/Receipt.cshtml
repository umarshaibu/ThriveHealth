@model ThriveHealth.Web.Models.Billing.Payment
@{
    ViewData["Title"] = $"Receipt {Model.ReceiptNumber}";
    Layout = null;
    var bill = Model.Bill!;
    var facility = bill.Facility;
    var patient = bill.Patient;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <style>
        body { background: #f5f7fa; padding: 24px; font-family: system-ui, -apple-system, sans-serif; }
        .receipt { max-width: 720px; margin: 0 auto; background: #fff; padding: 32px; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,.06); }
        .receipt h1 { font-size: 1.4rem; }
        .receipt-row { display: flex; justify-content: space-between; padding: 6px 0; }
        .receipt-row + .receipt-row { border-top: 1px dashed #e6e8ec; }
        .receipt-stamp { display: inline-block; padding: 4px 12px; background: #198754; color: white; border-radius: 4px; font-size: .75rem; letter-spacing: 1px; text-transform: uppercase; }
        @@media print {
            body { background: white; padding: 0; }
            .receipt { box-shadow: none; padding: 24px; }
            .no-print { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="receipt">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h1 class="mb-1">@(facility?.Name ?? "ThriveHealth")</h1>
                <small class="text-muted">@facility?.Address · @facility?.Phone · @facility?.Email</small>
            </div>
            <div class="text-end">
                <div class="receipt-stamp">Paid</div>
                <div class="small text-muted mt-1">@Model.ReceivedAt.ToLocalTime():dd MMM yyyy HH:mm</div>
            </div>
        </div>

        <h5 class="mb-3">Receipt @Model.ReceiptNumber</h5>

        <div class="row g-3 mb-3">
            <div class="col-6">
                <small class="text-muted text-uppercase">Patient</small>
                <div class="fw-semibold">@patient?.FullName</div>
                <div class="small text-muted">@patient?.HospitalNumber</div>
            </div>
            <div class="col-6">
                <small class="text-muted text-uppercase">Bill</small>
                <div class="fw-semibold">@bill.BillNumber</div>
                <div class="small text-muted">Service date @bill.ServiceDate.ToString("dd MMM yyyy")</div>
            </div>
        </div>

        <table class="table table-sm">
            <thead><tr><th>Description</th><th class="text-end">Qty</th><th class="text-end">Unit</th><th class="text-end">Total</th></tr></thead>
            <tbody>
                @foreach (var item in bill.Items)
                {
                    <tr>
                        <td>@item.Description<div class="small text-muted">@item.ServiceCode</div></td>
                        <td class="text-end">@item.Quantity</td>
                        <td class="text-end">@item.UnitPrice.ToString("N2")</td>
                        <td class="text-end">@item.LineNet.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr><td colspan="3" class="text-end text-muted">Subtotal</td><td class="text-end">@bill.GrossAmount.ToString("N2")</td></tr>
                @if (bill.DiscountAmount > 0)
                {
                    <tr><td colspan="3" class="text-end text-muted">Discount</td><td class="text-end">- @bill.DiscountAmount.ToString("N2")</td></tr>
                }
                <tr class="fw-semibold"><td colspan="3" class="text-end">Net amount</td><td class="text-end">@bill.NetAmount.ToString("N2")</td></tr>
            </tfoot>
        </table>

        <div class="receipt-row"><span>Payment method</span><span>@Model.Method</span></div>
        @if (!string.IsNullOrEmpty(Model.Reference))
        {
            <div class="receipt-row"><span>Reference</span><span class="text-muted">@Model.Reference</span></div>
        }
        <div class="receipt-row fw-semibold"><span>Amount paid</span><span>@Model.Amount.ToString("N2")</span></div>

        <div class="mt-4 pt-3 border-top small text-muted">
            Issued by @(facility?.Name ?? "ThriveHealth"). For queries about this receipt, contact the
            billing office quoting receipt number <strong>@Model.ReceiptNumber</strong>.
        </div>

        <div class="d-flex justify-content-end gap-2 mt-3 no-print">
            <a class="btn btn-outline-secondary btn-sm" href="javascript:history.back()"><i class="bi bi-arrow-left me-1"></i> Back</a>
            <button class="btn btn-primary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i> Print / Save as PDF</button>
        </div>
    </div>
</body>
</html>
