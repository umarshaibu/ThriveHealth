@{
    ViewData["Title"] = "Symptom checker";
    var p = (ThriveHealth.Web.Models.Patients.Patient)ViewBag.Patient;
}

<div class="row"><div class="col-lg-9">
    <h1 class="th-section-title"><i class="bi bi-chat-dots text-primary me-1"></i> Symptom checker</h1>
    <p class="th-section-sub">Describe what you're feeling. The assistant will tell you whether to book an appointment, come in today, or seek emergency care. <strong>This is not medical advice — talk to a clinician for diagnosis.</strong></p>

    <div class="th-card">
        <div class="th-card-body" id="aiChat" style="min-height: 200px;">
            <div class="text-muted small">Hi @p.FirstName. Tell me what's wrong, e.g. "I have a headache and fever for 3 days".</div>
        </div>
        <div class="th-card-footer">
            <div class="d-flex gap-2">
                <input id="aiQ" class="form-control" placeholder="Type your symptoms…" />
                <button class="btn btn-primary" onclick="aiAskSymptom()"><i class="bi bi-send"></i></button>
            </div>
        </div>
    </div>

    <div class="alert alert-warning small mt-3 mb-0">
        <strong>Emergency?</strong> If you have severe chest pain, difficulty breathing, heavy bleeding, sudden weakness on one side of the body, or any life-threatening symptom — go to A&amp;E now or call your nearest hospital. Don't wait for the chatbot.
    </div>
</div></div>

@section Scripts {
<script>
var convoHistory = [];
var inFlight = false;
function escHtml(s) {
    return (s || "").toString().replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
}
async function aiAskSymptom() {
    if (inFlight) return;
    var q = document.getElementById('aiQ').value.trim();
    if (!q) return;
    var chat = document.getElementById('aiChat');
    chat.insertAdjacentHTML('beforeend', `<div class="mb-2"><strong>You:</strong> ${escHtml(q)}</div>`);
    document.getElementById('aiQ').value = '';
    var thinkingEl = document.createElement('div');
    thinkingEl.className = 'text-muted small mb-2';
    thinkingEl.textContent = 'Thinking…';
    chat.appendChild(thinkingEl);
    chat.scrollTop = chat.scrollHeight;
    convoHistory.push('Patient: ' + q);

    inFlight = true;
    var controller = new AbortController();
    var timeout = setTimeout(() => controller.abort(), 30000); // 30s server-side budget; if it hangs, fail loudly
    try {
        var r = await fetch('/Portal/SymptomCheckerAsk', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ question: q, history: convoHistory }),
            signal: controller.signal
        });
        clearTimeout(timeout);
        thinkingEl.remove();
        if (!r.ok) {
            chat.insertAdjacentHTML('beforeend', `<div class="alert alert-warning">AI failed: HTTP ${r.status} ${r.statusText}</div>`);
        } else {
            var j = await r.json();
            if (j.ok) {
                chat.insertAdjacentHTML('beforeend', `<pre class="mb-3 p-2 border rounded-3 bg-light" style="white-space:pre-wrap;font-family:inherit">${escHtml(j.text)}</pre>`);
                convoHistory.push('Assistant: ' + j.text);
            } else {
                chat.insertAdjacentHTML('beforeend', `<div class="alert alert-warning">AI failed: ${escHtml(j.error || 'unknown')}</div>`);
            }
        }
        chat.scrollTop = chat.scrollHeight;
    } catch (e) {
        clearTimeout(timeout);
        thinkingEl.remove();
        var msg = e.name === 'AbortError'
            ? 'Server didn\'t respond after 30 seconds. Restart the app or check the AI provider settings.'
            : (e.message || String(e));
        chat.insertAdjacentHTML('beforeend', `<div class="alert alert-warning">AI failed: ${escHtml(msg)}</div>`);
    } finally {
        inFlight = false;
    }
}
document.getElementById('aiQ').addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); aiAskSymptom(); } });
</script>
}
