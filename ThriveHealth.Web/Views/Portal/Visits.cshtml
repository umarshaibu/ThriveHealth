@model IReadOnlyList<ThriveHealth.Web.Models.Clinical.Encounter>
@using ThriveHealth.Web.Models.Clinical
@{
    ViewData["Title"] = "My visits";
    string TypeIcon(EncounterType t) => t switch
    {
        EncounterType.Telemedicine => "bi-camera-video",
        EncounterType.Emergency => "bi-shield-plus",
        EncounterType.InpatientAdmission => "bi-hospital",
        EncounterType.AntenatalVisit => "bi-heart-pulse",
        EncounterType.OutpatientFollowUp => "bi-arrow-clockwise",
        EncounterType.SpecialistClinic => "bi-mortarboard",
        EncounterType.Procedure => "bi-bandaid",
        _ => "bi-clipboard2-pulse"
    };
    string Tone(EncounterStatus s) => s switch
    {
        EncounterStatus.InProgress => "th-pill-warning",
        EncounterStatus.Signed => "th-pill-success",
        _ => "th-pill-muted"
    };
}

<h1 class="th-section-title mb-3">My visits</h1>

@if (!Model.Any())
{
    <div class="th-card"><div class="th-card-body th-empty"><i class="bi bi-clipboard"></i><h5 class="mt-2">No visits recorded yet</h5></div></div>
}
else
{
    <div class="th-card"><div class="th-card-body p-0">
        <ul class="list-group list-group-flush">
        @foreach (var e in Model)
        {
            <li class="list-group-item">
                <a class="text-decoration-none text-body d-flex justify-content-between align-items-center gap-3" asp-action="Visit" asp-route-id="@e.Id">
                    <div class="d-flex align-items-start gap-3 flex-grow-1">
                        <div class="th-pill th-pill-info" style="min-width: 36px; text-align: center;"><i class="bi @TypeIcon(e.Type)"></i></div>
                        <div>
                            <strong>@(e.ChiefComplaint ?? e.Type.ToString())</strong>
                            <div class="small text-muted">@e.StartedAt.ToLocalTime().ToString("ddd dd MMM yyyy · HH:mm") · @(e.Clinic?.Name ?? "—") · Dr @(e.Clinician?.LastName ?? "—")</div>
                            <div class="small text-muted">@e.Type</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="th-pill @Tone(e.Status)">@e.Status</span>
                        <i class="bi bi-chevron-right text-muted"></i>
                    </div>
                </a>
            </li>
        }
        </ul>
    </div></div>
}
