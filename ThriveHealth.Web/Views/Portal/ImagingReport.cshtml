@model ThriveHealth.Web.Models.Clinical.ImagingOrder
@{
    ViewData["Title"] = $"Imaging report · {Model.StudyDescription}";
    var report = Model.Report;
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title mb-1">@Model.Modality — @Model.StudyDescription</h1>
        <p class="text-muted small mb-0">Order placed @Model.OrderedAt.ToLocalTime().ToString("dd MMM yyyy") · @Model.Urgency</p>
    </div>
    <a asp-action="Results" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i> Back to results</a>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="th-card h-100"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-info-circle me-1"></i> Clinical indication</h6>
            <p class="mb-0">@(Model.ClinicalIndication ?? "—")</p>
            <div class="small text-muted mt-1">Ordered by Dr @(Model.OrderedBy?.LastName ?? "—")</div>
        </div></div>
    </div>
    <div class="col-md-6">
        <div class="th-card h-100"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-clipboard2-pulse me-1"></i> Study</h6>
            <div>@Model.Modality — @Model.StudyDescription</div>
            @if (!string.IsNullOrEmpty(report?.Technique)) { <div class="small text-muted">Technique: @report.Technique</div> }
            @if (!string.IsNullOrEmpty(report?.Contrast)) { <div class="small text-muted">Contrast: @report.Contrast</div> }
            @if (!string.IsNullOrEmpty(Model.AccessionNumber)) { <div class="small text-muted">Accession # @Model.AccessionNumber</div> }
        </div></div>
    </div>
</div>

@if (report is null)
{
    <div class="alert alert-warning d-flex align-items-start gap-2">
        <i class="bi bi-hourglass-split mt-1"></i>
        <div>
            <strong>Report not yet available.</strong>
            <div class="small mb-0">Current status: <strong>@Model.Status</strong>. We'll notify you when the radiologist has authorised the report.</div>
        </div>
    </div>
}
else
{
    <div class="th-card mb-3"><div class="th-card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="text-uppercase text-muted small mb-0"><i class="bi bi-card-text me-1"></i> Radiologist's report</h6>
            <span class="th-pill @(report.IsAuthorized ? "th-pill-success" : "th-pill-info")">@(report.IsAuthorized ? "Authorised" : "Pending authorisation")</span>
        </div>
        @if (!string.IsNullOrEmpty(report.Findings))
        {
            <h6 class="small text-uppercase text-muted">Findings</h6>
            <p style="white-space: pre-wrap;">@report.Findings</p>
        }
        @if (!string.IsNullOrEmpty(report.Impression))
        {
            <h6 class="small text-uppercase text-muted mt-3">Impression</h6>
            <p style="white-space: pre-wrap;" class="fw-semibold">@report.Impression</p>
        }
        @if (!string.IsNullOrEmpty(report.Recommendation))
        {
            <h6 class="small text-uppercase text-muted mt-3">Recommendation</h6>
            <p style="white-space: pre-wrap;">@report.Recommendation</p>
        }
        @if (!string.IsNullOrEmpty(report.DicomViewerUrl))
        {
            <a href="@report.DicomViewerUrl" target="_blank" class="btn btn-outline-primary btn-sm mt-2"><i class="bi bi-eye me-1"></i> View images</a>
        }
        <div class="border-top pt-3 mt-3 small text-muted">
            @if (report.PerformedAt.HasValue)
            {
                <div>Performed @report.PerformedAt.Value.ToLocalTime():dd MMM yyyy HH:mm @if (report.PerformedBy != null) { <text>by @report.PerformedBy.FullName</text> }</div>
            }
            @if (report.ReportedAt.HasValue)
            {
                <div>Reported @report.ReportedAt.Value.ToLocalTime():dd MMM yyyy HH:mm @if (report.ReportedBy != null) { <text>by Dr @report.ReportedBy.FullName</text> }</div>
            }
            @if (report.AuthorizedAt.HasValue)
            {
                <div>Authorised @report.AuthorizedAt.Value.ToLocalTime():dd MMM yyyy HH:mm @if (report.AuthorizedBy != null) { <text>by Dr @report.AuthorizedBy.FullName</text> }</div>
            }
        </div>
    </div></div>

    @if (report.HasCriticalFinding)
    {
        <div class="alert alert-danger d-flex align-items-start gap-2">
            <i class="bi bi-exclamation-octagon-fill mt-1"></i>
            <div>
                <strong>Critical finding flagged.</strong>
                <div class="small mb-0">Your clinician has been alerted. Please follow their instructions.</div>
            </div>
        </div>
    }
}

<p class="small text-muted"><i class="bi bi-info-circle me-1"></i> Imaging reports must be interpreted by a clinician in the context of your symptoms and history.</p>
