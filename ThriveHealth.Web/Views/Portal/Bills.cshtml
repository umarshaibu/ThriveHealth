@model IReadOnlyList<ThriveHealth.Web.Models.Billing.Bill>
@using ThriveHealth.Web.Models.Billing
@{
    ViewData["Title"] = "My bills";
    string Tone(BillStatus s) => s switch
    {
        BillStatus.Open => "th-pill-warning",
        BillStatus.PartiallyPaid => "th-pill-info",
        BillStatus.Paid => "th-pill-success",
        _ => "th-pill-muted"
    };
}

<h1 class="th-section-title mb-3">My bills</h1>

@if (!Model.Any())
{
    <div class="th-card"><div class="th-card-body th-empty"><i class="bi bi-receipt"></i><h5 class="mt-2">No bills</h5></div></div>
}
else
{
    foreach (var b in Model)
    {
        <div class="th-card mb-3"><div class="th-card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <strong class="font-monospace">@b.BillNumber</strong>
                    <div class="small text-muted">@b.ServiceDate.ToString("dd MMM yyyy") · @b.Items.Count item(s)</div>
                </div>
                <span class="th-pill @Tone(b.Status)">@b.Status</span>
            </div>
            <hr class="my-2" />
            <dl class="row mb-0 small">
                <dt class="col-7">Net</dt><dd class="col-5 text-end">₦@b.NetAmount.ToString("N2")</dd>
                <dt class="col-7">Paid</dt><dd class="col-5 text-end text-success">₦@b.PaidAmount.ToString("N2")</dd>
                <dt class="col-7 fw-bold border-top pt-1">Balance</dt><dd class="col-5 text-end fw-bold border-top pt-1">₦@b.Balance.ToString("N2")</dd>
            </dl>
            @if (b.Status is BillStatus.Open or BillStatus.PartiallyPaid)
            {
                <form asp-action="PayBill" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="billId" value="@b.Id" />
                    <button class="btn btn-success w-100"><i class="bi bi-credit-card me-1"></i> Pay ₦@b.Balance.ToString("N2") online</button>
                </form>
                <div class="small text-muted mt-1"><i class="bi bi-info-circle me-1"></i>Or pay at the cashier desk on your next visit.</div>
            }
            @if (b.Payments.Any(p => p.Status == PaymentStatus.Recorded))
            {
                <div class="mt-2 d-flex flex-wrap gap-2">
                    @foreach (var pay in b.Payments.Where(p => p.Status == PaymentStatus.Recorded).OrderByDescending(p => p.ReceivedAt))
                    {
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Receipt" asp-route-paymentId="@pay.Id" target="_blank">
                            <i class="bi bi-receipt me-1"></i> @pay.ReceiptNumber · ₦@pay.Amount.ToString("N0")
                        </a>
                    }
                </div>
            }
        </div></div>
    }
}
