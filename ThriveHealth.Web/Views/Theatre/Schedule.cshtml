@model ThriveHealth.Web.Models.ViewModels.TheatreScheduleViewModel
@using ThriveHealth.Web.Models.Theatre
@{
    ViewData["Title"] = "Theatre schedule";
    var prev = Model.Date.AddDays(-1);
    var next = Model.Date.AddDays(1);

    string StatusTone(TheatreSessionStatus s) => s switch
    {
        TheatreSessionStatus.Scheduled => "th-pill-info",
        TheatreSessionStatus.PreOp => "th-pill-warning",
        TheatreSessionStatus.InTheatre => "th-pill-danger",
        TheatreSessionStatus.Recovery => "th-pill-warning",
        TheatreSessionStatus.Completed => "th-pill-success",
        TheatreSessionStatus.Cancelled => "th-pill-muted",
        TheatreSessionStatus.Postponed => "th-pill-muted",
        _ => "th-pill-muted"
    };
    string UrgencyTone(CaseUrgency u) => u switch
    {
        CaseUrgency.Emergency => "th-pill-danger",
        CaseUrgency.Urgent => "th-pill-warning",
        CaseUrgency.ScheduledUrgent => "th-pill-info",
        _ => "th-pill-muted"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Theatre schedule</h1>
        <p class="th-section-sub mb-0">@Model.Date.ToString("dddd · dd MMM yyyy") · @Model.Theatres.Count theatre@(Model.Theatres.Count == 1 ? "" : "s")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Schedule" asp-route-date="@prev.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary"><i class="bi bi-chevron-left"></i></a>
        <a asp-action="Schedule" class="btn btn-outline-secondary">Today</a>
        <a asp-action="Schedule" asp-route-date="@next.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary"><i class="bi bi-chevron-right"></i></a>
        <a asp-action="Book" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.TheatreSchedule" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Book session</a>
    </div>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="row g-3 mb-3">
    <div class="col-md-3"><div class="th-stat tone-info"><div class="th-stat-icon"><i class="bi bi-calendar2-event"></i></div><div class="th-stat-label">Scheduled</div><div class="th-stat-value">@Model.ScheduledCount</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-warning"><div class="th-stat-icon"><i class="bi bi-activity"></i></div><div class="th-stat-label">In progress</div><div class="th-stat-value">@Model.InProgressCount</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-success"><div class="th-stat-icon"><i class="bi bi-check2-circle"></i></div><div class="th-stat-label">Completed</div><div class="th-stat-value">@Model.CompletedCount</div></div></div>
    <div class="col-md-3"><div class="th-stat tone-primary"><div class="th-stat-icon"><i class="bi bi-hospital"></i></div><div class="th-stat-label">Theatres</div><div class="th-stat-value">@Model.Theatres.Count</div></div></div>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Sessions.Any())
{
    <div class="th-empty m-4"><i class="bi bi-calendar-x"></i><h5 class="mt-2">No sessions scheduled</h5><p class="text-muted">Book a session to get started.</p></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Time</th><th>Theatre</th><th>Patient</th><th>Procedure</th><th>Surgeon</th><th>Urgency</th><th>Status</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var r in Model.Sessions)
        {
            var s = r.Session;
            <tr>
                <td><strong>@s.ScheduledStartUtc.ToLocalTime().ToString("HH:mm")</strong><div class="small text-muted">@s.EstimatedMinutes min</div></td>
                <td><span class="th-pill th-pill-muted">@s.Theatre?.Code</span><div class="small text-muted">@s.Theatre?.Name</div></td>
                <td><strong>@r.Patient.FullName</strong><div class="small text-muted">@r.Patient.HospitalNumber</div></td>
                <td>@s.ProcedureName @if (!string.IsNullOrEmpty(s.CptCode)) { <small class="text-muted">@s.CptCode</small> }</td>
                <td>@s.LeadSurgeon?.FullName</td>
                <td><span class="th-pill @UrgencyTone(s.Urgency)">@s.Urgency</span></td>
                <td><span class="th-pill @StatusTone(s.Status)">@s.Status</span></td>
                <td class="text-end"><a asp-action="Session" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open me-1"></i> Open</a></td>
            </tr>
        }
        </tbody>
    </table>
}
</div></div>
