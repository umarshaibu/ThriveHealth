@model ThriveHealth.Web.Models.Scheduling.Clinic
@{
    ViewData["Title"] = Model.Name;
    var avail = (List<ThriveHealth.Web.Models.Scheduling.ClinicianAvailability>)ViewBag.Availability;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="d-flex align-items-center gap-3">
        <span class="d-inline-block rounded-circle" style="width:18px;height:18px;background:@Model.ColorHex"></span>
        <div>
            <h1 class="th-section-title mb-0">@Model.Name <span class="font-monospace text-muted ms-2">@Model.Code</span></h1>
            <p class="th-section-sub mb-0">@Model.Specialty · @Model.DefaultSlotMinutes-min slots · @(Model.IsActive ? "Active" : "Inactive")</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Queue" asp-action="Board" asp-route-clinicId="@Model.Id" class="btn btn-outline-primary" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.QueueRead"><i class="bi bi-display me-1"></i> Queue board</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i> Edit</a>
    </div>
</div>

<div class="th-card mb-3">
    <div class="th-card-header">
        <h5 class="th-card-title"><i class="bi bi-calendar-week me-1 text-primary"></i> Weekly clinician availability</h5>
        <a asp-action="AddAvailability" asp-route-clinicId="@Model.Id" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i> Add availability</a>
    </div>
    <div class="th-card-body p-0">
        @if (avail.Count == 0)
        {
            <div class="th-empty m-4"><i class="bi bi-calendar-x"></i><h5 class="mt-2">No availability configured</h5><p>Add a clinician's recurring schedule (e.g., Mon-Fri 8am–1pm) to make slots bookable.</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead><tr><th>Day</th><th>Time</th><th>Clinician</th><th>Room</th><th>Slot</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var a in avail)
                    {
                        <tr>
                            <td><strong>@a.DayOfWeek</strong></td>
                            <td>@a.StartTime.ToString("HH:mm") – @a.EndTime.ToString("HH:mm")</td>
                            <td>@a.Clinician?.FullName <small class="text-muted">@a.Clinician?.Designation</small></td>
                            <td>@(a.Room?.Name ?? "—")</td>
                            <td>@(a.SlotMinutesOverride.HasValue ? $"{a.SlotMinutesOverride} min" : "default")</td>
                            <td class="text-end">
                                <form asp-action="RemoveAvailability" asp-route-id="@a.Id" method="post" class="d-inline" onsubmit="return confirm('Remove this availability?');" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ClinicsManage">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
