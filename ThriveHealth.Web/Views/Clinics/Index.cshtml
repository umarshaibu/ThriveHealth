@model IEnumerable<ThriveHealth.Web.Models.Scheduling.Clinic>
@{ ViewData["Title"] = "Clinics"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Clinics</h1>
        <p class="th-section-sub mb-0">Configure clinics, their slot durations, and weekly clinician availability.</p>
    </div>
    <a asp-action="Create" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.ClinicsManage" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> New clinic</a>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Any())
{
    <div class="th-empty m-4"><i class="bi bi-building"></i><h5 class="mt-2">No clinics yet</h5><p>Add your first clinic to start booking appointments.</p></div>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead><tr><th></th><th>Code</th><th>Name</th><th>Specialty</th><th>Slot</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="d-inline-block rounded-circle" style="width:14px;height:14px;background:@c.ColorHex"></span></td>
                    <td><span class="font-monospace">@c.Code</span></td>
                    <td><strong>@c.Name</strong></td>
                    <td>@c.Specialty</td>
                    <td>@c.DefaultSlotMinutes min</td>
                    <td>@if (c.IsActive) { <span class="th-pill th-pill-success">Active</span> } else { <span class="th-pill th-pill-muted">Inactive</span> }</td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-folder2-open"></i> Open</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
</div></div>
