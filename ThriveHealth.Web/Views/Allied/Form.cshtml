@model ThriveHealth.Web.Models.ViewModels.AlliedSessionInputViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using ThriveHealth.Web.Models.Allied
@{
    ViewData["Title"] = $"{(Model.Id.HasValue ? "Edit" : "New")} {Model.ServiceLine} session";
    var providers = ViewBag.Providers as SelectList;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="th-section-title">@(Model.Id.HasValue ? "Edit" : "New") @Model.ServiceLine session</h1>
    <a asp-action="Index" asp-route-line="@Model.ServiceLine" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<form asp-action="Save" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AlliedSession">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ServiceLine" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="th-card mb-3"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-clipboard2 me-1"></i> Consultation</h6>
                <div class="row g-3">
                    @if (!Model.Id.HasValue)
                    {
                        <div class="col-12">
                            <label class="form-label">Patient</label>
                            <div class="input-group">
                                <input type="hidden" asp-for="PatientId" id="PatientId" />
                                <input asp-for="PatientLabel" id="PatientLabel" class="form-control" placeholder="Search…" autocomplete="off" />
                                <button type="button" class="btn btn-outline-secondary" id="psBtn"><i class="bi bi-search"></i></button>
                            </div>
                            <span asp-validation-for="PatientId" class="text-danger small"></span>
                        </div>
                    }
                    else
                    {
                        <div class="col-12"><label class="form-label">Patient</label><input class="form-control" disabled value="@Model.PatientLabel" /></div>
                    }
                    <div class="col-md-6"><label asp-for="ScheduledUtc" class="form-label">Scheduled</label><input asp-for="ScheduledUtc" type="datetime-local" class="form-control" /></div>
                    <div class="col-md-6"><label asp-for="ProviderId" class="form-label">Provider</label><select asp-for="ProviderId" asp-items="providers" class="form-select"><option value="">—</option></select></div>
                    <div class="col-12"><label asp-for="ChiefComplaint" class="form-label">Chief complaint</label><textarea asp-for="ChiefComplaint" class="form-control" rows="2"></textarea></div>
                </div>
            </div></div>

            <div class="th-card"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-clipboard2-pulse me-1"></i> Examination & assessment</h6>
                <div class="mb-2"><label asp-for="Examination" class="form-label">Examination</label><textarea asp-for="Examination" class="form-control" rows="3"></textarea></div>
                <div class="mb-2"><label asp-for="Assessment" class="form-label">Assessment</label><textarea asp-for="Assessment" class="form-control" rows="2"></textarea></div>
                <div class="mb-0"><label asp-for="Plan" class="form-label">Plan</label><textarea asp-for="Plan" class="form-control" rows="2"></textarea></div>
            </div></div>
        </div>

        <div class="col-lg-6">
            @if (Model.ServiceLine == AlliedServiceLine.Dental)
            {
                <div class="th-card mb-3"><div class="th-card-body">
                    <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-tooth me-1"></i> Dental</h6>
                    <div class="row g-3">
                        <div class="col-12"><label asp-for="ToothChart" class="form-label">Tooth chart notation</label><input asp-for="ToothChart" class="form-control" placeholder="e.g. 16-DO caries; 36 RCT" /></div>
                        <div class="col-md-6"><label asp-for="DentalProcedureCode" class="form-label">Procedure code</label><input asp-for="DentalProcedureCode" class="form-control" placeholder="ADA / CDT code" /></div>
                        <div class="col-md-6"><label asp-for="Modality" class="form-label">Modality</label><input asp-for="Modality" class="form-control" placeholder="Scaling, RCT, extraction…" /></div>
                    </div>
                </div></div>
            }
            else if (Model.ServiceLine == AlliedServiceLine.Optometry)
            {
                <div class="th-card mb-3"><div class="th-card-body">
                    <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-eyeglasses me-1"></i> Optometry</h6>
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="RightEyeAcuity" class="form-label">Right eye acuity</label><input asp-for="RightEyeAcuity" class="form-control" placeholder="6/6" /></div>
                        <div class="col-md-6"><label asp-for="LeftEyeAcuity" class="form-label">Left eye acuity</label><input asp-for="LeftEyeAcuity" class="form-control" placeholder="6/9" /></div>
                        <div class="col-md-6"><label asp-for="RightEyeRefraction" class="form-label">Right refraction</label><input asp-for="RightEyeRefraction" class="form-control" placeholder="-1.50/-0.50 x 90" /></div>
                        <div class="col-md-6"><label asp-for="LeftEyeRefraction" class="form-label">Left refraction</label><input asp-for="LeftEyeRefraction" class="form-control" placeholder="-1.25/-0.50 x 85" /></div>
                    </div>
                </div></div>
            }
            else if (Model.ServiceLine == AlliedServiceLine.Physiotherapy)
            {
                <div class="th-card mb-3"><div class="th-card-body">
                    <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-arms-up me-1"></i> Physiotherapy</h6>
                    <div class="row g-3">
                        <div class="col-md-6"><label asp-for="SessionsCompleted" class="form-label">Sessions completed</label><input asp-for="SessionsCompleted" type="number" min="0" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="SessionsPlanned" class="form-label">Sessions planned</label><input asp-for="SessionsPlanned" type="number" min="0" class="form-control" /></div>
                        <div class="col-12"><label asp-for="PhysioModalitiesUsed" class="form-label">Modalities used</label><input asp-for="PhysioModalitiesUsed" class="form-control" placeholder="TENS, US, ROM exercises…" /></div>
                    </div>
                </div></div>
            }

            <div class="th-card"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-bandaid me-1"></i> Treatment</h6>
                <textarea asp-for="TreatmentGiven" class="form-control" rows="6" placeholder="Describe procedures performed, materials used, patient response…"></textarea>
            </div></div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-3">
        <a asp-action="Index" asp-route-line="@Model.ServiceLine" class="btn btn-outline-secondary">Cancel</a>
        <button class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>
    </div>
</form>

@if (!Model.Id.HasValue)
{
    <div class="modal fade" id="patientSearch" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Find patient</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body"><input id="ps_q" class="form-control mb-2" placeholder="Search…" /><div id="ps_results" class="list-group" style="max-height:380px;overflow:auto"></div></div>
            </div>
        </div>
    </div>
}

@section Scripts {
<partial name="_ValidationScriptsPartial" />
@if (!Model.Id.HasValue)
{
    <script>
        var ps = new bootstrap.Modal(document.getElementById('patientSearch'));
        document.getElementById('psBtn').addEventListener('click', () => ps.show());
        document.getElementById('PatientLabel').addEventListener('focus', () => ps.show());
        var t;
        document.getElementById('ps_q').addEventListener('input', function () {
            clearTimeout(t);
            var q = this.value;
            t = setTimeout(async () => {
                if (!q || q.length < 2) { document.getElementById('ps_results').innerHTML = ''; return; }
                var r = await fetch('/Patients/Search?q=' + encodeURIComponent(q));
                if (!r.ok) return;
                var data = await r.json();
                document.getElementById('ps_results').innerHTML = data.map(p =>
                    `<button type="button" class="list-group-item list-group-item-action" data-id="${p.id}" data-label="${p.fullName} · ${p.hospitalNumber}"><strong>${p.fullName}</strong> <small class="text-muted">${p.hospitalNumber}</small></button>`
                ).join('');
                document.querySelectorAll('#ps_results .list-group-item').forEach(b => b.addEventListener('click', function () {
                    document.getElementById('PatientId').value = this.dataset.id;
                    document.getElementById('PatientLabel').value = this.dataset.label;
                    ps.hide();
                }));
            }, 250);
        });
    </script>
}
}
