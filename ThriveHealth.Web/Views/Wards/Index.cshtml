@model IEnumerable<ThriveHealth.Web.Models.Inpatient.Ward>
@{ ViewData["Title"] = "Wards"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="th-section-title">Wards &amp; beds</h1>
        <p class="th-section-sub mb-0">Configure wards and add beds. Bed restrictions enforce sex/age safety on admission.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Board" class="btn btn-outline-primary"><i class="bi bi-grid me-1"></i> Bed board</a>
        <a asp-action="Create" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.WardsManage" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> New ward</a>
    </div>
</div>

@foreach (var w in Model)
{
    <div class="th-card mb-3">
        <div class="th-card-header">
            <h5 class="th-card-title">
                <span class="d-inline-block rounded-circle me-2" style="width:12px;height:12px;background:@w.ColorHex"></span>
                @w.Name <span class="font-monospace small text-muted ms-2">@w.Code</span>
                <small class="text-muted ms-2">@w.Type · @w.Beds.Count beds</small>
            </h5>
            <a asp-action="Edit" asp-route-id="@w.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
        </div>
        <div class="th-card-body">
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var b in w.Beds.OrderBy(b => b.BedNumber))
                {
                    var t = b.Status switch
                    {
                        ThriveHealth.Web.Models.Inpatient.BedStatus.Free => "th-pill-success",
                        ThriveHealth.Web.Models.Inpatient.BedStatus.Occupied => "th-pill-info",
                        _ => "th-pill-warning"
                    };
                    <span class="th-pill @t font-monospace">@b.BedNumber · @b.Status</span>
                }
            </div>
            <form asp-action="AddBed" method="post" class="row g-2 align-items-end" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.WardsManage">
                @Html.AntiForgeryToken()
                <input type="hidden" name="wardId" value="@w.Id" />
                <div class="col-md-3"><label class="form-label small">New bed #</label><input class="form-control" name="bedNumber" placeholder="@w.Code-XX" /></div>
                <div class="col-md-3"><label class="form-label small">Restriction</label>
                    <select name="restriction" class="form-select">
                        <option value="0">None</option>
                        <option value="1">Male only</option>
                        <option value="2">Female only</option>
                        <option value="3">Paediatric only</option>
                    </select>
                </div>
                <div class="col-md-2"><button class="btn btn-sm btn-primary"><i class="bi bi-plus me-1"></i> Add bed</button></div>
            </form>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="th-empty"><i class="bi bi-hospital"></i><h5 class="mt-2">No wards yet</h5><a asp-action="Create" class="btn btn-primary mt-2">New ward</a></div>
}
