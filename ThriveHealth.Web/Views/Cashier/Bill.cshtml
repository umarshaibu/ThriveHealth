@model ThriveHealth.Web.Models.ViewModels.BillDetailViewModel
@using ThriveHealth.Web.Models.Billing
@{
    ViewData["Title"] = $"Bill {Model.Bill.BillNumber}";

    string Tone(BillStatus s) => s switch
    {
        BillStatus.Open => "th-pill-warning",
        BillStatus.PartiallyPaid => "th-pill-info",
        BillStatus.Paid => "th-pill-success",
        BillStatus.Cancelled => "th-pill-muted",
        BillStatus.WrittenOff => "th-pill-muted",
        _ => "th-pill-muted"
    };

    string KindIcon(BillItemKind k) => k switch
    {
        BillItemKind.Consultation => "bi-clipboard2-pulse",
        BillItemKind.Lab => "bi-droplet-half",
        BillItemKind.Imaging => "bi-radioactive",
        BillItemKind.Drug => "bi-capsule",
        BillItemKind.Procedure => "bi-bandaid",
        BillItemKind.BedDay => "bi-hospital",
        BillItemKind.Theatre => "bi-scissors",
        _ => "bi-receipt"
    };

    string MethodLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash => "Cash",
        PaymentMethod.Pos => "POS",
        PaymentMethod.BankTransfer => "Bank transfer",
        PaymentMethod.MobileMoney => "Mobile money",
        PaymentMethod.Cheque => "Cheque",
        PaymentMethod.Voucher => "Voucher",
        _ => m.ToString()
    };
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title mb-1">Bill <span class="font-monospace">@Model.Bill.BillNumber</span></h1>
        <div class="d-flex gap-2 flex-wrap">
            <span class="th-pill @Tone(Model.Bill.Status)">@Model.Bill.Status</span>
            <span class="th-pill th-pill-muted">@Model.Bill.ServiceDate.ToString("dd MMM yyyy")</span>
            <span class="th-pill th-pill-muted">@Model.Patient.FullName · @Model.Patient.HospitalNumber</span>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Bills" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Bills</a>
        <button type="button" class="btn btn-outline-primary" onclick="aiBillCheck(@Model.Bill.Id)" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.AiBillAnomaly"><i class="bi bi-stars me-1"></i> AI anomaly check</button>
        @if (Model.Bill.Status is BillStatus.Open or BillStatus.PartiallyPaid)
        {
            <a asp-action="TakePayment" asp-route-id="@Model.Bill.Id" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.BillsPaymentRecord" class="btn btn-success"><i class="bi bi-cash-coin me-1"></i> Take payment</a>
        }
    </div>
</div>
<div id="aiBillCheckCard" class="th-card mb-3" style="display:none">
    <div class="th-card-header"><h5 class="th-card-title mb-0"><i class="bi bi-stars me-1 text-primary"></i> AI bill anomaly check</h5></div>
    <div class="th-card-body"><pre id="aiBillCheckOut" class="mb-0" style="white-space:pre-wrap;font-family:inherit"></pre></div>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="row g-3">
    <div class="col-lg-8">
        <div class="th-card mb-3"><div class="th-card-body p-0">
            <div class="p-3 border-bottom"><h6 class="mb-0"><i class="bi bi-list-ul me-1"></i> Items</h6></div>
            @if (!Model.Bill.Items.Any())
            {
                <div class="th-empty m-4"><i class="bi bi-inbox"></i><h5 class="mt-2">No items</h5></div>
            }
            else
            {
                <table class="table align-middle mb-0">
                    <thead><tr><th>Description</th><th class="text-center">Qty</th><th class="text-end">Unit (₦)</th><th class="text-end">Disc (₦)</th><th class="text-end">Net (₦)</th></tr></thead>
                    <tbody>
                    @foreach (var i in Model.Bill.Items)
                    {
                        <tr>
                            <td><i class="@KindIcon(i.Kind) me-1 text-muted"></i>@i.Description@if (!string.IsNullOrEmpty(i.ServiceCode)) { <small class="text-muted ms-1">@i.ServiceCode</small> }</td>
                            <td class="text-center">@i.Quantity</td>
                            <td class="text-end">@i.UnitPrice.ToString("N0")</td>
                            <td class="text-end">@i.LineDiscount.ToString("N0")</td>
                            <td class="text-end fw-semibold">@i.LineNet.ToString("N0")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div></div>

        <div class="th-card"><div class="th-card-body p-0">
            <div class="p-3 border-bottom"><h6 class="mb-0"><i class="bi bi-cash-coin me-1"></i> Payment history</h6></div>
            @if (!Model.Bill.Payments.Any())
            {
                <div class="th-empty m-4"><i class="bi bi-cash-stack"></i><h5 class="mt-2">No payments yet</h5></div>
            }
            else
            {
                <table class="table align-middle mb-0">
                    <thead><tr><th>Receipt #</th><th>Method</th><th class="text-end">Amount (₦)</th><th>Reference</th><th>Received</th><th>Status</th></tr></thead>
                    <tbody>
                    @foreach (var p in Model.Bill.Payments.OrderByDescending(x => x.ReceivedAt))
                    {
                        <tr>
                            <td><span class="font-monospace">@p.ReceiptNumber</span></td>
                            <td>@MethodLabel(p.Method)</td>
                            <td class="text-end fw-semibold">@p.Amount.ToString("N0")</td>
                            <td><small class="text-muted">@p.Reference</small></td>
                            <td><small>@p.ReceivedAt.ToLocalTime().ToString("dd MMM HH:mm")</small></td>
                            <td>@if (p.Status == PaymentStatus.Recorded) { <span class="th-pill th-pill-success">Recorded</span> } else { <span class="th-pill th-pill-danger">Reversed</span> }</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div></div>
    </div>

    <div class="col-lg-4">
        <div class="th-card mb-3"><div class="th-card-body">
            <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-calculator me-1"></i> Totals</h6>
            <dl class="row mb-0">
                <dt class="col-7">Gross</dt><dd class="col-5 text-end">₦@Model.Bill.GrossAmount.ToString("N2")</dd>
                <dt class="col-7">Discount</dt><dd class="col-5 text-end text-danger">−₦@Model.Bill.DiscountAmount.ToString("N2")</dd>
                <dt class="col-7 border-top pt-2">Net</dt><dd class="col-5 text-end border-top pt-2 fw-semibold">₦@Model.Bill.NetAmount.ToString("N2")</dd>
                <dt class="col-7">Paid</dt><dd class="col-5 text-end text-success">₦@Model.Bill.PaidAmount.ToString("N2")</dd>
                <dt class="col-7 border-top pt-2 fw-bold">Balance</dt><dd class="col-5 text-end border-top pt-2 fw-bold fs-5">₦@Model.Bill.Balance.ToString("N2")</dd>
            </dl>
        </div></div>

        @if (Model.Bill.Status is BillStatus.Open or BillStatus.PartiallyPaid)
        {
            <div class="th-card" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.BillsDiscount"><div class="th-card-body">
                <h6 class="text-uppercase text-muted small mb-2"><i class="bi bi-tag me-1"></i> Apply discount</h6>
                <form asp-action="Discount" method="post" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.BillsDiscount">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="BillId" value="@Model.Bill.Id" />
                    <div class="mb-2">
                        <label class="form-label">Amount (₦)</label>
                        <input name="DiscountAmount" type="number" step="0.01" min="0" class="form-control" value="@Model.Bill.DiscountAmount" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Reason</label>
                        <input name="Reason" class="form-control" required maxlength="200" placeholder="Required" />
                    </div>
                    <button class="btn btn-outline-primary w-100"><i class="bi bi-save me-1"></i> Apply</button>
                </form>
            </div></div>
        }
    </div>
</div>

@section Scripts {
<script>
async function aiBillCheck(id) {
    var card = document.getElementById('aiBillCheckCard');
    var out = document.getElementById('aiBillCheckOut');
    card.style.display = 'block';
    out.textContent = 'Checking…';
    try {
        var r = await fetch('/Cashier/CheckBillAnomaly?id=' + id, { method: 'POST' });
        var j = await r.json();
        out.textContent = j.ok ? j.text : ('AI failed: ' + (j.error || 'unknown'));
    } catch (e) { out.textContent = 'AI failed: ' + e.message; }
}
</script>
}
