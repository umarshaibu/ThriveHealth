@model ThriveHealth.Web.Models.Billing.CashierShift
@using ThriveHealth.Web.Models.Billing
@{
    ViewData["Title"] = $"Shift report · {Model.ShiftNumber}";
    var summary = ViewBag.Summary as ThriveHealth.Web.Services.ShiftSummary;
    var posted = Model.Payments.Where(p => p.Status == PaymentStatus.Recorded).OrderByDescending(p => p.ReceivedAt).ToList();

    string MethodLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash => "Cash", PaymentMethod.Pos => "POS", PaymentMethod.BankTransfer => "Transfer",
        PaymentMethod.MobileMoney => "Mobile", PaymentMethod.Cheque => "Cheque", _ => m.ToString()
    };
    var expectedCash = (summary?.Cash ?? 0) + Model.OpeningFloat;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
    <div>
        <h1 class="th-section-title">Shift report</h1>
        <p class="th-section-sub mb-0">@Model.ShiftNumber · @Model.Cashier?.FullName</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Bills" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Bills</a>
        <button class="btn btn-primary" onclick="window.print()"><i class="bi bi-printer me-1"></i> Print</button>
    </div>
</div>

<div class="th-card mb-3"><div class="th-card-body">
    <div class="row">
        <div class="col-md-6">
            <h5 class="mb-1">Cashier shift report</h5>
            <div class="text-muted small">Shift <span class="font-monospace">@Model.ShiftNumber</span></div>
            <div class="mt-2"><strong>Cashier:</strong> @Model.Cashier?.FullName (@Model.Cashier?.StaffNumber)</div>
            <div><strong>Opened:</strong> @Model.OpenedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
            <div><strong>Closed:</strong> @(Model.ClosedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "— still open —")</div>
            <div><strong>Status:</strong> <span class="th-pill @(Model.Status == CashierShiftStatus.Closed ? "th-pill-success" : "th-pill-warning")">@Model.Status</span></div>
        </div>
        <div class="col-md-6">
            <h6 class="text-uppercase text-muted small mb-2">Cash reconciliation</h6>
            <dl class="row mb-0">
                <dt class="col-7">Opening float</dt><dd class="col-5 text-end">₦@Model.OpeningFloat.ToString("N2")</dd>
                <dt class="col-7">Cash takings</dt><dd class="col-5 text-end">₦@summary?.Cash.ToString("N2")</dd>
                <dt class="col-7 border-top pt-2 fw-bold">Expected cash</dt><dd class="col-5 text-end border-top pt-2 fw-bold">₦@expectedCash.ToString("N2")</dd>
                <dt class="col-7">Counted cash</dt><dd class="col-5 text-end">₦@Model.CountedCash.ToString("N2")</dd>
                <dt class="col-7 border-top pt-2 fw-bold">Variance</dt>
                <dd class="col-5 text-end border-top pt-2 fw-bold @(Model.Variance < 0 ? "text-danger" : Model.Variance > 0 ? "text-warning" : "")">@(Model.Variance < 0 ? "−" : Model.Variance > 0 ? "+" : "")₦@Math.Abs(Model.Variance).ToString("N2")</dd>
            </dl>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <div class="mt-3 small"><strong>Notes:</strong> @Model.Notes</div>
    }
</div></div>

<div class="th-card mb-3"><div class="th-card-body">
    <h6 class="text-uppercase text-muted small mb-3"><i class="bi bi-pie-chart me-1"></i> Takings by method</h6>
    <table class="table table-sm mb-0">
        <thead><tr><th>Method</th><th class="text-end">Amount (₦)</th></tr></thead>
        <tbody>
            <tr><td>Cash</td><td class="text-end">@summary?.Cash.ToString("N2")</td></tr>
            <tr><td>POS</td><td class="text-end">@summary?.Pos.ToString("N2")</td></tr>
            <tr><td>Bank transfer</td><td class="text-end">@summary?.Transfer.ToString("N2")</td></tr>
            <tr><td>Mobile money</td><td class="text-end">@summary?.MobileMoney.ToString("N2")</td></tr>
            <tr><td>Cheque</td><td class="text-end">@summary?.Cheque.ToString("N2")</td></tr>
            <tr class="table-secondary"><th>Total</th><th class="text-end">@summary?.Total.ToString("N2")</th></tr>
        </tbody>
    </table>
</div></div>

<div class="th-card"><div class="th-card-body p-0">
    <div class="p-3 border-bottom"><h6 class="mb-0"><i class="bi bi-receipt me-1"></i> Receipts (@posted.Count)</h6></div>
    @if (!posted.Any())
    {
        <div class="th-empty m-4"><i class="bi bi-cash-stack"></i><h5 class="mt-2">No payments recorded under this shift</h5></div>
    }
    else
    {
        <table class="table align-middle mb-0">
            <thead><tr><th>Time</th><th>Receipt #</th><th>Patient</th><th>Bill #</th><th>Method</th><th>Reference</th><th class="text-end">Amount (₦)</th></tr></thead>
            <tbody>
            @foreach (var p in posted)
            {
                <tr>
                    <td>@p.ReceivedAt.ToLocalTime().ToString("HH:mm")</td>
                    <td><span class="font-monospace">@p.ReceiptNumber</span></td>
                    <td>@p.Bill?.Patient?.FullName</td>
                    <td><span class="font-monospace small">@p.Bill?.BillNumber</span></td>
                    <td>@MethodLabel(p.Method)</td>
                    <td><small class="text-muted">@p.Reference</small></td>
                    <td class="text-end fw-semibold">@p.Amount.ToString("N2")</td>
                </tr>
            }
            </tbody>
        </table>
    }
</div></div>
