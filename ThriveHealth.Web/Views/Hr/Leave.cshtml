@model IReadOnlyList<ThriveHealth.Web.Models.Hr.LeaveRequest>
@using ThriveHealth.Web.Models.Hr
@{
    ViewData["Title"] = "Leave requests";
    var current = ViewBag.Status as LeaveStatus?;

    string Tone(LeaveStatus s) => s switch
    {
        LeaveStatus.Submitted => "th-pill-warning",
        LeaveStatus.Approved => "th-pill-success",
        LeaveStatus.Rejected => "th-pill-danger",
        LeaveStatus.Cancelled => "th-pill-muted",
        _ => "th-pill-muted"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="th-section-title">Leave requests</h1>
        <p class="th-section-sub mb-0">@Model.Count request@(Model.Count == 1 ? "" : "s") · most recent first</p>
    </div>
    <a asp-action="RequestLeave" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.LeaveRequest" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Request leave</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

<div class="d-flex gap-2 mb-3 flex-wrap">
    <a asp-action="Leave" class="btn btn-sm @(current is null ? "btn-primary" : "btn-outline-secondary")">All</a>
    <a asp-action="Leave" asp-route-status="@LeaveStatus.Submitted" class="btn btn-sm @(current == LeaveStatus.Submitted ? "btn-primary" : "btn-outline-secondary")">Submitted</a>
    <a asp-action="Leave" asp-route-status="@LeaveStatus.Approved" class="btn btn-sm @(current == LeaveStatus.Approved ? "btn-primary" : "btn-outline-secondary")">Approved</a>
    <a asp-action="Leave" asp-route-status="@LeaveStatus.Rejected" class="btn btn-sm @(current == LeaveStatus.Rejected ? "btn-primary" : "btn-outline-secondary")">Rejected</a>
</div>

<div class="th-card"><div class="th-card-body p-0">
@if (!Model.Any())
{
    <div class="th-empty m-4"><i class="bi bi-calendar-x"></i><h5 class="mt-2">No leave requests</h5></div>
}
else
{
    <table class="table align-middle mb-0">
        <thead><tr><th>Staff</th><th>Type</th><th>Dates</th><th>Days</th><th>Status</th><th>Decided by</th><th class="text-end"></th></tr></thead>
        <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td><strong>@l.Staff?.FullName</strong><div class="small text-muted">@l.Staff?.Designation</div></td>
                <td><span class="th-pill th-pill-muted">@l.Type</span></td>
                <td>@l.StartDate.ToString("dd MMM") – @l.EndDate.ToString("dd MMM yyyy")</td>
                <td>@l.Days</td>
                <td><span class="th-pill @Tone(l.Status)">@l.Status</span></td>
                <td>@if (l.DecidedAt.HasValue) { <span>@l.DecidedBy?.FullName</span><div class="small text-muted">@l.DecidedAt.Value.ToString("dd MMM HH:mm")</div> } else { <span class="text-muted">—</span> }</td>
                <td class="text-end">
                    @if (l.Status == LeaveStatus.Submitted)
                    {
                        <form asp-action="DecideLeave" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.HrRead">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@l.Id" />
                            <input type="hidden" name="decision" value="@LeaveStatus.Approved" />
                            <button class="btn btn-sm btn-success" onclick="return confirm('Approve leave?')"><i class="bi bi-check-lg"></i></button>
                        </form>
                        <form asp-action="DecideLeave" method="post" class="d-inline" asp-permission="@ThriveHealth.Web.Models.Identity.Permissions.HrRead">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@l.Id" />
                            <input type="hidden" name="decision" value="@LeaveStatus.Rejected" />
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Reject leave?')"><i class="bi bi-x-lg"></i></button>
                        </form>
                    }
                </td>
            </tr>
            @if (!string.IsNullOrEmpty(l.Reason))
            {
                <tr><td colspan="7" class="bg-light"><small class="text-muted"><i class="bi bi-chat-left-text me-1"></i>@l.Reason</small></td></tr>
            }
        }
        </tbody>
    </table>
}
</div></div>
